<%- include('layouts/header') %>

    <style>
        :root {
            --q-blue: #2563eb;
            --q-blue-d: #1d4ed8;
            --q-blue-l: #eff6ff;
            --q-green: #16a34a;
            --q-green-d: #15803d;
            --q-green-l: #f0fdf4;
            --q-red: #dc2626;
            --q-red-d: #b91c1c;
            --q-red-l: #fef2f2;
            --q-amber: #d97706;
            --q-amber-d: #b45309;
            --q-amber-l: #fffbeb;
            --q-teal: #0891b2;
            --q-teal-l: #ecfeff;
            --q-orange: #ea580c;
            --border: #e2e8f0;
            --text: #0f172a;
            --muted: #64748b;
            --faint: #94a3b8;
            --rc: 16px;
        }

        * {
            box-sizing: border-box;
        }

        .q {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        /* ── HEADER ── */
        .q-hdr {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 24px;
        }

        .q-hdr-l h1 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 4px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .q-hdr-l p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

        .q-hdr-r {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 9px 16px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid;
            transition: all .15s;
            white-space: nowrap;
            font-family: inherit;
        }

        .btn svg {
            width: 15px;
            height: 15px;
            flex-shrink: 0;
        }

        .btn-outline {
            background: #fff;
            border-color: var(--border);
            color: #374151;
        }

        .btn-outline:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

        .btn-blue {
            background: var(--q-blue);
            border-color: var(--q-blue);
            color: #fff;
        }

        .btn-blue:hover {
            background: var(--q-blue-d);
        }

        .btn-red {
            background: var(--q-red);
            border-color: var(--q-red);
            color: #fff;
        }

        .btn-red:hover {
            background: var(--q-red-d);
        }

        .btn-sm {
            padding: 5px 12px;
            font-size: 12px;
            border-radius: 8px;
        }

        .btn:disabled {
            opacity: .5;
            cursor: not-allowed;
        }

        /* Live chip */
        .live-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 13px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
            background: var(--q-green-l);
            border: 1px solid #bbf7d0;
            color: var(--q-green);
        }

        .live-chip .ldot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--q-green);
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
                transform: scale(1)
            }

            50% {
                opacity: .35;
                transform: scale(.75)
            }
        }

        /* ── STAT CARDS — single strip with dividers ── */
        .q-cards {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            background: #fff;
            border-radius: 16px;
            border: 1px solid #e8eaed;
            overflow: hidden;
            margin-bottom: 20px;
        }


        .q-card {
            padding: 20px 22px 18px;
            border-right: 1px solid #e8eaed;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            gap: 0;
            position: relative;
            overflow: hidden;
            transition: background .15s;
        }

        .q-card:last-child {
            border-right: none;
        }

        .q-card:hover {
            background: #fafbff;
        }

        /* Active — biru solid */
        .q-card.qc-active {
            background: #2563eb;
            border-color: #2563eb;
        }

        .q-card.qc-active:hover {
            background: #1d4ed8;
        }

        .q-card.qc-active .card-lbl {
            color: rgba(255, 255, 255, .70);
        }

        .q-card.qc-active .card-val {
            color: #fff;
        }

        .q-card.qc-active .card-sub {
            color: rgba(255, 255, 255, .60);
        }

        .q-card.qc-active .card-pill {
            background: rgba(255, 255, 255, .20) !important;
            color: rgba(255, 255, 255, .90) !important;
        }

        .q-card.qc-active .sp-line {
            stroke: rgba(255, 255, 255, .70) !important;
        }

        .q-card.qc-active .sp-fill {
            fill: rgba(255, 255, 255, .12) !important;
        }

        .q-card.qc-active .sp-dot {
            fill: #fff !important;
        }

        /* label */
        .card-lbl {
            font-size: 12px;
            font-weight: 500;
            color: #64748b;
            margin-bottom: 10px;
            letter-spacing: .1px;
            transition: color .15s;
        }

        /* body */
        .card-body {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 8px;
        }

        .card-left {
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        /* angka */
        .card-val {
            font-size: 30px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -1.2px;
            line-height: 1;
            transition: color .15s;
        }

        @media(max-width:1400px) {
            .card-val {
                font-size: 26px;
            }
        }

        /* meta */
        .card-meta {
            display: flex;
            align-items: center;
            gap: 5px;
            margin-top: 6px;
            flex-wrap: wrap;
        }

        .card-pill {
            display: inline-flex;
            align-items: center;
            gap: 2px;
            padding: 1px 6px;
            border-radius: 100px;
            font-size: 10.5px;
            font-weight: 700;
            white-space: nowrap;
            flex-shrink: 0;
            transition: all .15s;
        }

        .pill-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .pill-green {
            background: #dcfce7;
            color: #16a34a;
        }

        .pill-slate {
            background: #f1f5f9;
            color: #475569;
        }

        .pill-teal {
            background: #cffafe;
            color: #0e7490;
        }

        .pill-orange {
            background: #ffedd5;
            color: #c2410c;
        }

        .card-sub {
            font-size: 11px;
            color: #94a3b8;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            transition: color .15s;
        }

        /* sparkline */
        .card-spark {
            flex-shrink: 0;
            width: 72px;
            height: 36px;
        }

        .card-spark svg {
            width: 72px;
            height: 36px;
        }

        .sp-fill {
            transition: fill .3s;
        }

        .sp-line {
            stroke-width: 1.8;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .sp-dot {}

        /* ── Responsive stat cards ── */
        @media(max-width:1000px) {
            .q-cards {
                grid-template-columns: repeat(3, 1fr);
            }

            .q-card:nth-child(3) {
                border-right: none;
            }

            .q-card:nth-child(-n+3) {
                border-bottom: 1px solid #e8eaed;
            }

            .q-card:nth-last-child(-n+2) {
                border-bottom: none;
            }
        }

        @media(max-width:600px) {
            .q-cards {
                grid-template-columns: repeat(2, 1fr);
            }

            .q-card {
                border-right: none;
                border-bottom: 1px solid #e8eaed;
            }

            .q-card:nth-child(odd) {
                border-right: 1px solid #e8eaed;
            }

            .q-card:nth-child(even) {
                border-right: none;
            }

            .q-card:nth-last-child(-n+2) {
                border-bottom: none;
            }
        }

        @media(max-width:400px) {
            .q-cards {
                grid-template-columns: 1fr;
            }

            .q-card {
                border-right: none !important;
                border-bottom: 1px solid #e8eaed;
            }

            .q-card:last-child {
                border-bottom: none;
            }
        }

        .q-card.qc-active {
            border-color: #2563eb;
        }


        /* ── CONNECTION BANNER ── */
        .conn-banner {
            border-radius: 10px;
            padding: 11px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 16px;
            font-size: 13px;
            font-weight: 500;
            border: 1.5px solid;
        }

        .conn-success {
            background: var(--q-green-l);
            color: #15803d;
            border-color: #bbf7d0;
        }

        .conn-info {
            background: var(--q-blue-l);
            color: var(--q-blue);
            border-color: #bfdbfe;
        }

        .conn-error {
            background: var(--q-red-l);
            color: var(--q-red);
            border-color: #fecaca;
        }

        /* ── TABLE ── */
        .q-tbl-wrap {
            background: #fff;
            border: 1.5px solid var(--border);
            border-radius: var(--rc);
            overflow: hidden;
        }

        .q-tbl-hdr {
            padding: 14px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid #f1f5f9;
            flex-wrap: wrap;
            gap: 10px;
        }

        .q-tbl-title {
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .q-count {
            font-size: 11px;
            font-weight: 600;
            background: #f1f5f9;
            color: var(--muted);
            padding: 2px 9px;
            border-radius: 20px;
        }

        .search-wrap {
            position: relative;
        }

        .search-wrap svg {
            position: absolute;
            left: 11px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--faint);
            pointer-events: none;
            width: 14px;
            height: 14px;
        }

        .search-wrap input {
            padding: 8px 12px 8px 33px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-size: 13px;
            outline: none;
            background: #f8fafc;
            font-family: inherit;
            color: var(--text);
            width: 220px;
            transition: all .15s;
        }

        .search-wrap input:focus {
            border-color: var(--q-blue);
            background: #fff;
            box-shadow: 0 0 0 3px #2563eb14;
        }

        .q-tbl-hdr select {
            padding: 8px 12px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-size: 13px;
            outline: none;
            background: #f8fafc;
            color: #374151;
            cursor: pointer;
            font-family: inherit;
        }

        .q-tbl-hdr select:focus {
            border-color: var(--q-blue);
        }

        .q-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: auto;
        }

        .q-table thead tr {
            background: #fafbfc;
        }

        .q-table th {
            padding: 11px 14px;
            font-size: 10px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: .06em;
            text-align: left;
            border-bottom: 1px solid #eef2f7;
            white-space: nowrap;
        }

        .q-table tbody tr {
            border-bottom: 1px solid #f5f7fa;
            transition: background .15s;
        }

        .q-table tbody tr:hover {
            background: #fafbff;
        }

        .q-table tbody tr:last-child {
            border-bottom: none;
        }

        .q-table tbody tr.row-disabled {
            opacity: .6;
        }

        .q-table td {
            padding: 12px 14px;
            font-size: 13px;
            color: #374151;
            vertical-align: middle;
        }

        .num-cell {
            color: #94a3b8;
            font-size: 11px;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            font-family: 'Geist Mono', ui-monospace, Menlo, monospace;
            width: 36px;
        }

        .name-cell {
            font-weight: 700;
            color: var(--text);
            cursor: pointer;
            letter-spacing: -.2px;
            line-height: 1.3;
            font-size: 13px;
        }

        .name-cell:hover {
            color: var(--q-blue);
        }

        .comment-sub {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 2px;
            font-weight: 500;
        }

        .target-cell {
            min-width: 220px;
            max-width: 360px;
        }

        .ip-chips {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
        }

        .ip-chip {
            font-family: 'Geist Mono', ui-monospace, Menlo, monospace;
            font-size: 10.5px;
            font-weight: 600;
            background: #f1f5f9;
            color: #475569;
            border: 1px solid #e2e8f0;
            border-radius: 5px;
            padding: 1.5px 6px;
            letter-spacing: -.2px;
            cursor: pointer;
            transition: all .15s;
        }

        .ip-chip:hover {
            background: #eff6ff;
            color: #1d4ed8;
            border-color: #bfdbfe;
        }

        .ip-chip.single {
            background: #eff6ff;
            color: #1d4ed8;
            border-color: #dbeafe;
        }

        .ip-more {
            font-size: 10.5px;
            font-weight: 700;
            color: #64748b;
            background: #fff;
            border: 1px dashed #cbd5e1;
            border-radius: 5px;
            padding: 1.5px 6px;
            cursor: pointer;
            transition: all .15s;
            font-family: inherit;
        }

        .ip-more:hover {
            background: #f8fafc;
            color: var(--q-blue);
            border-color: var(--q-blue);
            border-style: solid;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 10.5px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .05em;
        }

        .pill-on {
            background: var(--q-green-l);
            color: #15803d;
        }

        .pill-off {
            background: #f1f5f9;
            color: #94a3b8;
        }

        .sdot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: currentColor;
        }

        .sdot-on {
            animation: pulse 2s infinite;
        }

        .bw-cell {
            min-width: 180px;
        }

        .bw-line {
            display: flex;
            align-items: center;
            gap: 7px;
            margin-bottom: 5px;
        }

        .bw-line:last-child {
            margin-bottom: 0;
        }

        .bw-arr {
            width: 13px;
            height: 13px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 8px;
            font-weight: 900;
            line-height: 1;
        }

        .arr-rx {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .arr-tx {
            background: #ffedd5;
            color: #c2410c;
        }

        .bw-val {
            font-size: 11.5px;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            min-width: 66px;
            letter-spacing: -.2px;
        }

        .bw-val.rx {
            color: #1d4ed8;
        }

        .bw-val.tx {
            color: #c2410c;
        }

        .bw-bar {
            flex: 1;
            height: 4px;
            background: #f1f5f9;
            border-radius: 2px;
            overflow: hidden;
            min-width: 30px;
        }

        .bw-fill {
            height: 100%;
            border-radius: 2px;
            transition: width .5s ease, background .3s;
        }

        .bw-pct {
            font-size: 10px;
            font-weight: 700;
            color: #94a3b8;
            width: 28px;
            text-align: right;
            flex-shrink: 0;
            font-variant-numeric: tabular-nums;
        }

        .bw-pct.warn {
            color: #c2410c;
        }

        .bw-pct.danger {
            color: #dc2626;
        }

        .bw-limit-sub {
            font-size: 10px;
            color: #94a3b8;
            font-family: 'Geist Mono', ui-monospace, Menlo, monospace;
            margin-top: 3px;
            padding-top: 3px;
            border-top: 1px dashed #eef2f7;
            display: flex;
            gap: 10px;
        }

        .bw-limit-sub span {
            color: #64748b;
            font-weight: 600;
        }

        .bw-limit-sub span.unlim {
            color: #cbd5e1;
            font-style: italic;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .prio-box {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            gap: 1px;
        }

        .prio-val {
            font-size: 14px;
            font-weight: 800;
            color: var(--text);
            line-height: 1;
            letter-spacing: -.5px;
            font-variant-numeric: tabular-nums;
        }

        .prio-lbl {
            font-size: 8px;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: .05em;
        }

        .prio-box.hi {
            background: #fef2f2;
            border-color: #fecaca;
        }

        .prio-box.hi .prio-val {
            color: #b91c1c;
        }

        .prio-box.hi .prio-lbl {
            color: #dc2626;
        }

        .prio-box.mid {
            background: #fffbeb;
            border-color: #fde68a;
        }

        .prio-box.mid .prio-val {
            color: #b45309;
        }

        .prio-box.mid .prio-lbl {
            color: #d97706;
        }

        .act-btns {
            display: flex;
            gap: 4px;
            justify-content: flex-end;
        }

        .act-btn {
            width: 30px;
            height: 30px;
            padding: 0;
            border-radius: 9px;
            border: 1px solid #e8eaed;
            background: #fff;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all .15s;
            font-family: inherit;
            color: #64748b;
        }

        .act-btn svg {
            width: 15px;
            height: 15px;
            stroke-width: 1.8;
        }

        .act-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 2px 6px -1px rgba(15, 23, 42, .08);
        }

        .act-edit:hover {
            color: var(--q-blue);
            border-color: #bfdbfe;
            background: var(--q-blue-l);
        }

        .act-pause {
            color: #b45309;
        }

        .act-pause:hover {
            color: #b45309;
            border-color: #fde68a;
            background: var(--q-amber-l);
        }

        .act-play {
            color: #15803d;
        }

        .act-play:hover {
            color: #15803d;
            border-color: #bbf7d0;
            background: var(--q-green-l);
        }

        .act-del {
            color: #dc2626;
        }

        .act-del:hover {
            color: #dc2626;
            border-color: #fecaca;
            background: var(--q-red-l);
        }

        /* Empty */
        .tbl-empty {
            text-align: center;
            padding: 60px 20px;
            color: var(--faint);
        }

        .tbl-empty svg {
            width: 36px;
            height: 36px;
            opacity: .35;
            margin-bottom: 10px;
        }

        .tbl-empty p {
            font-size: 13px;
            margin: 0;
        }

        /* ── DETAIL PANEL (modernized) ── */
        #detailPanel {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, .5);
            z-index: 1100;
            display: none;
            align-items: flex-end;
            justify-content: center;
            backdrop-filter: blur(2px);
        }

        @media(min-width:640px) {
            #detailPanel {
                align-items: center;
            }
        }

        .detail-box {
            background: #fff;
            border-radius: 20px 20px 0 0;
            width: 100%;
            max-width: 680px;
            max-height: 92vh;
            overflow-y: auto;
            font-family: 'Plus Jakarta Sans', sans-serif;
            box-shadow: 0 20px 60px -15px rgba(15, 23, 42, .3);
        }

        @media(min-width:640px) {
            .detail-box {
                border-radius: 20px;
                max-height: 88vh;
            }
        }

        /* Header with soft gradient */
        .detail-hdr {
            padding: 22px 26px 18px;
            background: linear-gradient(135deg, var(--q-blue-l) 0%, #fff 60%);
            border-bottom: 1px solid #f0f4f8;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
        }

        .detail-hdr-l h3 {
            font-size: 18px;
            font-weight: 800;
            color: var(--text);
            margin: 0;
            letter-spacing: -.3px;
            line-height: 1.2;
        }

        .detail-chip {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            margin-top: 6px;
            font-family: 'Geist Mono', ui-monospace, Menlo, monospace;
            font-size: 11px;
            font-weight: 600;
            background: #fff;
            color: var(--q-blue-d);
            border: 1px solid #dbeafe;
            border-radius: 5px;
            padding: 2px 7px;
        }

        .detail-close {
            width: 32px;
            height: 32px;
