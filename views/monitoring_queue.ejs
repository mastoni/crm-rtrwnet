                            <input class="form-control" id="qMaxUp">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Priority</label>
                            <input class="form-control" id="qPriority" type="number" min="1" max="8" value="8">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Disabled</label>
                            <select class="form-control" id="qDisabled">
                                <option value="false">No</option>
                                <option value="true">Yes</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Comment</label>
                        <input class="form-control" id="qComment">
                    </div>
                    <div class="q-modal-footer">
                        <button type="button" class="btn btn-outline" id="cancelModal">Batal</button>
                        <button type="submit" class="btn btn-blue" id="saveQueue">Simpan</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- DETAIL PANEL -->
        <div class="q-modal-overlay" id="detailPanel">
            <div class="q-modal-box" style="width:800px; max-width:96vw;">
                <div class="q-modal-hdr">
                    <h3 id="detailName">Queue Detail</h3>
                    <button class="q-modal-close" id="btnCloseDetail">×</button>
                </div>
                <div style="display:flex;gap:20px;margin-bottom:15px;flex-wrap:wrap;">
                    <div><span class="form-label">Target:</span> <span id="detailTarget" style="font-size:13px;"></span>
                    </div>
                    <div><span class="form-label">Limit ↓:</span> <span id="detailMaxDown"
                            style="font-size:13px;"></span></div>
                    <div><span class="form-label">Limit ↑:</span> <span id="detailMaxUp" style="font-size:13px;"></span>
                    </div>
                    <div><span class="form-label">Status:</span> <span id="detailStatus" style="font-size:13px;"></span>
                    </div>
                    <div id="detailPriorityWrap" style="font-size:13px;"></div>
                </div>
                <div><span class="form-label">Comment:</span> <span id="detailComment" style="font-size:13px;"></span>
                </div>
                <div style="display:flex;gap:20px;margin-bottom:15px;flex-wrap:wrap;margin-top:10px;">
                    <div><span class="form-label">Bytes ↓:</span> <span id="detailBytesDown"
                            style="font-size:13px;"></span></div>
                    <div><span class="form-label">Bytes ↑:</span> <span id="detailBytesUp"
                            style="font-size:13px;"></span></div>
                </div>
                <div style="border-bottom:2px solid #f1f5f9;margin-bottom:15px;display:flex;">
                    <button class="btn btn-outline"
                        style="border-bottom-left-radius:0; border-bottom-right-radius:0; border-bottom:none;"
                        id="tabLive" onclick="QueuePage.switchDetailTab('live')">Live</button>
                    <button class="btn btn-outline"
                        style="border-bottom-left-radius:0; border-bottom-right-radius:0; border-bottom:none; margin-left:-1px;"
                        id="tabHistory" onclick="QueuePage.switchDetailTab('history')">History</button>
                </div>
                <div id="paneLive">
                    <div style="display:flex;gap:20px;margin-bottom:10px;">
                        <div style="color:#06b6d4;font-weight:bold;font-size:13px;">DL: <span id="detailRxRate">0</span>
                            Mbps</div>
                        <div style="color:#f59e0b;font-weight:bold;font-size:13px;">UL: <span id="detailTxRate">0</span>
                            Mbps</div>
                    </div>
                    <div id="detailChart"></div>
                </div>
                <div id="paneHistory" style="display:none;">
                    <div style="display:flex;gap:10px;margin-bottom:10px;">
                        <button class="btn btn-outline btn-sm hist-btn"
                            onclick="QueuePage.switchHistoryRange('1h')">1h</button>
                        <button class="btn btn-outline btn-sm hist-btn"
                            onclick="QueuePage.switchHistoryRange('24h')">24h</button>
                    </div>
                    <div id="historyStatus" style="color:#94a3b8;font-size:12px;margin-bottom:10px;"></div>
                    <div id="historyChart"></div>
                </div>
            </div>
        </div>

    </main>

    <%- include('layouts/footer') %>