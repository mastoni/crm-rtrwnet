<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description"
    content="CRM RT/RW Net — Platform All-in-One untuk Internet Service Provider. Kelola pelanggan, billing, MikroTik, monitoring, dan ticketing dalam satu dashboard modern.">
  <title>CRM RT/RW Net — Dashboard All-in-One untuk ISP</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&family=DM+Mono:wght@400;500&display=swap"
    rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box
    }

    html {
      scroll-behavior: smooth
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: #fff;
      color: #0F172A;
      overflow-x: hidden
    }

    .mono {
      font-family: 'DM Mono', monospace
    }

    /* ── Navbar ── */
    #navbar {
      position: fixed;
      top: 0;
      width: 100%;
      z-index: 100;
      background: rgba(255, 255, 255, .9);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(226, 232, 240, .8);
      transition: box-shadow .3s
    }

    #navbar.scrolled {
      box-shadow: 0 4px 30px rgba(30, 58, 138, .10)
    }

    .nav-inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none
    }

    .nav-logo-icon {
      width: 36px;
      height: 36px;
      background: linear-gradient(135deg, #1E3A8A, #2563EB, #0EA5E9);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center
    }

    .nav-logo-text {
      font-weight: 800;
      font-size: 17px;
      color: #0F172A;
      letter-spacing: -.02em
    }

    .nav-logo-text span {
      font-weight: 400;
      color: #94A3B8
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 28px
    }

    .nav-links a {
      font-size: 13.5px;
      font-weight: 600;
      color: #64748B;
      text-decoration: none;
      transition: color .2s
    }

    .nav-links a:hover {
      color: #2563EB
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 10px
    }

    .btn-outline {
      padding: 8px 18px;
      border: 1.5px solid #CBD5E1;
      border-radius: 12px;
      font-size: 13px;
      font-weight: 700;
      color: #334155;
      background: #fff;
      text-decoration: none;
      transition: all .2s;
      cursor: pointer
    }

    .btn-outline:hover {
      border-color: #2563EB;
      color: #2563EB
    }

    .btn-primary {
      padding: 9px 20px;
      background: linear-gradient(135deg, #1E3A8A, #2563EB, #0EA5E9);
      border-radius: 12px;
      font-size: 13px;
      font-weight: 700;
      color: #fff;
      text-decoration: none;
      border: none;
      cursor: pointer;
      box-shadow: 0 4px 20px rgba(37, 99, 235, .35);
      transition: all .25s;
      display: inline-flex;
      align-items: center;
      gap: 6px
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(37, 99, 235, .45)
    }

    .btn-primary-lg {
      padding: 14px 32px;
      font-size: 15px;
      border-radius: 16px;
      gap: 8px
    }

    .btn-ghost-lg {
      padding: 13px 28px;
      border: 2px solid #E2E8F0;
      border-radius: 16px;
      font-size: 15px;
      font-weight: 700;
      color: #334155;
      background: #fff;
      text-decoration: none;
      transition: all .25s;
      display: inline-flex;
      align-items: center;
      gap: 7px
    }

    .btn-ghost-lg:hover {
      border-color: #2563EB;
      color: #2563EB;
      background: rgba(37, 99, 235, .04)
    }

    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 4px
    }

    .hamburger span {
      width: 22px;
      height: 2px;
      background: #334155;
      border-radius: 2px;
      transition: all .3s
    }

    @media(max-width:768px) {
      .nav-links {
        display: none
      }

      .hamburger {
        display: flex
      }
    }

    /* ── Gradient text ── */
    .gt {
      background: linear-gradient(120deg, #1E3A8A, #2563EB, #0EA5E9);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text
    }

    /* ── Hero ── */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding-top: 64px;
      position: relative;
      overflow: hidden;
      background: radial-gradient(ellipse 70% 55% at 70% -5%, rgba(30, 58, 138, .12) 0%, transparent 65%),
        radial-gradient(ellipse 45% 45% at 5% 85%, rgba(14, 165, 233, .09) 0%, transparent 55%), #F8FBFF
    }

    .hero-inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 60px 24px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
      width: 100%
    }

    @media(max-width:1024px) {
      .hero-inner {
        grid-template-columns: 1fr;
        gap: 40px;
        text-align: center
      }
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 11.5px;
      font-weight: 800;
      letter-spacing: .1em;
      text-transform: uppercase;
      background: linear-gradient(135deg, #DBEAFE, #E0F2FE);
      color: #1E3A8A;
      border: 1px solid #BFDBFE;
      margin-bottom: 20px
    }

    .hero-eyebrow .pulse {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #10B981;
      animation: pulse 2s infinite
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1;
        transform: scale(1)
      }

      50% {
        opacity: .6;
        transform: scale(.85)
      }
    }

    .hero-title {
      font-size: clamp(2.4rem, 5vw, 3.8rem);
      font-weight: 900;
      line-height: 1.06;
      letter-spacing: -.03em;
      color: #0F172A;
      margin-bottom: 20px
    }

    .hero-desc {
      font-size: 17px;
      color: #64748B;
      line-height: 1.72;
      margin-bottom: 36px;
      max-width: 480px;
      font-weight: 400
    }

    @media(max-width:1024px) {
      .hero-desc {
        margin: 0 auto 36px
      }
    }

    .hero-btns {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-bottom: 44px
    }

    @media(max-width:1024px) {
      .hero-btns {
        justify-content: center
      }
    }

    .hero-stats {
      display: flex;
      gap: 24px;
      flex-wrap: wrap
    }

    @media(max-width:1024px) {
      .hero-stats {
        justify-content: center
      }
    }

    .hstat {
      display: flex;
      align-items: center;
      gap: 10px
    }

    .hstat-ico {
      width: 38px;
      height: 38px;
      border-radius: 11px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0
    }

    .hstat-lbl {
      font-size: 13px;
      font-weight: 800;
      color: #1E293B
    }

    .hstat-sub {
      font-size: 11px;
      color: #94A3B8;
      font-weight: 500
    }

    /* ── Dashboard mockup ── */
    .mockup-wrap {
      position: relative;
      display: flex;
      justify-content: flex-end
    }

    @media(max-width:1024px) {
      .mockup-wrap {
        justify-content: center
      }
    }

    .mockup-glow {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none
    }

    .mockup-glow-ball {
      width: 320px;
      height: 320px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(30, 58, 138, .14), transparent 70%);
      filter: blur(28px)
    }

    .mockup-card {
      width: 320px;
      background: #fff;
      border-radius: 22px;
      border: 1px solid #E2E8F0;
      box-shadow: 0 28px 60px rgba(30, 58, 138, .18);
      overflow: hidden;
      position: relative;
      z-index: 2;
      animation: bob 5s ease-in-out infinite
    }

    @keyframes bob {

      0%,
      100% {
        transform: translateY(0)
      }

      50% {
        transform: translateY(-10px)
      }
    }

    .mockup-hdr {
      padding: 14px 16px;
      background: linear-gradient(135deg, #1E3A8A, #2563EB, #0EA5E9);
      display: flex;
      align-items: center;
      gap: 10px
    }

    .mockup-hdr-ico {
      width: 30px;
      height: 30px;
      border-radius: 8px;
      background: rgba(255, 255, 255, .2);
      display: flex;
      align-items: center;
      justify-content: center
    }

    .mockup-hdr-title {
      font-size: 12px;
      font-weight: 800;
      color: #fff
    }

    .mockup-hdr-status {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 10px;
      color: rgba(255, 255, 255, .75);
      font-weight: 600;
      margin-top: 1px
    }

    .mockup-hdr-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #4ADE80;
      animation: pulse 2s infinite
    }

    .mockup-body {
      padding: 12px;
      background: #F8FAFC;
      display: flex;
      flex-direction: column;
      gap: 9px
    }

    .mockup-row2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 9px
    }

    .mockup-stat {
      background: #fff;
      border-radius: 12px;
      padding: 12px;
      border: 1px solid #F1F5F9
    }

    .mockup-stat-lbl {
      font-size: 9.5px;
      color: #94A3B8;
      font-weight: 700;
      margin-bottom: 4px;
      text-transform: uppercase;
      letter-spacing: .04em
    }

    .mockup-stat-val {
      font-size: 18px;
      font-weight: 900;
      color: #0F172A;
      font-family: 'DM Mono', monospace
    }

    .mockup-stat-sub {
      font-size: 8.5px;
      font-weight: 700;
      margin-top: 2px
    }

    .green {
      color: #10B981
    }

    .blue {
      color: #2563EB
    }

    .red {
      color: #EF4444
    }

    .mockup-chart {
      background: #fff;
      border-radius: 12px;
      padding: 12px;
      border: 1px solid #F1F5F9
    }

    .mockup-chart-hdr {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px
    }

    .mockup-chart-lbl {
      font-size: 9.5px;
      color: #64748B;
      font-weight: 700
    }

    .mockup-chart-val {
      font-size: 9px;
      color: #94A3B8;
      font-weight: 600
    }

    .mockup-list {
      background: #fff;
      border-radius: 12px;
      padding: 12px;
      border: 1px solid #F1F5F9
    }

    .mockup-list-lbl {
      font-size: 9.5px;
      color: #64748B;
      font-weight: 700;
      margin-bottom: 7px;
      text-transform: uppercase;
      letter-spacing: .04em
    }

    .mockup-list-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 5px
    }

    .mockup-list-row:last-child {
      margin-bottom: 0
    }

    .mlr-name {
      font-size: 9.5px;
      font-weight: 700;
      color: #334155
    }

    .mlr-badge {
      font-size: 8.5px;
      font-weight: 800;
      padding: 2px 7px;
      border-radius: 5px
    }

    .badge-ok {
      background: #DCFCE7;
      color: #15803D
    }

    .badge-warn {
      background: #FEF3C7;
      color: #92400E
    }

    /* Float cards */
    .float-card {
      position: absolute;
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 8px 32px rgba(30, 58, 138, .13);
      border: 1px solid;
      padding: 12px;
      z-index: 10
    }

    .float-left {
      left: -50px;
      top: 30px;
      width: 160px;
      border-color: #FEE2E2;
      animation: bob2 5.5s ease-in-out 1.2s infinite
    }

    .float-right {
      right: -24px;
      bottom: 40px;
      width: 155px;
      border-color: #E0F2FE;
      animation: bob3 6s ease-in-out 2.4s infinite
    }

    @keyframes bob2 {

      0%,
      100% {
        transform: translateY(0)
      }

      50% {
        transform: translateY(-9px)
      }
    }

    @keyframes bob3 {

      0%,
      100% {
        transform: translateY(0)
      }

      50% {
        transform: translateY(-8px)
      }
    }

    .float-ico {
      width: 26px;
      height: 26px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 6px
    }

    .float-title {
      font-size: 10px;
      font-weight: 800;
      color: #1E293B;
      margin-bottom: 4px
    }

    .float-sub {
      font-size: 8.5px;
      color: #94A3B8;
      line-height: 1.5;
      font-weight: 500
    }

    .float-row {
      display: flex;
      justify-content: space-between;
      font-size: 8.5px;
      margin-bottom: 3px
    }

    .float-row:last-child {
      margin-bottom: 0
    }

    .float-key {
      color: #94A3B8;
      font-weight: 600
    }

    .float-val {
      font-weight: 800
    }

    /* ── Ticker ── */
    .ticker-bar {
      border-top: 1px solid #F1F5F9;
      border-bottom: 1px solid #F1F5F9;
      background: #fff;
      padding: 14px 0;
      overflow: hidden
    }

    .ticker-track {
      display: flex;
      width: max-content;
      animation: ticker 32s linear infinite
    }

    @keyframes ticker {
      0% {
        transform: translateX(0)
      }

      100% {
        transform: translateX(-50%)
      }
    }

    .ticker-item {
      font-size: 13px;
      font-weight: 700;
      color: #94A3B8;
      white-space: nowrap;
      padding: 0 28px;
      display: flex;
      align-items: center;
      gap: 7px
    }

    .ticker-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      flex-shrink: 0
    }

    /* ── Section commons ── */
    .section {
      padding: 96px 24px
    }

    .section-inner {
      max-width: 1280px;
      margin: 0 auto
    }

    .section-hdr {
      text-align: center;
      margin-bottom: 64px
    }

    .section-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 14px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: .1em;
      text-transform: uppercase;
      background: #F0F9FF;
      color: #0369A1;
      border: 1px solid #BAE6FD;
      margin-bottom: 16px
    }

    .section-title {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 900;
      letter-spacing: -.03em;
      line-height: 1.1;
      color: #0F172A;
      margin-bottom: 16px
    }

    .section-desc {
      font-size: 15px;
      color: #64748B;
      line-height: 1.7;
      max-width: 580px;
      margin: 0 auto
    }

    .hd {
      height: 1px;
      background: linear-gradient(90deg, transparent, #BFDBFE 35%, #BAE6FD 65%, transparent);
      margin: 80px 0
    }

    /* ── Feature cards ── */
    .feat-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px
    }

    @media(max-width:1024px) {
      .feat-grid {
        grid-template-columns: repeat(2, 1fr)
      }
    }

    @media(max-width:640px) {
      .feat-grid {
        grid-template-columns: 1fr
      }
    }

    .feat-card {
      background: #fff;
      border: 1.5px solid #E2E8F0;
      border-radius: 20px;
      padding: 28px;
      transition: all .3s;
      cursor: default
    }

    .feat-card:hover {
      border-color: #BFDBFE;
      box-shadow: 0 12px 40px rgba(30, 58, 138, .10);
      transform: translateY(-4px)
    }

    .feat-icon {
      width: 48px;
      height: 48px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 18px;
      box-shadow: 0 6px 20px rgba(0, 0, 0, .15)
    }

    .feat-title {
      font-size: 17px;
      font-weight: 800;
      color: #0F172A;
      margin-bottom: 10px
    }

    .feat-desc {
      font-size: 13.5px;
      color: #64748B;
      line-height: 1.65;
      margin-bottom: 14px
    }

    .feat-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px
    }

    .feat-tag {
      font-size: 10px;
      font-weight: 700;
      padding: 3px 9px;
      border-radius: 6px;
      border: 1px solid
    }

    /* ── Showcase zig-zag ── */
    .showcase {
      padding: 96px 0;
      background: linear-gradient(180deg, #F8FAFC, #EFF6FF)
    }

    .showcase-inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px
    }

    .showcase-item {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
      margin-bottom: 96px
    }

    .showcase-item:last-child {
      margin-bottom: 0
    }

    .showcase-item.reverse .showcase-img {
      order: -1
    }

    @media(max-width:900px) {

      .showcase-item,
      .showcase-item.reverse {
        grid-template-columns: 1fr
      }

      .showcase-item.reverse .showcase-img {
        order: 0
      }
    }

    .showcase-eyebrow {
      font-size: 11px;
      font-weight: 800;
      letter-spacing: .15em;
      text-transform: uppercase;
      margin-bottom: 12px
    }

    .showcase-title {
      font-size: clamp(1.7rem, 3vw, 2.3rem);
      font-weight: 900;
      letter-spacing: -.025em;
      line-height: 1.15;
      color: #0F172A;
      margin-bottom: 14px
    }

    .showcase-desc {
      font-size: 14.5px;
      color: #64748B;
      line-height: 1.72;
      margin-bottom: 22px
    }

    .showcase-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 24px
    }

    .showcase-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 13.5px;
      color: #334155
    }

    .check-ico {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: linear-gradient(135deg, #10B981, #059669);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 1px
    }

    .showcase-img-wrap {
      position: relative
    }

    .showcase-img-glow {
      position: absolute;
      inset: -12px;
      border-radius: 28px;
      background: linear-gradient(135deg, #3B82F6, #0EA5E9);
      opacity: .2;
      filter: blur(28px)
    }

    .showcase-img-frame {
      position: relative;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 24px 60px rgba(30, 58, 138, .18);
      border: 1px solid rgba(255, 255, 255, .8)
    }

    .screenshot-mockup {
      width: 100%;
      background: linear-gradient(135deg, #F8FAFC, #EFF6FF);
      padding: 20px;
      border-radius: 18px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      min-height: 280px
    }

    .sm-topbar {
      background: linear-gradient(135deg, #1E3A8A, #2563EB);
      border-radius: 12px;
      padding: 10px 14px;
      display: flex;
      align-items: center;
      gap: 8px
    }

    .sm-topbar-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255, 255, 255, .4)
    }

    .sm-topbar-title {
      font-size: 10px;
      font-weight: 800;
      color: #fff;
      flex: 1
    }

    .sm-row {
      display: flex;
      gap: 10px
    }

    .sm-card {
      background: #fff;
      border-radius: 10px;
      padding: 10px 12px;
      border: 1px solid #E2E8F0;
      flex: 1
    }

    .sm-card-lbl {
      font-size: 8.5px;
      color: #94A3B8;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .04em;
      margin-bottom: 3px
    }

    .sm-card-val {
      font-size: 16px;
      font-weight: 900;
      color: #0F172A;
      font-family: 'DM Mono', monospace
    }

    .sm-card-sub {
      font-size: 8px;
      font-weight: 700;
      margin-top: 1px
    }

    .sm-table {
      background: #fff;
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid #E2E8F0
    }

    .sm-table-hdr {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 8px;
      padding: 8px 12px;
      background: #F8FAFC;
      border-bottom: 1px solid #F1F5F9
    }

    .sm-th {
      font-size: 8px;
      font-weight: 700;
      color: #94A3B8;
      text-transform: uppercase;
      letter-spacing: .04em
    }

    .sm-row2 {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 8px;
      padding: 7px 12px;
      border-bottom: 1px solid #F8FAFC
    }

    .sm-row2:last-child {
      border-bottom: none
    }

    .sm-td {
      font-size: 9px;
      font-weight: 600;
      color: #334155
    }

    .sm-badge {
      font-size: 7.5px;
      font-weight: 800;
      padding: 2px 7px;
      border-radius: 5px;
      display: inline-block
    }

    /* ── How it works ── */
    .steps {
      padding: 96px 24px;
      background: #fff
    }

    .steps-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      position: relative
    }

    @media(max-width:900px) {
      .steps-grid {
        grid-template-columns: repeat(2, 1fr)
      }
    }

    @media(max-width:540px) {
      .steps-grid {
        grid-template-columns: 1fr
      }
    }

    .steps-line {
      position: absolute;
      top: 28px;
      left: 15%;
      right: 15%;
      height: 1px;
      background: linear-gradient(90deg, transparent, #BFDBFE 30%, #BAE6FD 70%, transparent);
      z-index: 0
    }

    @media(max-width:900px) {
      .steps-line {
        display: none
      }
    }

    .step {
      text-align: center;
      position: relative;
      z-index: 1
    }

    .step-num {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: linear-gradient(135deg, #1E3A8A, #2563EB);
      color: #fff;
      font-size: 18px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
      box-shadow: 0 8px 24px rgba(30, 58, 138, .3)
    }

    .step-title {
      font-size: 15px;
      font-weight: 800;
      color: #0F172A;
      margin-bottom: 8px
    }

    .step-desc {
      font-size: 13px;
      color: #64748B;
      line-height: 1.6
    }

    /* ── Stats ── */
    .stats-section {
      padding: 80px 24px;
      background: linear-gradient(135deg, #0F172A, #1E3A8A)
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      border-radius: 0;
      overflow: hidden
    }

    @media(max-width:900px) {
      .stats-grid {
        grid-template-columns: repeat(2, 1fr)
      }
    }

    .stat-box {
      padding: 36px 24px;
      text-align: center;
      border-right: 1px solid rgba(255, 255, 255, .08)
    }

    .stat-box:last-child {
      border-right: none
    }

    @media(max-width:900px) {
      .stat-box:nth-child(2) {
        border-right: none
      }

      .stat-box:nth-child(1),
      .stat-box:nth-child(2) {
        border-bottom: 1px solid rgba(255, 255, 255, .08)
      }
    }

    .stat-box-val {
      font-size: 42px;
      font-weight: 900;
      letter-spacing: -.04em;
      line-height: 1;
      margin-bottom: 6px;
      font-family: 'DM Mono', monospace;
      background: linear-gradient(135deg, #60A5FA, #38BDF8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text
    }

    .stat-box-lbl {
      font-size: 14px;
      font-weight: 600;
      color: rgba(255, 255, 255, .6)
    }

    /* ── Pricing ── */
    .pricing {
      padding: 96px 24px;
      background: #F8FAFC
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px
    }

    @media(max-width:900px) {
      .pricing-grid {
        grid-template-columns: 1fr;
        max-width: 400px;
        margin: 0 auto
      }
    }

    .price-card {
      background: #fff;
      border: 1.5px solid #E2E8F0;
      border-radius: 20px;
      padding: 32px;
      transition: all .3s
    }

    .price-card:hover {
      border-color: #93C5FD;
      box-shadow: 0 12px 40px rgba(30, 58, 138, .10)
    }

    .price-card.popular {
      border-color: #2563EB;
      background: linear-gradient(150deg, #EFF6FF, #F0F9FF);
      box-shadow: 0 16px 50px rgba(30, 58, 138, .13)
    }

    .popular-badge {
      display: inline-block;
      background: linear-gradient(135deg, #1E3A8A, #2563EB);
      color: #fff;
      font-size: 10px;
      font-weight: 800;
      padding: 4px 12px;
      border-radius: 999px;
      letter-spacing: .06em;
      text-transform: uppercase;
      margin-bottom: 16px
    }

    .price-name {
      font-size: 18px;
      font-weight: 800;
      color: #0F172A;
      margin-bottom: 6px
    }

    .price-desc {
      font-size: 13px;
      color: #64748B;
      margin-bottom: 20px;
      line-height: 1.5
    }

    .price-amount {
      font-size: 36px;
      font-weight: 900;
      color: #0F172A;
      letter-spacing: -.03em;
      margin-bottom: 4px;
      font-family: 'DM Mono', monospace
    }

    .price-note {
      font-size: 12px;
      color: #94A3B8;
      margin-bottom: 24px
    }

    .price-feats {
      list-style: none;
      margin-bottom: 28px;
      display: flex;
      flex-direction: column;
      gap: 10px
    }

    .price-feat {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: #334155
    }

    .pf-check {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: linear-gradient(135deg, #10B981, #059669);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0
    }

    /* ── FAQ ── */
    .faq {
      padding: 80px 24px;
      background: #fff
    }

    .faq-list {
      max-width: 760px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 0
    }

    .faq-item {
      border-bottom: 1px solid #F1F5F9
    }

    .faq-q {
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 0;
      font-size: 15px;
      font-weight: 700;
      color: #0F172A;
      background: none;
      border: none;
      cursor: pointer;
      text-align: left;
      gap: 16px
    }

    .faq-q:hover {
      color: #2563EB
    }

    .faq-chevron {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      transition: transform .25s;
      color: #94A3B8
    }

    .faq-item.open .faq-chevron {
      transform: rotate(180deg)
    }

    .faq-a {
      font-size: 14px;
      color: #64748B;
      line-height: 1.72;
      padding-bottom: 18px;
      display: none
    }

    .faq-item.open .faq-a {
      display: block
    }

    /* ── CTA ── */
    .cta-section {
      padding: 80px 24px;
      background: linear-gradient(135deg, #0F172A 0%, #1E3A8A 60%, #1D4ED8 100%);
      position: relative;
      overflow: hidden
    }

    .cta-blob1 {
      position: absolute;
      top: -80px;
      right: -80px;
      width: 360px;
      height: 360px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(96, 165, 250, .2), transparent 70%);
      pointer-events: none
    }

    .cta-blob2 {
      position: absolute;
      bottom: -80px;
      left: -80px;
      width: 280px;
      height: 280px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(56, 189, 248, .15), transparent 70%);
      pointer-events: none
    }

    .cta-inner {
      max-width: 640px;
      margin: 0 auto;
      text-align: center;
      position: relative;
      z-index: 1
    }

    .cta-title {
      font-size: clamp(1.9rem, 4vw, 2.8rem);
      font-weight: 900;
      letter-spacing: -.03em;
      color: #fff;
      margin-bottom: 14px;
      line-height: 1.12
    }

    .cta-desc {
      font-size: 16px;
      color: rgba(255, 255, 255, .7);
      line-height: 1.65;
      margin-bottom: 36px
    }

    .cta-btns {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap
    }

    .btn-white {
      padding: 14px 32px;
      background: #fff;
      border-radius: 16px;
      font-size: 15px;
      font-weight: 800;
      color: #1E3A8A;
      text-decoration: none;
      transition: all .25s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, .2)
    }

    .btn-white:hover {
      background: #EFF6FF;
      transform: translateY(-2px)
    }

    .btn-ghost-white {
      padding: 13px 28px;
      background: rgba(255, 255, 255, .12);
      border: 2px solid rgba(255, 255, 255, .3);
      border-radius: 16px;
      font-size: 15px;
      font-weight: 700;
      color: #fff;
      text-decoration: none;
      transition: all .25s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      backdrop-filter: blur(8px)
    }

    .btn-ghost-white:hover {
      background: rgba(255, 255, 255, .2);
      border-color: rgba(255, 255, 255, .5)
    }

    /* ── Footer ── */
    footer {
      background: #0F172A;
      padding: 60px 24px 32px;
      color: #fff
    }

    .footer-inner {
      max-width: 1280px;
      margin: 0 auto
    }

    .footer-top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 48px;
      padding-bottom: 48px;
      border-bottom: 1px solid rgba(255, 255, 255, .08)
    }

    @media(max-width:900px) {
      .footer-top {
        grid-template-columns: 1fr 1fr
      }
    }

    @media(max-width:540px) {
      .footer-top {
        grid-template-columns: 1fr
      }
    }

    .footer-brand-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px
    }

    .footer-brand-desc {
      font-size: 13px;
      color: rgba(255, 255, 255, .45);
      line-height: 1.7;
      max-width: 280px
    }

    .footer-col-title {
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .35);
      margin-bottom: 14px
    }

    .footer-col-links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px
    }

    .footer-col-links a {
      font-size: 13px;
      color: rgba(255, 255, 255, .5);
      text-decoration: none;
      transition: color .2s
    }

    .footer-col-links a:hover {
      color: #60A5FA
    }

    .footer-bottom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 24px;
      flex-wrap: gap
    }

    @media(max-width:640px) {
      .footer-bottom {
        flex-direction: column;
        gap: 10px;
        text-align: center
      }
    }

    .footer-copy {
      font-size: 12px;
      color: rgba(255, 255, 255, .3)
    }

    /* ── Scroll reveal ── */
    .sr {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity .65s ease, transform .65s ease
    }

    .sr-l {
      opacity: 0;
      transform: translateX(-22px);
      transition: opacity .65s ease, transform .65s ease
    }

    .sr-r {
      opacity: 0;
      transform: translateX(22px);
      transition: opacity .65s ease, transform .65s ease
    }

    .sr.on,
    .sr-l.on,
    .sr-r.on {
      opacity: 1;
      transform: translate(0)
    }

    /* ── Mobile nav ── */
    .mobile-nav {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, .95);
      z-index: 200;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 32px;
      backdrop-filter: blur(12px)
    }

    .mobile-nav.open {
      display: flex
    }

    .mobile-nav a {
      font-size: 22px;
      font-weight: 800;
      color: #fff;
      text-decoration: none;
      opacity: .8;
      transition: opacity .2s
    }

    .mobile-nav a:hover {
      opacity: 1
    }

    .mobile-nav-close {
      position: absolute;
      top: 20px;
      right: 24px;
      background: none;
      border: none;
      color: #fff;
      font-size: 24px;
      cursor: pointer;
      padding: 8px
    }
  </style>
</head>

