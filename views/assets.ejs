                </svg>
                <input type="text" id="searchInput" placeholder="Cari nama, kode, SN, brand..."
                    oninput="debounceSearch()">
            </div>
            <select id="filterStatus" onchange="loadAssets()">
                <option value="">Semua Status</option>
                <option value="active">Terpasang</option>
                <option value="storage">Gudang</option>
                <option value="repair">Servis</option>
                <option value="damaged">Rusak</option>
                <option value="disposed">Dibuang</option>
                <option value="lost">Hilang</option>
            </select>
            <select id="filterCategory" onchange="loadAssets()">
                <option value="">Semua Kategori</option>
            </select>
        </div>

        <!-- LIST VIEW -->
        <div id="viewList">
            <div class="card">
                <div class="card-body" style="padding:0;overflow-x:auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th style="width:44px"></th>
                                <th>Kode / Nama</th>
                                <th>Kategori</th>
                                <th>Brand / Model</th>
                                <th>S/N</th>
                                <th>Status</th>
                                <th>Kondisi</th>
                                <th>Lokasi / Customer</th>
                                <th>Harga Beli</th>
                                <th style="width:100px">Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="assetTableBody">
                            <tr>
                                <td colspan="10" style="text-align:center;padding:40px;color:var(--text-muted)">Memuat
                                    data...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- GRID VIEW -->
        <div id="viewGrid" style="display:none">
            <div id="assetGrid"
                style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;"></div>
        </div>

        <!-- Pagination -->
        <div id="pagination"
            style="display:flex;align-items:center;justify-content:space-between;margin-top:16px;font-size:13px;">
            <span id="paginfoText" style="color:var(--text-secondary)"></span>
            <div id="paginBtns" style="display:flex;gap:6px;"></div>
        </div>

    </main>

    <!-- Modals -->

    <!-- 1. Asset Modal -->
    <div class="modal-overlay" id="assetModal">
        <div class="modal-box wide">
            <div class="modal-header">
                <h3 id="assetModalTitle">Tambah Asset</h3>
                <div class="modal-close" onclick="closeModal('assetModal')">&times;</div>
            </div>
            <form onsubmit="submitAsset(event)">
                <input type="hidden" id="editAssetId">
                <div class="form-grid-3">
                    <div class="form-group">
                        <label>Nama Asset *</label>
                        <input type="text" id="fName" required>
                    </div>
                    <div class="form-group">
                        <label>Kategori</label>
                        <select id="fCategory"></select>
                    </div>
                    <div class="form-group">
                        <label>Status *</label>
                        <select id="fStatus" required>
                            <option value="active">Terpasang (Active)</option>
                            <option value="storage">Gudang (Storage)</option>
                            <option value="repair">Servis (Repair)</option>
                            <option value="damaged">Rusak (Damaged)</option>
                            <option value="disposed">Dibuang (Disposed)</option>
                            <option value="lost">Hilang (Lost)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Kondisi</label>
                        <select id="fCondition">
                            <option value="new">Baru (New)</option>
                            <option value="good">Baik (Good)</option>
                            <option value="fair">Sedang (Fair)</option>
                            <option value="poor">Buruk (Poor)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Brand</label>
                        <input type="text" id="fBrand">
                    </div>
                    <div class="form-group">
                        <label>Model</label>
                        <input type="text" id="fModel">
                    </div>
                    <div class="form-group">
                        <label>Serial Number (S/N)</label>
                        <input type="text" id="fSerial">
                    </div>
                    <div class="form-group">
                        <label>Lokasi / Gudang</label>
                        <input type="text" id="fLocation">
                    </div>
                </div>

                <div class="form-sep">Informasi Pembelian</div>
                <div class="form-grid-3">
                    <div class="form-group">
                        <label>Tanggal Beli</label>
                        <input type="date" id="fPurchaseDate">
                    </div>
                    <div class="form-group">
                        <label>Harga Beli</label>
                        <input type="number" id="fPrice" min="0">
                    </div>
                    <div class="form-group">
                        <label>Vendor / Toko</label>
                        <input type="text" id="fVendor">
                    </div>
                    <div class="form-group">
                        <label>Garansi Sampai</label>
                        <input type="date" id="fWarranty">
                    </div>
                </div>

                <div class="form-sep">Penggunaan Terkini</div>
                <div class="form-grid-3">
                    <div class="form-group">
                        <label>Customer (ID)</label>
                        <input type="number" id="fCustomer" placeholder="ID Customer">
                    </div>
                    <div class="form-group">
                        <label>Infrastructure (ID)</label>
                        <input type="number" id="fInfra" placeholder="ID Tiang/ODP">
                    </div>
                    <div class="form-group">
                        <label>Perangkat ONT (ID)</label>
                        <input type="number" id="fOnt" placeholder="ID ONT">
                    </div>
                </div>

                <div class="form-group" style="margin-top:16px;">
                    <label>Catatan Tambahan</label>
                    <textarea id="fNotes" rows="2"></textarea>
                </div>

                <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:24px;">
                    <button type="button" class="btn-outline" onclick="closeModal('assetModal')">Batal</button>
                    <button type="submit" class="btn-blue" id="assetSubmitBtn">Simpan</button>
                </div>
            </form>
        </div>
    </div>

    <!-- 2. Detail Modal -->
    <div class="modal-overlay" id="detailModal">
        <div class="modal-box wide">
            <div class="modal-header">
                <h3>Detail Asset</h3>
                <div class="modal-close" onclick="closeModal('detailModal')">&times;</div>
            </div>
            <div class="detail-layout">
                <div class="detail-col-left">
                    <div class="detail-photo" id="detPhotoArea">
                        <img id="detPhoto" src="" style="display:none;">
                    </div>
                    <div class="detail-meta">
                        <div style="font-size:18px; font-weight:800; color:var(--text);" id="detName"></div>
                        <div style="font-size:12px; color:var(--text-secondary);" id="detCode"></div>
                    </div>
                    <div class="detail-actions">
                        <span id="detStatus" class="badge-status"></span>
                        <span id="detCond" class="badge-condition"></span>
                    </div>
                </div>
                <div class="detail-col-right">
                    <div class="form-sep" style="margin-top:0">Info Dasar</div>
                    <div class="detail-grid">
                        <div class="detail-item"><label>Kategori</label><span id="detCat"></span></div>
                        <div class="detail-item"><label>Brand / Model</label><span id="detBrand"></span></div>
                        <div class="detail-item"><label>S/N</label><span id="detSerial"></span></div>
                        <div class="detail-item"><label>Lokasi</label><span id="detLoc"></span></div>
                        <div class="detail-item"><label>Tgl Ditambahkan</label><span id="detCreated"></span></div>
                    </div>
                    <div class="form-sep">Info Pembelian</div>
                    <div class="detail-grid">
                        <div class="detail-item"><label>Tgl Beli</label><span id="detBuyDate"></span></div>
                        <div class="detail-item"><label>Harga</label><span id="detPrice"></span></div>
                        <div class="detail-item"><label>Vendor</label><span id="detVendor"></span></div>
                        <div class="detail-item"><label>Garansi</label><span id="detWar"></span></div>
                    </div>
                    <div class="form-sep">Catatan</div>
                    <div style="font-size:13px; color:var(--text);" id="detNotes"></div>

                    <div class="form-sep">Riwayat (Timeline)</div>
                    <div class="timeline" id="detHistory">
                        <!-- Timeline items -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 3. Assign Modal -->
    <div class="modal-overlay" id="assignModal">
        <div class="modal-box">
            <div class="modal-header">
                <h3 id="assignTitle">Assign Asset</h3>
                <div class="modal-close" onclick="closeModal('assignModal')">&times;</div>
            </div>
            <form onsubmit="submitAssign(event)">
                <input type="hidden" id="assignAssetId">
                <div class="form-group" style="margin-bottom:12px;">
                    <label>Pilih Customer (ID)</label>
                    <input type="number" id="asgCustomer">
                </div>
                <div class="form-group" style="margin-bottom:12px;">
                    <label>Atau Pilih Infrastruktur (ID)</label>
                    <input type="number" id="asgInfra">
                </div>
                <div class="form-group" style="margin-bottom:12px;">
                    <label>Atau Pilih Perangkat ONT (ID)</label>
                    <input type="number" id="asgOnt">
                </div>
                <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:24px;">
                    <button type="button" class="btn-outline" onclick="closeModal('assignModal')">Batal</button>
                    <button type="submit" class="btn-blue" id="assignSubmitBtn">Assign</button>
                </div>
            </form>
        </div>
    </div>

    <!-- 4. Category Modal -->
    <div class="modal-overlay" id="categoryModal">
        <div class="modal-box">
            <div class="modal-header">
                <h3>Kelola Kategori</h3>
                <div class="modal-close" onclick="closeModal('categoryModal')">&times;</div>
            </div>

            <div class="form-sep" style="margin-top:0">Tambah Baru</div>
            <div style="display:flex; gap:10px; align-items:flex-end; margin-bottom:24px;">
                <div class="form-group" style="flex:1;">
                    <label>Nama Kategori</label>
                    <input type="text" id="catName" placeholder="Contoh: Router WiFi">
                </div>
                <div class="form-group">
                    <label>Warna</label>
                    <input type="color" id="catColor" value="#3b82f6"
                        style="padding:0; height:42px; width:42px; border:none; cursor:pointer;">
                </div>
                <button type="button" class="btn-blue" onclick="addCategory()" style="height:42px;">Tambah</button>
            </div>

            <div class="form-sep">Daftar Kategori</div>
            <div id="categoryList"
                style="display:flex; flex-direction:column; gap:8px; max-height:250px; overflow-y:auto; padding-right:6px;">
                <!-- Category List Rendered Here -->
            </div>

            <div style="display:flex; justify-content:flex-end; margin-top:24px;">
                <button type="button" class="btn-outline" onclick="closeModal('categoryModal')">Tutup</button>
            </div>
        </div>
    </div>

    <%- include('layouts/footer') %>