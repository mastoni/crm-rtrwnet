<%- include('layouts/header') %>

<script>
    function astCardClick(el) {
        if (typeof App !== 'undefined') App.showToast('Fitur ini masih dalam pengembangan', 'info');
        else console.log('astCardClick', el);
    }
</script>

    <style>
