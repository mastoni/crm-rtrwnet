<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title : 'FLAYNET ISP Dashboard' %>
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/app.css">
    <% if (page==='infrastructure' || page==='assets' || page==='tickets' ) { %>
        <!-- Leaflet CSS for maps -->
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
            integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
        <% } %>
</head>

<body>
    <div class="app-layout">
        <%- include('sidebar') %>

            <div class="main-content">


                <!-- Topbar Header -->
                <header class="header">
                    <div class="header-inner">
                        <button class="sidebar-toggle" id="sidebarToggle"
                            onclick="document.getElementById('sidebar').classList.toggle('show')">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20"
                                height="20">
                                <line x1="3" y1="12" x2="21" y2="12" />
                                <line x1="3" y1="6" x2="21" y2="6" />
                                <line x1="3" y1="18" x2="21" y2="18" />
                            </svg>
                        </button>

                        <div class="search-box">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="11" cy="11" r="8" />
                                <line x1="21" y1="21" x2="16.65" y2="16.65" />
                            </svg>
                            <input type="text" placeholder="Cari perangkat, user..." id="globalSearch">
                        </div>

                        <div class="topbar-actions">
                            <!-- Notification Bell -->
                            <div class="notif-wrap" id="notifWrap">
                                <button class="topbar-btn notif-bell-btn" id="notificationBtn"
                                    onclick="toggleNotifPanel()">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                        width="18" height="18">
                                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" />
                                        <path d="M13.73 21a2 2 0 01-3.46 0" />
                                    </svg>
                                    <span class="notif-count-badge" id="notifCountBadge" style="display:none;">0</span>
                                </button>

                                <!-- Notification Panel -->
                                <div class="notif-panel" id="notifPanel" style="display:none;">
                                    <div class="notif-panel-hdr">
                                        <div>
                                            <div style="font-size:14px;font-weight:700;color:#0d1b3e;">Notifikasi</div>
                                            <div style="font-size:11px;color:#94a3b8;" id="notifSubtitle">–</div>
                                        </div>
                                        <button onclick="markAllNotifRead()"
                                            style="font-size:11.5px;color:#1a6ef5;background:none;border:none;cursor:pointer;font-weight:600;padding:0;">Tandai
                                            semua</button>
                                    </div>
                                    <div class="notif-panel-tabs">
                                        <button class="notif-tab active"
                                            onclick="switchNotifTab('all',this)">Semua</button>
                                        <button class="notif-tab" onclick="switchNotifTab('unread',this)">Belum
                                            dibaca</button>
                                    </div>
                                    <div class="notif-panel-list" id="notifPanelList">
                                        <div class="notif-empty-state">
                                            <svg width="32" height="32" fill="none" stroke="#d1d5db" stroke-width="1.5"
                                                viewBox="0 0 24 24">
                                                <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" />
                                                <path d="M13.73 21a2 2 0 01-3.46 0" />
                                            </svg>
                                            <p>Tidak ada notifikasi</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </header>

                <style>
                    @media(min-width:769px) {
                        .sidebar-toggle {
                            display: none !important;
                        }
                    }

                    /* Notification */
                    .notif-wrap {
                        position: relative;
                    }

                    .notif-bell-btn {
                        position: relative;
                        width: 36px;
                        height: 36px;
                        border-radius: 10px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        background: none;
                        border: none;
                        cursor: pointer;
                        color: #64748b;
                        transition: all .15s;
                    }

                    .notif-bell-btn:hover {
                        background: #f4f8ff;
                        color: #1a6ef5;
                    }

                    .notif-count-badge {
                        position: absolute;
                        top: -2px;
                        right: -2px;
                        min-width: 16px;
                        height: 16px;
                        border-radius: 99px;
                        background: #ef4444;
                        color: #fff;
                        font-size: 9.5px;
                        font-weight: 800;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        padding: 0 4px;
                        border: 2px solid #fff;
                        line-height: 1;
                    }

                    .notif-panel {
                        position: absolute;
                        right: -8px;
                        top: calc(100% + 10px);
                        width: 360px;
                        background: #fff;
                        border-radius: 16px;
                        box-shadow: 0 8px 40px rgba(0, 0, 0, .14), 0 0 0 1px rgba(0, 0, 0, .06);
                        z-index: 9999;
                        overflow: hidden;
                        animation: notifSlide .2s ease;
                    }

                    @keyframes notifSlide {
                        from {
                            opacity: 0;
                            transform: translateY(-8px)
                        }

                        to {
                            opacity: 1;
                            transform: translateY(0)
                        }
                    }

                    .notif-panel-hdr {
                        padding: 14px 16px 10px;
                        display: flex;
                        align-items: flex-start;
                        justify-content: space-between;
                        border-bottom: 1px solid #f1f5f9;
                    }

                    .notif-panel-tabs {
                        display: flex;
                        padding: 0 16px;
                        border-bottom: 1px solid #f1f5f9;
                    }

                    .notif-tab {
                        padding: 8px 12px;
                        font-size: 12px;
                        font-weight: 600;
                        cursor: pointer;
                        border: none;
                        background: none;
                        color: #94a3b8;
                        border-bottom: 2px solid transparent;
                        transition: all .15s;
                        margin-bottom: -1px;
                    }

                    .notif-tab.active {
                        color: #1a6ef5;
                        border-bottom-color: #1a6ef5;
                    }

                    .notif-panel-list {
                        max-height: 380px;
                        overflow-y: auto;
                    }

                    .notif-item {
                        display: flex;
                        gap: 11px;
                        padding: 12px 16px;
                        border-bottom: 1px solid #f8faff;
                        cursor: pointer;
                        transition: background .12s;
                        position: relative;
                    }

                    .notif-item:hover {
                        background: #f8faff;
                    }

                    .notif-item.unread {
                        background: #f0f7ff;
                    }

                    .notif-item.unread::before {
                        content: '';
                        position: absolute;
                        left: 0;
                        top: 0;
                        bottom: 0;
                        width: 3px;
                        background: #1a6ef5;
                        border-radius: 0 2px 2px 0;
                    }

                    .notif-icon {
                        width: 36px;
                        height: 36px;
                        border-radius: 10px;
                        flex-shrink: 0;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 16px;
                    }

                    .notif-icon.wa {
                        background: #dcfce7;
                    }

                    .notif-icon.overdue {
                        background: #fee2e2;
                    }

                    .notif-icon.due {
                        background: #fef9c3;
                    }

                    .notif-icon.info {
                        background: #eff6ff;
                    }

                    .notif-icon.warning {
                        background: #fff7ed;
                    }

                    .notif-icon.critical {
                        background: #fef2f2;
                    }

                    .notif-body {
                        flex: 1;
                        min-width: 0;
                    }

                    .notif-title {
                        font-size: 13px;
                        font-weight: 600;
                        color: #0d1b3e;
                        margin-bottom: 2px;
                    }

                    .notif-msg {
                        font-size: 11.5px;
                        color: #64748b;
                        line-height: 1.5;
                    }

                    .notif-time {
                        font-size: 10.5px;
                        color: #94a3b8;
                        margin-top: 3px;
                    }

                    .notif-empty-state {
                        display: flex;
                        flex-direction: column;
                        align-items: center;
                        justify-content: center;
                        padding: 32px 16px;
                        color: #94a3b8;
                        gap: 8px;
                        font-size: 13px;
                    }
                </style>

                <div class="notification-dropdown" id="notifDropdown" style="display:none"></div>

                <script>
                    // ── Notification Panel ─────────────────────────────────────────
                    let _notifOpen = false;
                    let _notifTab = 'all';
                    let _notifItems = [];

                    function toggleNotifPanel() {
                        _notifOpen = !_notifOpen;
                        const panel = document.getElementById('notifPanel');
                        if (panel) panel.style.display = _notifOpen ? 'block' : 'none';
                        if (_notifOpen) loadNotifPanel();
                    }

                    // Close on outside click
                    document.addEventListener('click', function (e) {
                        const wrap = document.getElementById('notifWrap');
                        if (wrap && !wrap.contains(e.target)) {
                            _notifOpen = false;
                            const p = document.getElementById('notifPanel');
                            if (p) p.style.display = 'none';
                        }
                    });

                    async function loadNotifPanel() {
                        const list = document.getElementById('notifPanelList');
                        if (!list) return;
                        list.innerHTML = '<div style="padding:20px;text-align:center;color:#94a3b8;font-size:12px;">Memuat...</div>';

                        const url = _notifTab === 'unread' ? '/notifications?unread=true&limit=30' : '/notifications?limit=30';
                        const d = await App.api(url);
                        _notifItems = d?.data || [];

                        updateNotifSubtitle();

                        if (!_notifItems.length) {
                            list.innerHTML = '<div class="notif-empty-state"><svg width="32" height="32" fill="none" stroke="#d1d5db" stroke-width="1.5" viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg><p>Tidak ada notifikasi</p></div>';
                            return;
                        }

                        list.innerHTML = _notifItems.map(n => {
                            const icon = getNotifIcon(n.type, n.severity);
                            const time = formatNotifTime(n.created_at);
                            return `<div class="notif-item ${n.is_read ? '' : 'unread'}" onclick="readNotif(${n.id}, this)">
            <div class="notif-icon ${n.severity || 'info'}">${icon}</div>
            <div class="notif-body">
              <div class="notif-title">${escHtml(n.title)}</div>
              <div class="notif-msg">${escHtml(n.message)}</div>
              <div class="notif-time">${time}</div>
            </div>
          </div>`;
                        }).join('');
                    }

                    function updateNotifSubtitle() {
                        const unreadCount = _notifItems.filter(n => !n.is_read).length;
                        const el = document.getElementById('notifSubtitle');
                        if (el) el.textContent = unreadCount > 0 ? unreadCount + ' belum dibaca' : 'Semua sudah dibaca';
                    }

                    function getNotifIcon(type, severity) {
                        if (type === 'wa_incoming') return '💬';
                        if (type === 'wa_disconnected') return '🔌';
                        if (type === 'overdue') return '🔴';
                        if (type === 'due_today') return '⏰';
                        if (type === 'due_soon') return '🔔';
                        if (type === 'payment') return '✅';
                        if (severity === 'critical') return '🚨';
                        if (severity === 'warning') return '⚠️';
                        return 'ℹ️';
                    }

                    function formatNotifTime(dt) {
                        if (!dt) return '';
                        const now = new Date();
                        const d = new Date(dt);
                        const diff = Math.floor((now - d) / 1000);
                        if (diff < 60) return 'Baru saja';
                        if (diff < 3600) return Math.floor(diff / 60) + ' menit lalu';
                        if (diff < 86400) return Math.floor(diff / 3600) + ' jam lalu';
                        return d.toLocaleDateString('id-ID', { day: '2-digit', month: 'short' });
                    }

                    function escHtml(s) { return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

                    async function readNotif(id, el) {
                        if (el && el.classList.contains('unread')) {
                            el.classList.remove('unread');
                            await App.api('/notifications/' + id + '/read', { method: 'PUT' });
                            updateNotifCount();
                        }
                    }

                    async function markAllNotifRead() {
                        await App.api('/notifications/read-all', { method: 'PUT' });
                        document.querySelectorAll('.notif-item.unread').forEach(el => el.classList.remove('unread'));
                        const badge = document.getElementById('notifCountBadge');
                        if (badge) badge.style.display = 'none';
                        const sub = document.getElementById('notifSubtitle');
                        if (sub) sub.textContent = 'Semua sudah dibaca';
                    }

                    function switchNotifTab(tab, btn) {
                        _notifTab = tab;
                        document.querySelectorAll('.notif-tab').forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');
                        loadNotifPanel();
                    }

                    async function updateNotifCount() {
                        const d = await App.api('/notifications/unread-count');
                        const count = d?.data?.count || 0;
                        const badge = document.getElementById('notifCountBadge');
                        if (badge) {
                            badge.textContent = count > 99 ? '99+' : count;
                            badge.style.display = count > 0 ? 'flex' : 'none';
                        }
                    }

                    // Init + socket listener
                    document.addEventListener('DOMContentLoaded', () => {
                        updateNotifCount();
                        setInterval(updateNotifCount, 30000); // refresh tiap 30 detik

                        // Socket real-time
                        if (typeof io !== 'undefined') {
                            const token = localStorage.getItem('token');
                            const sock = io({ auth: { token } });
                            sock.on('notification:new', (data) => {
                                updateNotifCount();
                                if (!_notifOpen && typeof App !== 'undefined') {
                                    const icons = { wa_incoming: '💬', overdue: '🔴', due_today: '⏰', payment: '✅' };
                                    App.showToast((icons[data.type] || '🔔') + ' ' + (data.title || 'Notifikasi baru'), 'info');
                                }
                                if (_notifOpen) loadNotifPanel();
                            });
                        }
                    });
                </script>