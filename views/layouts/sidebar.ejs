    .profile-avatar-wrap {
        position: relative;
        flex-shrink: 0;
    }

    .profile-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1a6ef5, #0047cc);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: -.5px;
        border: 2.5px solid rgba(255, 255, 255, .15);
        box-shadow: 0 0 0 2.5px #1a6ef5, 0 3px 10px rgba(26, 110, 245, .45);
        transition: box-shadow .2s;
    }

    .profile-avatar:hover {
        box-shadow: 0 0 0 2.5px #1a6ef5, 0 4px 16px rgba(26, 110, 245, .6);
    }

    .profile-avatar-wrap::after {
        content: '';
        position: absolute;
        bottom: 1px;
        right: 1px;
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: #22c55e;
        border: 2px solid #fff;
    }

    .profile-info {
        flex: 1;
        min-width: 0;
    }

    .profile-name {
        font-size: 12.5px;
        font-weight: 700;
        color: #0d1b3e;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.3;
    }

    .profile-role {
        font-size: 10.5px;
        color: #94a3b8;
        text-transform: capitalize;
        margin-top: 1px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .profile-logout-btn {
        margin-left: auto;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        color: #94a3b8;
        transition: all .15s;
        flex-shrink: 0;
        text-decoration: none;
    }

    .profile-logout-btn:hover {
        background: rgba(245, 54, 92, .12);
        color: #f5365c;
    }
</style>

<script>
    (function () {
        const nameEl = document.getElementById('sidebarName');
        const av = document.getElementById('sidebarAvatar');
        if (nameEl && av) {
            const name = nameEl.textContent.trim();
            const initials = name.split(/\s+/).filter(Boolean).map(w => w[0]).slice(0, 2).join('').toUpperCase() || 'A';
            av.textContent = initials;
        }
        // GenieACS online badge
        (async () => {
            try {
                const r = await fetch('/api/genieacs/stats');
                const j = await r.json();
                if (j.success && j.data?.online > 0) {
                    const badge = document.getElementById('genieacs-online-badge');
                    if (badge) { badge.textContent = j.data.online; badge.style.display = 'inline-flex'; }
                }
            } catch (e) { }
        })();

        const logoutBtn = document.getElementById('logoutBtnProfile') || document.getElementById('logoutBtn');
        if (logoutBtn) {
            logoutBtn.addEventListener('click', async (e) => {
                e.preventDefault();
                try {
                    await fetch('/api/auth/logout', { method: 'POST' });
                    localStorage.removeItem('token');
                    localStorage.removeItem('user');
                } catch (err) { }
                window.location.href = '/login';
            });
        }
    })();
</script>
