<%- include('layouts/header') %>

    <style>
        :root {
            --ot-blue: #2563eb;
            --ot-blue-d: #1d4ed8;
            --ot-blue-l: #eff6ff;
            --ot-green: #16a34a;
            --ot-green-d: #15803d;
            --ot-green-l: #f0fdf4;
            --ot-red: #dc2626;
            --ot-red-d: #b91c1c;
            --ot-red-l: #fef2f2;
            --ot-amber: #d97706;
            --ot-amber-d: #b45309;
            --ot-amber-l: #fffbeb;
            --ot-teal: #0891b2;
            --ot-teal-l: #ecfeff;
            --ot-slate: #475569;
            --border: #e2e8f0;
            --text: #0f172a;
            --muted: #64748b;
            --faint: #94a3b8;
            --rc: 16px;
        }

        * {
            box-sizing: border-box;
        }

        .ot {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        /* HEADER */
        .ot-hdr {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 24px;
        }

        .ot-hdr-l h1 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 4px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .ot-hdr-l p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .ot-hdr-r {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 9px 16px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid;
            transition: all .15s;
            white-space: nowrap;
            font-family: inherit;
        }

        .btn svg {
            width: 15px;
            height: 15px;
            flex-shrink: 0;
        }

        .btn-outline {
            background: #fff;
            border-color: var(--border);
            color: #374151;
        }

        .btn-outline:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

        .btn-blue {
            background: var(--ot-blue);
            border-color: var(--ot-blue);
            color: #fff;
        }

        .btn-blue:hover {
            background: var(--ot-blue-d);
        }

        .btn-amber {
            background: var(--ot-amber);
            border-color: var(--ot-amber);
            color: #fff;
        }

        .btn-amber:hover {
            background: var(--ot-amber-d);
        }

        .btn-red {
            background: var(--ot-red);
            border-color: var(--ot-red);
            color: #fff;
        }

        .btn-red:hover {
            background: var(--ot-red-d);
        }

        .btn-sm {
            padding: 5px 12px;
            font-size: 12px;
            border-radius: 8px;
        }

        .btn:disabled {
            opacity: .5;
            cursor: not-allowed;
        }

        /* Live chip */
        .live-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 13px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
            background: var(--ot-green-l);
            border: 1px solid #bbf7d0;
            color: var(--ot-green);
        }

        .live-chip .ldot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--ot-green);
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
                transform: scale(1)
            }

            50% {
                opacity: .35;
                transform: scale(.75)
            }
        }

        @keyframes spin {
            to {
                transform: rotate(360deg)
            }
        }

        /* STAT CARDS — Modern Fresh */
        /* ── STAT CARDS — single strip with dividers ── */
        .ot-cards {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            background: #fff;
            border-radius: 16px;
            border: 1px solid #e8eaed;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .ot-card {
            padding: 20px 22px 18px;
            border-right: 1px solid #e8eaed;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            gap: 0;
            position: relative;
            overflow: hidden;
            transition: background .15s;
        }

        .ot-card:last-child {
            border-right: none;
        }

        .ot-card:hover {
            background: #fafbff;
        }

        /* Reset ornamen lama — paksa hapus ::before dan ::after */
        .ot-card::before,
        .ot-card::after {
            display: none !important;
            content: none !important;
        }

        /* Active — biru solid */
        .ot-card.otc-active {
            background: #2563eb;
            border-color: #2563eb;
        }

        .ot-card.otc-active:hover {
            background: #1d4ed8;
        }

        .ot-card.otc-active .card-lbl {
            color: rgba(255, 255, 255, .70);
        }

        .ot-card.otc-active .card-val {
            color: #fff;
        }

        .ot-card.otc-active .card-sub {
            color: rgba(255, 255, 255, .60);
        }

        .ot-card.otc-active .card-pill {
            background: rgba(255, 255, 255, .20) !important;
            color: rgba(255, 255, 255, .90) !important;
        }

        .ot-card.otc-active .sp-line {
            stroke: rgba(255, 255, 255, .70) !important;
        }

        .ot-card.otc-active .sp-fill {
            fill: rgba(255, 255, 255, .12) !important;
        }

        .ot-card.otc-active .sp-dot {
            fill: #fff !important;
        }

        /* ── Custom GenieACS Server card ── */
        .ot-card-server {
            padding: 18px 22px 16px !important;
            gap: 10px !important;
            justify-content: space-between;
        }

        .srv-hdr {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .srv-icon {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            background: #ecfdf5;
            color: #059669;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: background .15s, color .15s;
        }

        .srv-icon svg {
            width: 16px;
            height: 16px;
            stroke-width: 2;
        }

        .srv-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            border-radius: 20px;
            background: #dcfce7;
            color: #15803d;
            font-size: 10.5px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .05em;
            white-space: nowrap;
            transition: background .15s, color .15s;
        }

        .srv-pd {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #10b981;
            animation: srvpulse 2s infinite;
        }

        @keyframes srvpulse {

            0%,
            100% {
                opacity: 1
            }

            50% {
                opacity: .35
            }
        }

        /* Error / disconnected states */
        .srv-pill.err {
            background: #fee2e2;
            color: #b91c1c;
        }

        .srv-pill.err .srv-pd {
            background: #ef4444;
            animation: none;
        }

        .srv-icon.err {
            background: #fee2e2;
            color: #b91c1c;
        }

        .srv-pill.warn {
            background: #fef3c7;
            color: #b45309;
        }

        .srv-pill.warn .srv-pd {
            background: #f59e0b;
        }

        .srv-icon.warn {
            background: #fef3c7;
            color: #b45309;
        }

        .srv-stack {
            display: flex;
            flex-direction: column;
            gap: 2px;
            min-width: 0;
        }

        .srv-name {
            font-size: 14px;
            font-weight: 700;
            color: #0f172a;
            line-height: 1.2;
            letter-spacing: -.2px;
        }

        .srv-url {
            font-family: 'Geist Mono', ui-monospace, Menlo, monospace;
            font-size: 11px;
            color: #64748b;
            letter-spacing: -.2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            min-width: 0;
        }

        .srv-foot {
            display: flex;
            align-items: center;
            gap: 10px;
            padding-top: 10px;
            border-top: 1px dashed #eef2f7;
            font-size: 10.5px;
            color: #94a3b8;
            font-weight: 600;
        }

        .srv-foot b {
            color: #334155;
            font-weight: 700;
            font-family: 'Geist Mono', ui-monospace, monospace;
        }

        .srv-foot .latok {
            color: #15803d;
        }

        .srv-dot-sep {
            color: #cbd5e1;
        }

        /* When active (card clicked to filter), invert colors */
        .ot-card-server.otc-active {
            background: #2563eb;
            border-color: #2563eb;
        }

        .ot-card-server.otc-active .srv-icon {
            background: rgba(255, 255, 255, .18);
            color: #fff;
        }

        .ot-card-server.otc-active .srv-pill {
            background: rgba(255, 255, 255, .20);
            color: #fff;
        }

        .ot-card-server.otc-active .srv-pd {
            background: #bbf7d0;
        }

        .ot-card-server.otc-active .srv-name {
            color: #fff;
        }

        .ot-card-server.otc-active .srv-url {
            color: rgba(255, 255, 255, .75);
        }

        .ot-card-server.otc-active .srv-foot {
            color: rgba(255, 255, 255, .70);
            border-top-color: rgba(255, 255, 255, .20);
        }

        .ot-card-server.otc-active .srv-foot b {
            color: #fff;
        }

        .ot-card-server.otc-active .srv-foot .latok {
            color: #bbf7d0;
        }

        .ot-card-server.otc-active .srv-dot-sep {
            color: rgba(255, 255, 255, .35);
        }

        /* label */
        .card-lbl {
            font-size: 12px;
            font-weight: 500;
            color: #64748b;
            margin-bottom: 10px;
            letter-spacing: .1px;
            transition: color .15s;
        }

        /* body */
        .card-body {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 8px;
        }

        .card-left {
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        /* angka */
        .card-val {
            font-size: 30px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -1.2px;
            line-height: 1;
            transition: color .15s;
        }

        @media(max-width:1400px) {
            .card-val {
                font-size: 26px;
            }
        }

        /* meta */
        .card-meta {
            display: flex;
            align-items: center;
            gap: 5px;
            margin-top: 6px;
            flex-wrap: wrap;
        }

        .card-pill {
            display: inline-flex;
            align-items: center;
            gap: 2px;
            padding: 1px 6px;
            border-radius: 100px;
            font-size: 10.5px;
            font-weight: 700;
            white-space: nowrap;
            flex-shrink: 0;
            transition: all .15s;
        }

        .pill-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .pill-green {
            background: #dcfce7;
            color: #16a34a;
        }

        .pill-red {
            background: #fee2e2;
            color: #dc2626;
        }

        .pill-amber {
            background: #fef3c7;
            color: #b45309;
        }

        .pill-slate {
            background: #f1f5f9;
            color: #475569;
        }

        .pill-teal {
            background: #cffafe;
            color: #0e7490;
        }

        .card-sub {
            font-size: 11px;
            color: #94a3b8;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            transition: color .15s;
        }

        /* sparkline */
        .card-spark {
            flex-shrink: 0;
            width: 72px;
            height: 36px;
        }

        .card-spark svg {
            width: 72px;
            height: 36px;
        }

        .sp-fill {
            transition: fill .3s;
        }

        .sp-line {
            stroke-width: 1.8;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .sp-dot {}

        /* responsive */
        @media(max-width:700px) {
            .ot-cards {
                grid-template-columns: repeat(2, 1fr);
            }

            .ot-card {
                border-right: none;
                border-bottom: 1px solid #e8eaed;
            }

            .ot-card:nth-child(odd) {
                border-right: 1px solid #e8eaed;
            }

            .ot-card:nth-child(even) {
                border-right: none;
            }

            .ot-card:nth-last-child(-n+2) {
                border-bottom: none;
            }
        }

        @media(max-width:400px) {
            .ot-cards {
                grid-template-columns: 1fr;
            }

            .ot-card {
                border-right: none !important;
                border-bottom: 1px solid #e8eaed;
            }

            .ot-card:last-child {
                border-bottom: none;
            }
        }

        .card-sub {
            font-size: 12px;
            opacity: .8;
            font-weight: 500;
        }

        /* ALERT */
        .ot-alert {
            display: none;
            background: var(--ot-red-l);
            border: 1.5px solid #fecaca;
            border-left: 4px solid var(--ot-red);
            border-radius: 10px;
            padding: 11px 16px;
            margin-bottom: 16px;
            font-size: 13px;
            font-weight: 500;
            color: var(--ot-red);
            align-items: center;
            gap: 10px;
        }

        .ot-alert.show {
            display: flex;
        }

        /* TABLE WRAPPER */
        .ot-tbl-wrap {
            background: #fff;
            border: 1.5px solid var(--border);
            border-radius: var(--rc);
            overflow: hidden;
        }

        .ot-tbl-hdr {
            padding: 14px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid #f1f5f9;
            flex-wrap: wrap;
            gap: 10px;
        }

        .ot-tbl-title {
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .ot-count {
            font-size: 11px;
            font-weight: 600;
            background: #f1f5f9;
            color: var(--muted);
            padding: 2px 9px;
            border-radius: 20px;
        }

        /* Filter chips */
        .filter-chips {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }

        .fchip {
            padding: 5px 13px;
            border-radius: 20px;
            border: 1.5px solid var(--border);
            background: #fff;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            color: var(--muted);
            transition: all .15s;
            font-family: inherit;
        }

        .fchip:hover {
            border-color: var(--ot-blue);
            color: var(--ot-blue);
        }

        .fchip.active {
            background: var(--ot-blue);
            border-color: var(--ot-blue);
            color: #fff;
        }

        .fchip.online.active {
            background: var(--ot-green);
            border-color: var(--ot-green);
        }

        .fchip.offline.active {
            background: var(--ot-red);
            border-color: var(--ot-red);
        }

        .search-wrap {
            position: relative;
        }

        .search-wrap svg {
            position: absolute;
            left: 11px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--faint);
            pointer-events: none;
            width: 14px;
            height: 14px;
        }

        .search-wrap input {
            padding: 8px 12px 8px 33px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-size: 13px;
            outline: none;
            background: #f8fafc;
            font-family: inherit;
            color: var(--text);
            width: 220px;
            transition: all .15s;
        }

        .search-wrap input:focus {
            border-color: var(--ot-blue);
            background: #fff;
            box-shadow: 0 0 0 3px #2563eb14;
        }

        .ot-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        .ot-table thead tr {
            background: #fafbfc;
        }

        .ot-table th {
            padding: 11px 14px;
            font-size: 10px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: .06em;
            text-align: left;
            border-bottom: 1px solid #eef2f7;
            white-space: nowrap;
        }

        .ot-table tbody tr {
            border-bottom: 1px solid #f5f7fa;
            transition: background .15s;
            cursor: pointer;
        }

        .ot-table tbody tr:hover {
            background: #fafbff;
        }

        .ot-table tbody tr:last-child {
            border-bottom: none;
        }

        .ot-table tbody tr.row-offline {
            opacity: .55;
        }

        .ot-table td {
            padding: 14px;
            font-size: 13px;
            color: #374151;
            vertical-align: middle;
            overflow: hidden;
        }

        /* More breathing space for narrow metric cols */
        .ot-table th:nth-child(4),
        .ot-table td:nth-child(4),
        .ot-table th:nth-child(5),
        .ot-table td:nth-child(5),
        .ot-table th:nth-child(6),
        .ot-table td:nth-child(6),
        .ot-table th:nth-child(7),
        .ot-table td:nth-child(7) {
            padding-left: 16px;
            padding-right: 16px;
        }

        /* ── Responsive: aggressive column hiding, keep table format ── */
        /* < 1280px: hide Uptime, hide tanggal sub di Last Inform */
        @media(max-width:1280px) {

            .ot-table th:nth-child(7),
            .ot-table td:nth-child(7) {
                display: none;
            }

            /* Uptime */
            .inform-sub {
                display: none;
            }
        }

        /* < 1024px: hide Clients + SSID */
        @media(max-width:1024px) {

            .ot-table th:nth-child(5),
            .ot-table td:nth-child(5) {
                display: none;
            }

            /* Clients */
            .ot-table th:nth-child(8),
            .ot-table td:nth-child(8) {
                display: none;
            }

            /* SSID */
        }

        /* < 900px: hide Suhu + WAN IP */
        @media(max-width:900px) {

            .ot-table th:nth-child(6),
            .ot-table td:nth-child(6) {
                display: none;
            }

            /* Suhu */
            .ot-table th:nth-child(9),
            .ot-table td:nth-child(9) {
                display: none;
            }

            /* WAN IP */
        }

        /* < 720px: hide Customer + Last Inform */
        @media(max-width:720px) {

            .ot-table th:nth-child(3),
            .ot-table td:nth-child(3) {
                display: none;
            }

            /* Customer */
            .ot-table th:nth-child(10),
            .ot-table td:nth-child(10) {
                display: none;
            }

            /* Last Inform */
        }

        /* Mobile compact: < 640px — tighten padding, smaller fonts, keep table */
        @media(max-width:640px) {
            .ot-table th {
                padding: 9px 8px;
                font-size: 9px;
                letter-spacing: .04em;
            }

            .ot-table td {
                padding: 10px 8px;
                font-size: 12px;
            }

            .ot-table th:nth-child(4),
            .ot-table td:nth-child(4),
            .ot-table th:nth-child(5),
            .ot-table td:nth-child(5),
            .ot-table th:nth-child(6),
            .ot-table td:nth-child(6),
            .ot-table th:nth-child(7),
            .ot-table td:nth-child(7) {
                padding-left: 6px;
                padding-right: 6px;
            }

            .num-cell {
                font-size: 10px;
            }

            .sn-num {
                font-size: 11px;
            }

            .sn-sub {
                font-size: 9.5px;
            }

            .rx-val {
                font-size: 11px;
            }

            .rx-lbl {
                font-size: 8.5px;
            }

            .dev-val {
                font-size: 10.5px;
            }

            .ip-badge {
                font-size: 9.5px;
                padding: 1.5px 5px;
            }

            .act-btn {
                width: 26px;
                height: 26px;
            }

            .act-btn svg {
                width: 12px;
                height: 12px;
            }

            /* Override earlier hide rules — show Customer + Uptime in mobile */
            .ot-table th:nth-child(3),
            .ot-table td:nth-child(3) {
                display: table-cell !important;
            }

            /* Customer */
            .ot-table th:nth-child(7),
            .ot-table td:nth-child(7) {
                display: table-cell !important;
            }

            /* Uptime */
            /* Compact Customer in mobile */
            .cust-name {
                font-size: 11px;
            }

            .cust-id {
                font-size: 9px;
            }

            .cust-empty {
                font-size: 9.5px;
            }

            .cust-empty::before {
                width: 4px;
                height: 4px;
            }

            /* Compact uptime */
            .dev-val.uptime-txt {
                font-size: 10px;
            }

            /* Card list container — tetap allow horizontal scroll jika ada cell yang min-content lebih lebar */
            .ot-tbl-wrap>div[style*="overflow-x"] {
                -webkit-overflow-scrolling: touch;
            }
        }

        .num-cell {
            color: #94a3b8;
            font-size: 11px;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            font-family: 'Geist Mono', ui-monospace, Menlo, monospace;
        }

        /* Serial + Model combined cell — text-only stack, no icon */
        .sn-cell {
            display: flex;
            flex-direction: column;
            gap: 3px;
            min-width: 0;
        }

        .sn-num {
            font-family: 'Geist Mono', ui-monospace, Menlo, monospace;
            font-size: 12px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: -.2px;
            white-space: nowrap;
