                        <circle cx="12" cy="12" r="3" />
                        <path
                            d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" />
                    </svg>
                    Pengaturan Server
                </button>
            </div>
        </div>

        <!-- Alert -->
        <div class="ot-alert" id="genie-alert">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <span id="genie-alert-msg">GenieACS tidak dapat dijangkau</span>
        </div>

        <!-- Stat Cards -->
        <div class="ot-cards">

            <div class="ot-card otc-active" id="otc-total" data-filter="all" onclick="otcClick(this)">
                <div class="card-lbl">Total ONT</div>
                <div class="card-body">
                    <div class="card-left">
                        <span class="card-val" id="stat-total">—</span>
                        <div class="card-meta">
                            <span class="card-pill pill-blue" id="ot-pill-total">— device</span>
                            <span class="card-sub">Semua perangkat</span>
                        </div>
                    </div>
                    <div class="card-spark">
                        <svg id="sp-total" viewBox="0 0 72 36" preserveAspectRatio="none">
                            <path class="sp-fill" id="sp-total-fill" d="" fill="#2563eb" opacity=".12" />
                            <path class="sp-line" id="sp-total-line" d="" stroke="#2563eb" />
                            <circle class="sp-dot" id="sp-total-dot" r="2.5" fill="#2563eb" />
                        </svg>
                    </div>
                </div>
            </div>

            <div class="ot-card" id="otc-online" data-filter="online" onclick="otcClick(this)">
                <div class="card-lbl">Online</div>
                <div class="card-body">
                    <div class="card-left">
                        <span class="card-val" id="stat-online">—</span>
                        <div class="card-meta">
                            <span class="card-pill pill-green" id="ot-pill-online">— ONT</span>
                            <span class="card-sub">ONT aktif</span>
                        </div>
                    </div>
                    <div class="card-spark">
                        <svg id="sp-online" viewBox="0 0 72 36" preserveAspectRatio="none">
                            <path class="sp-fill" id="sp-online-fill" d="" fill="#16a34a" opacity=".12" />
                            <path class="sp-line" id="sp-online-line" d="" stroke="#16a34a" />
                            <circle class="sp-dot" id="sp-online-dot" r="2.5" fill="#16a34a" />
                        </svg>
                    </div>
                </div>
            </div>

            <div class="ot-card" id="otc-offline" data-filter="offline" onclick="otcClick(this)">
                <div class="card-lbl">Offline</div>
                <div class="card-body">
                    <div class="card-left">
                        <span class="card-val" id="stat-offline">—</span>
                        <div class="card-meta">
                            <span class="card-pill pill-red" id="ot-pill-offline">— ONT</span>
                            <span class="card-sub">ONT tidak aktif</span>
                        </div>
                    </div>
                    <div class="card-spark">
                        <svg id="sp-offline" viewBox="0 0 72 36" preserveAspectRatio="none">
                            <path class="sp-fill" id="sp-offline-fill" d="" fill="#dc2626" opacity=".12" />
                            <path class="sp-line" id="sp-offline-line" d="" stroke="#dc2626" />
                            <circle class="sp-dot" id="sp-offline-dot" r="2.5" fill="#dc2626" />
                        </svg>
                    </div>
                </div>
            </div>

            <div class="ot-card ot-card-server" id="otc-server" data-filter="server" onclick="otcClick(this)">
                <div class="srv-hdr">
                    <div class="card-lbl" style="margin:0;">Status Server</div>
                    <span class="srv-pill" id="srv-pill">
                        <span class="srv-pd"></span>
                        <span id="stat-server">—</span>
                    </span>
                </div>
                <div class="srv-stack">
                    <span class="srv-name">GenieACS NBI</span>
                    <span class="srv-url" id="stat-server-url">—</span>
                </div>
                <div class="srv-foot">
                    <span>TR-069</span>
                    <span class="srv-dot-sep">·</span>
                    <span id="srv-latency">Latency <b>—</b></span>
                </div>
            </div>

        </div>

        <!-- Table -->
        <div class="ot-tbl-wrap">
            <div class="ot-tbl-hdr">
                <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                    <div class="ot-tbl-title">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--ot-blue)"
                            stroke-width="2.5">
                            <rect x="2" y="6" width="20" height="12" rx="2" />
                            <path d="M6 10h.01M6 14h.01M10 10h8" />
                        </svg>
                        Daftar ONT / CPE
                        <span class="ot-count" id="ont-count-label">0 device</span>
                    </div>
                    <div class="filter-chips">
                        <button class="fchip active" onclick="GeniePage.setFilter('')">Semua</button>
                        <button class="fchip online" onclick="GeniePage.setFilter('online')">Online</button>
                        <button class="fchip offline" onclick="GeniePage.setFilter('offline')">Offline</button>
                    </div>
                </div>
                <div class="search-wrap">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    <input type="text" id="genie-search" placeholder="Cari serial, SSID, model..."
                        oninput="GeniePage.debounce()">
                </div>
            </div>

            <div style="overflow-x:auto">
                <table class="ot-table">
                    <thead>
                        <tr>
                            <th style="width:42px;">#</th>
                            <th style="width:200px;">Serial / Model</th>
                            <th style="width:140px;">Customer</th>
                            <th style="width:118px;">RX Power</th>
                            <th style="width:88px;">Clients</th>
                            <th style="width:96px;">Suhu</th>
                            <th style="width:108px;">Uptime</th>
                            <th>SSID 2.4G</th>
                            <th style="width:108px;">WAN IP</th>
                            <th style="width:104px;">Last Inform</th>
                            <th style="width:108px;text-align:right;">Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="genie-tbody">
                        <tr>
                            <td colspan="11">
                                <div class="tbl-empty">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                        <rect x="2" y="6" width="20" height="12" rx="2" />
                                        <path d="M6 10h.01M6 14h.01M10 10h8" />
                                    </svg>
                                    <p>Memuat data ONT...</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="ot-tbl-footer">
                <span class="pg-info" id="genie-pg-info"></span>
            </div>
        </div>

        <!-- Modal Settings -->
        <div class="ot-modal-overlay" id="modal-settings">
            <div class="ot-modal-box settings-modal-box">
                <div class="ot-modal-hdr">
                    <div class="modal-hdr-top">
                        <div class="ot-modal-hdr-l">
                            <h3>Pengaturan Server</h3>
                            <p>Konfigurasi koneksi API ke GenieACS</p>
                        </div>
                        <div class="ot-modal-hdr-r">
                            <button class="btn ot-modal-close" onclick="GeniePage.closeModal('modal-settings')" style="display:flex;align-items:center;justify-content:center;padding:8px">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="ot-modal-body">
                    <div class="settings-form-row">
                        <label>GenieACS NBI URL</label>
                        <input type="text" id="cfg-nbi-url" placeholder="http://192.168.99.104:7557">
                        <small>URL endpoint Northbound API GenieACS.</small>
                    </div>
                    <div class="settings-form-row">
                        <label>Username</label>
                        <input type="text" id="cfg-username" placeholder="Kosongkan jika tidak ada">
                    </div>
                    <div class="settings-form-row">
                        <label>Password</label>
                        <input type="password" id="cfg-password" placeholder="Kosongkan jika tidak ada">
                    </div>
                    <div id="cfg-test-result" style="display:none;margin-top:10px;"></div>
                </div>
                <div class="ot-modal-footer" style="display:flex;justify-content:flex-end;gap:10px">
                    <button class="btn btn-outline" onclick="GeniePage.testConn()">Test Koneksi</button>
                    <button class="btn btn-blue" onclick="GeniePage.saveSettings()">Simpan Konfigurasi</button>
                </div>
            </div>
        </div>

    </main>

    <%- include('layouts/footer') %>