                        </div>
                        <div style="text-align:right;">
                            <button class="btn btn-blue" id="btnSaveTask" onclick="saveTask()">
                                <span id="btnSaveTxt">Buat Work Order</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Delete Modal -->
        <div class="modal-ov" id="delModal">
            <div class="modal-bx" style="width:400px;text-align:center;">
                <div style="color:#ef4444;margin-bottom:14px;">
                    <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" />
                    </svg>
                </div>
                <div class="modal-ttl" style="margin-bottom:10px;">Hapus Work Order?</div>
                <div id="delMsg" style="color:var(--d-muted);font-size:13.5px;margin-bottom:24px;"></div>
                <div style="display:flex;gap:10px;justify-content:center;">
                    <button class="btn btn-outline" onclick="closeDelModal()">Batal</button>
                    <button class="btn btn-red" onclick="confirmDelete()">Ya, Hapus</button>
                </div>
            </div>
        </div>

        <!-- Drawer Overlay -->
        <div class="wo-drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>

        <!-- Drawer -->
        <div class="wo-drawer" id="woDrawer">
            <div class="wo-drawer-header">
                <div>
                    <div class="wo-drawer-title" id="drawerTitle"></div>
                    <div style="font-size:12.5px;color:var(--d-muted);font-weight:600;margin-top:2px" id="drawerWoNum">
                    </div>
                </div>
                <button class="wo-drawer-close" onclick="closeDrawer()">×</button>
            </div>
            <div class="wo-drawer-body" id="drawerBody">
            </div>
            <div class="wo-drawer-footer" id="drawerFooter">
            </div>
        </div>

    </main>

    <%- include('layouts/footer') %>