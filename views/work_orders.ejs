                                <div style="flex:1;">
                                    <label
                                        style="display:block;font-size:11.5px;font-weight:600;margin-bottom:4px;color:var(--d-text);">No.
                                        WhatsApp</label>
                                    <input type="text" class="finput" id="f_technician_phone" placeholder="628...">
                                </div>
                            </div>
