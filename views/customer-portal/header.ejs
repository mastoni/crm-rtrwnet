<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Portal - SKMNet</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --primary-light: #eff6ff;
            --success: #16a34a;
            --warning: #d97706;
            --danger: #dc2626;
            --bg: #f8fafc;
            --surface: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --radius: 16px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        body {
            background-color: var(--bg);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Navbar */
        .cp-nav {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 16px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .cp-logo {
            font-weight: 800;
            font-size: 20px;
            color: var(--primary);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .cp-logo svg {
            width: 24px;
            height: 24px;
        }

        .cp-nav-links {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .cp-nav-link {
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 14px;
            padding: 8px 12px;
            border-radius: 8px;
            transition: all 0.2s;
        }

        .cp-nav-link:hover, .cp-nav-link.active {
            color: var(--primary);
            background: var(--primary-light);
        }

        .cp-user-menu {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-left: 20px;
            padding-left: 20px;
            border-left: 1px solid var(--border);
        }

        .cp-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 14px;
        }

        .cp-logout {
            cursor: pointer;
            color: var(--text-muted);
            background: none;
            border: none;
            padding: 6px;
            border-radius: 6px;
        }

        .cp-logout:hover {
            color: var(--danger);
            background: #fee2e2;
        }

        /* Layout */
        .cp-container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 32px 24px;
            width: 100%;
            flex: 1;
        }

        /* Utilities */
        .cp-card {
            background: var(--surface);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            padding: 24px;
            margin-bottom: 24px;
        }
        
        .btn {
            padding: 10px 18px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background: var(--primary-dark);
        }

        @media (max-width: 768px) {
            .cp-nav-links {
                display: none; /* In real app, make a mobile menu */
            }
            .cp-container {
                padding: 20px 16px;
            }
        }
    </style>
</head>
<body>

    <nav class="cp-nav">
        <a href="/dashboard" class="cp-logo">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M12 2L2 7l10 5 10-5-10-5z" />
                <path d="M2 17l10 5 10-5" />
                <path d="M2 12l10 5 10-5" />
            </svg>
            SKMNet Portal
        </a>
        <div class="cp-nav-links">
            <a href="/dashboard" class="cp-nav-link <%= typeof page !== 'undefined' && page === 'dashboard' ? 'active' : '' %>">Dashboard</a>
            <a href="/rewards" class="cp-nav-link <%= typeof page !== 'undefined' && page === 'rewards' ? 'active' : '' %>">Reward Points</a>
            <a href="/tickets" class="cp-nav-link <%= typeof page !== 'undefined' && page === 'tickets' ? 'active' : '' %>">Support Tickets</a>
            <div class="cp-user-menu">
                <div class="cp-avatar"><%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %></div>
                <button class="cp-logout" onclick="logoutPortal()">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" />
                        <polyline points="16,17 21,12 16,7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                </button>
            </div>
        </div>
    </nav>
    <div class="cp-container">
