<%- include('header') %>

<style>
    .page-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 24px; flex-wrap: wrap; gap: 16px; }
    .page-title { font-size: 22px; font-weight: 800; display: flex; align-items: center; gap: 10px; }
    
    .my-points-badge { 
        background: #fefce8; border: 1px solid #fef08a; padding: 10px 16px; border-radius: 12px;
        display: flex; align-items: center; gap: 10px; color: #a16207; font-weight: 700; font-size: 16px;
    }
    .my-points-badge svg { width: 24px; height: 24px; color: #eab308; }

    .reward-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; }
    
    .reward-card {
        background: var(--surface); border: 1px solid var(--border); border-radius: 16px; overflow: hidden;
        transition: all 0.2s; display: flex; flex-direction: column;
    }
    .reward-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.06); border-color: #cbd5e1; }
    
    .reward-img { width: 100%; height: 160px; background: #f1f5f9; object-fit: cover; }
    .reward-img-placeholder { 
        width: 100%; height: 160px; background: #f8fafc; display: flex; align-items: center; justify-content: center;
        color: #cbd5e1; border-bottom: 1px solid #f1f5f9;
    }
    
    .reward-body { padding: 20px; display: flex; flex-direction: column; flex: 1; }
    .reward-title { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
    .reward-desc { font-size: 13px; color: var(--text-muted); line-height: 1.5; margin-bottom: 16px; flex: 1; }
    
    .reward-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; }
    .reward-cost { font-weight: 800; color: #eab308; display: flex; align-items: center; gap: 4px; font-size: 18px; }
    .reward-cost svg { width: 18px; height: 18px; }
    
</style>

<div class="page-header">
    <div class="page-title">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <rect x="2" y="7" width="20" height="14" rx="2" />
            <path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16" />
        </svg>
        Katalog Reward Points
    </div>
    <div class="my-points-badge" id="headerPoints">
        <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        <span id="ptsVal">...</span> Poin
    </div>
</div>

<div class="reward-grid" id="rewardGrid">
    <div style="grid-column: 1/-1; text-align: center; padding: 40px; color: var(--text-muted);">
        Memuat katalog reward...
    </div>
</div>

<script>
    let myPoints = 0;

    async function loadRewards() {
        try {
            // Load user points
            const rUser = await fetch('/api/me');
            const resUser = await rUser.json();
            if(resUser.success) {
                myPoints = resUser.data.points || 0;
                document.getElementById('ptsVal').textContent = myPoints;
            }

            // Load reward items
            const rItems = await fetch('/api/rewards/items'); // This API needs to be implemented in routes/rewards.js
            const resItems = await rItems.json();
            const grid = document.getElementById('rewardGrid');

            if(!resItems.success || resItems.data.length === 0) {
                grid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; padding: 40px; background: white; border-radius: 16px; border: 1px solid var(--border);">Belum ada item reward yang tersedia.</div>';
                return;
            }

            let html = '';
            resItems.data.forEach(item => {
                const canAfford = myPoints >= item.points_required;
                const imgHtml = item.image_url 
                    ? `<img src="${item.image_url}" class="reward-img">`
                    : `<div class="reward-img-placeholder"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>`;

                html += `
                <div class="reward-card">
                    ${imgHtml}
                    <div class="reward-body">
                        <div class="reward-title">${item.name}</div>
                        <div class="reward-desc">${item.description || 'Tidak ada deskripsi.'}</div>
                        <div class="reward-footer">
                            <div class="reward-cost">
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                ${item.points_required}
                            </div>
                            <button class="btn btn-primary" style="font-size:13px; padding:8px 16px; border-radius:8px;" ${canAfford ? '' : 'disabled'} onclick="redeem(${item.id})">
                                ${canAfford ? 'Tukar Poin' : 'Poin Kurang'}
                            </button>
                        </div>
                    </div>
                </div>`;
            });
            grid.innerHTML = html;
        } catch(e) { console.error(e); }
    }

    async function redeem(itemId) {
        if(!confirm('Apakah Anda yakin ingin menukarkan poin dengan item ini?')) return;
        
        try {
            const r = await fetch('/api/rewards/redeem', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ item_id: itemId })
            });
            const res = await r.json();
            if(res.success) {
                alert('Berhasil menukarkan poin! Silakan tunggu konfirmasi admin.');
                loadRewards(); // reload to update points
            } else {
                alert(res.message || 'Gagal menukarkan poin.');
            }
        } catch(err) {
            alert('Kesalahan jaringan');
        }
    }

    document.addEventListener('DOMContentLoaded', loadRewards);
</script>

<%- include('footer') %>
