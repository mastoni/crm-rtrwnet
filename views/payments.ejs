<%- include('layouts/header') %>

    <style>
        :root {
            --d-bg: #eef2f9;
            --d-card: #fff;
            --d-border: #e0e7f3;
            --d-text: #0d1b3e;
            --d-muted: #6b7fa8;
            --d-blue1: #1a6ef5;
            --d-blue2: #0047cc;
        }

        .pay-page {
            font-family: 'DM Sans', sans-serif;
            background: var(--d-bg) !important;
        }

        /* ── Fintech cards ── */
        /* ── STAT CARDS — single strip ── */
        .fin-grid,
        .fin-grid-4 {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            background: #fff;
            border-radius: 16px;
            border: 1px solid #e8eaed;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .fin-card {
            padding: 20px 22px 18px;
            border-right: 1px solid #e8eaed;
            min-height: 130px;
            cursor: default;
            display: flex;
            flex-direction: column;
            gap: 0;
            position: relative;
            overflow: hidden;
            transition: background .15s;
        }

        .fin-card::before,
        .fin-card::after {
            display: none !important;
            content: none !important;
        }

        .fin-card .orb1,
        .fin-card .orb2 {
            display: none !important;
        }

        .fin-card:last-child {
            border-right: none;
        }

        .fin-card:hover {
            background: #fafbff;
        }

        .card-lbl {
            font-size: 12px;
            font-weight: 500;
            color: #64748b;
            margin-bottom: 10px;
            letter-spacing: .1px;
            transition: color .15s;
        }

        .card-body {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 8px;
        }

        .card-left {
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .card-val {
            font-size: 30px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -1.2px;
            line-height: 1;
            transition: color .15s;
        }

        @media(max-width:1400px) {
            .card-val {
                font-size: 26px;
            }
        }

        .card-meta {
            display: flex;
            flex-direction: column;
            gap: 3px;
            margin-top: 6px;
        }

        .card-pill {
            display: inline-flex;
            align-items: center;
            padding: 1px 6px;
            border-radius: 100px;
            font-size: 10.5px;
            font-weight: 700;
            white-space: nowrap;
            flex-shrink: 0;
            align-self: flex-start;
        }

        .pill-green {
            background: #dcfce7;
            color: #16a34a;
        }

        .pill-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .pill-red {
            background: #fee2e2;
            color: #dc2626;
        }

        .pill-amber {
            background: #fef3c7;
            color: #b45309;
        }

        .pill-teal {
            background: #cffafe;
            color: #0e7490;
        }

        .pill-orange {
            background: #ffedd5;
            color: #c2410c;
        }

        .pill-slate {
            background: #f1f5f9;
            color: #475569;
        }

        .card-sub {
            font-size: 11px;
            color: #94a3b8;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            transition: color .15s;
        }

        .card-spark {
            flex-shrink: 0;
            width: 72px;
            height: 36px;
        }

        .card-spark svg {
            width: 72px;
            height: 36px;
        }

        .sp-fill {
            transition: fill .3s;
        }

        .sp-line {
            stroke-width: 1.8;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .sp-dot {}

        @media(max-width:700px) {

            .fin-grid,
            .fin-grid-4 {
                grid-template-columns: repeat(2, 1fr);
            }

            .fin-card {
                border-right: none;
                border-bottom: 1px solid #e8eaed;
            }

            .fin-card:nth-child(odd) {
                border-right: 1px solid #e8eaed;
            }

            .fin-card:nth-child(even) {
                border-right: none;
            }

            .fin-card:nth-last-child(-n+2) {
                border-bottom: none;
            }
        }

        @media(max-width:400px) {

            .fin-grid,
            .fin-grid-4 {
                grid-template-columns: 1fr;
            }

            .fin-card {
                border-right: none !important;
                border-bottom: 1px solid #e8eaed;
            }

            .fin-card:last-child {
                border-bottom: none;
            }
        }

        /* ── Layout ── */
        /* Main layout: form left + right panel */
        .pay-layout {
            display: grid;
            grid-template-columns: 300px minmax(0, 1fr);
            gap: 16px;
            align-items: start;
        }

        @media(max-width:1100px) {
            .pay-layout {
                grid-template-columns: 260px 1fr;
            }
        }

        @media(max-width:900px) {
            .pay-layout {
                grid-template-columns: 1fr;
            }
        }

        /* Responsive breakpoints — mengikuti PHP referensi */
        @media(max-width:1100px) {
            .fin-grid {
                grid-template-columns: repeat(2, 1fr) !important;
            }
        }

        @media(max-width:960px) {
            .pay-layout {
                grid-template-columns: 1fr !important;
            }

            .form-card {
                position: static !important;
            }
        }

        @media(max-width:640px) {
            .fin-grid {
                grid-template-columns: 1fr !important;
                gap: 0 !important;
            }

            .fin-card {
                padding: 18px 20px !important;
                min-height: auto !important;
                border-right: none !important;
                border-bottom: 1px solid #e8eaed;
            }

            .fin-card:last-child {
                border-bottom: none;
            }

            .fin-card .fc-val {
                font-size: 26px !important;
            }

            .fin-card .fc-bar {
                display: none;
            }

            .pay-btn {
                font-size: 13px;
                padding: 10px;
            }

            .method-grid {
                grid-template-columns: repeat(2, 1fr) !important;
            }

            .col-hide-mobile {
                display: none !important;
            }

            .pay-table th,
            .pay-table td {
                padding: 8px 10px !important;
                font-size: 11.5px !important;
            }

            .tbl-search {
                max-width: 100% !important;
            }
        }

        /* ── Form card ── */
        .form-card {
            background: #fff;
            border: 1px solid var(--d-border);
            border-radius: 22px;
            padding: 22px;
            position: sticky;
            top: 80px;
        }

        .form-card-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 18px;
        }

        .form-card-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: #eff6ff;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #1a6ef5;
        }

        .form-card-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--d-text);
        }

        .form-card-sub {
            font-size: 11px;
            color: var(--d-muted);
        }

        .pf-label {
            font-size: 10.5px;
            font-weight: 700;
            letter-spacing: .07em;
            text-transform: uppercase;
            color: var(--d-muted);
            display: block;
            margin-bottom: 6px;
        }

        .pf-input {
            width: 100%;
            padding: 10px 12px;
            border-radius: 10px;
            border: 1.5px solid var(--d-border);
            font-size: 13px;
            box-sizing: border-box;
            font-family: 'DM Sans', sans-serif;
            transition: border-color .15s, box-shadow .15s;
            outline: none;
        }

        .pf-input:focus {
            border-color: var(--d-blue1);
            box-shadow: 0 0 0 3px rgba(26, 110, 245, .1);
        }

        .pf-field {
            margin-bottom: 14px;
        }

        /* Customer autocomplete */
        .cust-wrap {
            position: relative;
        }

        .cust-icon {
            position: absolute;
            left: 11px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--d-muted);
            pointer-events: none;
        }

        .cust-inp {
            padding-left: 34px !important;
        }

        #custDropdown {
            display: none;
            position: absolute;
            z-index: 999;
            background: #fff;
            border: 1.5px solid var(--d-border);
            border-radius: 12px;
            max-height: 220px;
            overflow-y: auto;
            width: 100%;
            top: calc(100% + 4px);
            box-shadow: 0 12px 40px rgba(13, 27, 62, .15);
        }

        .cust-item {
            padding: 10px 13px;
            cursor: pointer;
            border-bottom: 1px solid #f0f4ff;
            transition: background .1s;
            font-size: 13px;
        }

        .cust-item:last-child {
            border-bottom: none;
        }

        .cust-item:hover {
            background: #f4f8ff;
        }

        .cust-item .ci-name {
            font-weight: 600;
            color: var(--d-text);
        }

        .cust-item .ci-sub {
            font-size: 11px;
            color: var(--d-muted);
            margin-top: 1px;
        }

        #custInfo {
            display: none;
            margin-top: 8px;
            padding: 12px 13px;
            background: #f4f8ff;
            border: 1px solid var(--d-border);
            border-radius: 10px;
            font-size: 12.5px;
        }

        /* Method pills */
        .method-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 6px;
        }

        .mpill {
            text-align: center;
            padding: 8px 4px;
            border-radius: 10px;
            border: 1.5px solid var(--d-border);
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all .15s;
            background: #fff;
            color: var(--d-text);
            user-select: none;
        }

        .mpill.active {
            border-color: var(--d-blue1);
            background: #eff6ff;
            color: var(--d-blue1);
        }

        .mpill:hover:not(.active) {
            background: #f8faff;
        }

        /* WA toggle */
        .wa-toggle-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 13px;
            background: #f0fdf4;
            border: 1.5px solid #bbf7d0;
            border-radius: 10px;
            margin-bottom: 14px;
        }

        /* Submit */
        .pay-btn {
            width: 100%;
            padding: 12px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 700;
            background: linear-gradient(135deg, #1a6ef5, #0047cc);
            color: #fff;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: opacity .15s, transform .1s;
            font-family: 'DM Sans', sans-serif;
        }

        .pay-btn:hover {
            opacity: .92;
            transform: translateY(-1px);
        }

        .pay-btn:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }

        /* Success banner */
        #successBanner {
            display: none;
            background: #f0fdf4;
            border: 1.5px solid #bbf7d0;
            border-radius: 14px;
            padding: 14px 18px;
            margin-bottom: 18px;
        }

        /* ── Right panel ── */
        .right-panel {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        /* Chart card */
        /* Chart row */
        .chart-row {
            display: grid;
            grid-template-columns: minmax(0, 2fr) minmax(200px, 1fr);
            gap: 16px;
            margin-bottom: 16px;
        }

        @media(max-width:900px) {
            .chart-row {
                grid-template-columns: 1fr;
            }
        }

        .w-card {
            background: #fff;
            border: 1px solid var(--d-border);
            border-radius: 22px;
            padding: 20px;
        }

        .wc-lbl {
            font-size: 10.5px;
            font-weight: 700;
            letter-spacing: .07em;
            text-transform: uppercase;
            color: var(--d-muted);
        }

        .wc-ttl {
            font-size: 15px;
            font-weight: 700;
            color: var(--d-text);
            margin-top: 2px;
        }

        .chart-filters {
            display: flex;
            gap: 6px;
            align-items: center;
        }

        .cf-select {
            padding: 5px 9px;
            border: 1.5px solid var(--d-border);
            border-radius: 8px;
            font-size: 12px;
            outline: none;
            background: #f8faff;
            color: var(--d-text);
            cursor: pointer;
        }

        /* Donut legend */
        .mb-row {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            margin-bottom: 8px;
        }

        .mb-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .mb-label {
            flex: 1;
            color: var(--d-text);
            font-weight: 600;
        }

        .mb-bar {
            width: 60px;
            height: 4px;
            background: #e0e7f3;
            border-radius: 2px;
            overflow: hidden;
        }

        .mb-fill {
            height: 100%;
            border-radius: 2px;
        }

        .mb-pct {
            min-width: 32px;
            text-align: right;
            font-weight: 700;
        }

        /* ── Table ── */
        .table-card {
            background: #fff;
            border: 1px solid var(--d-border);
            border-radius: 22px;
            overflow: hidden;
        }

        .table-header {
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            border-bottom: 1px solid #f0f4ff;
        }

        .tbl-search {
            position: relative;
            flex: 1;
            min-width: 200px;
            max-width: 280px;
        }

        .tbl-search svg {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            pointer-events: none;
        }

        .tbl-search input {
            width: 100%;
            padding: 8px 12px 8px 32px;
            border: 1.5px solid var(--d-border);
            border-radius: 10px;
            font-size: 13px;
            outline: none;
            box-sizing: border-box;
            background: #f8faff;
            transition: all .15s;
        }

        .tbl-search input:focus {
            border-color: var(--d-blue1);
            background: #fff;
        }

        .tbl-section-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: var(--d-muted);
        }

        .tbl-count {
            margin-left: auto;
            font-size: 12px;
            color: var(--d-muted);
            font-weight: 600;
        }

        .pay-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        .pay-table thead th {
            padding: 10px 16px;
            font-size: 10.5px;
            font-weight: 700;
            color: var(--d-muted);
            text-transform: uppercase;
            letter-spacing: .06em;
            background: #f8faff;
            text-align: left;
            white-space: nowrap;
            border-bottom: 1px solid #f0f4ff;
        }

        .pay-table tbody td {
            padding: 12px 16px;
            border-bottom: 1px solid #f8faff;
            vertical-align: middle;
        }

        .pay-table tbody tr:last-child td {
            border-bottom: none;
        }

        .pay-table tbody tr:hover td {
            background: #f8faff;
        }

        .mbadge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11.5px;
            font-weight: 700;
            white-space: nowrap;
        }

        .inv-btn {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            border-radius: 7px;
            font-size: 11.5px;
            font-weight: 700;
            background: #eff6ff;
            color: #1d4ed8;
            border: 1.5px solid #bfdbfe;
            cursor: pointer;
            transition: background .15s;
        }

        .inv-btn:hover {
            background: #dbeafe;
        }

        .del-btn {
            background: #fff0f2;
            border: 1.5px solid #fecdd3;
            color: #f5365c;
            padding: 4px 10px;
            border-radius: 7px;
            font-size: 11.5px;
            cursor: pointer;
            font-weight: 600;
            transition: background .15s;
        }

        .del-btn:hover {
            background: #ffe4e8;
        }

        .sent-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 11px;
            font-weight: 600;
            color: #16a34a;
            background: #dcfce7;
            padding: 2px 8px;
            border-radius: 20px;
        }

        /* Empty/loading */
        .tbl-empty {
            padding: 50px 20px;
            text-align: center;
            color: #94a3b8;
        }

        .tbl-empty svg {
            width: 40px;
            height: 40px;
            margin-bottom: 10px;
            opacity: .35;
        }

        /* Pagination */
        .pay-pagination {
            padding: 14px 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            border-top: 1px solid #f0f4ff;
        }

        .pg-btn {
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 12.5px;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid var(--d-border);
            background: #fff;
            color: var(--d-text);
            transition: background .15s;
        }

        .pg-btn:hover {
            background: #f4f8ff;
        }

        .pg-btn.active {
            background: var(--d-blue1);
            border-color: var(--d-blue1);
            color: #fff;
        }

        /* ── Card active state ── */
        .fin-card {
            cursor: pointer;
        }

        .fin-card.fc-active {
            background: #2563eb;
            border-color: #2563eb;
        }

        .fin-card.fc-active:hover {
            background: #1d4ed8;
        }

        .fin-card.fc-active .card-lbl {
            color: rgba(255, 255, 255, .70);
        }

        .fin-card.fc-active .card-val {
            color: #fff;
        }

        .fin-card.fc-active .card-sub {
            color: rgba(255, 255, 255, .60);
        }

        .fin-card.fc-active .card-pill {
            background: rgba(255, 255, 255, .20) !important;
            color: rgba(255, 255, 255, .90) !important;
        }

        .fin-card.fc-active .sp-line {
            stroke: rgba(255, 255, 255, .70) !important;
        }

        .fin-card.fc-active .sp-fill {
            fill: rgba(255, 255, 255, .12) !important;
        }

        .fin-card.fc-active .sp-dot {
            fill: #fff !important;
        }
    </style>

    <main class="page-content">

        <!-- Header -->
        <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px;"
            class="a1">
            <div>
                <h1 style="font-size:22px;font-weight:800;color:#0d1b3e;margin:0 0 4px;">Payments</h1>
                <p style="font-size:13px;color:var(--d-muted);margin:0;" id="payHeaderSub">Manajemen pembayaran
                    pelanggan ISP</p>
            </div>
        </div>

        <!-- Success Banner -->
        <div id="successBanner" class="a1">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div
                        style="width:34px;height:34px;border-radius:10px;background:#dcfce7;display:flex;align-items:center;justify-content:center;font-size:16px;">
                        ✅</div>
                    <div>
                        <div style="font-size:13.5px;font-weight:700;color:#15803d;" id="successMsg">Pembayaran berhasil
                            dicatat.</div>
                        <div style="font-size:12px;color:#16a34a;margin-top:1px;" id="successInvNum"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stat Cards -->

        <div class="fin-grid">
            <div class="fin-card fc-active" id="fc-totalinv" onclick="payCardClick(this)">
                <div class="card-lbl">Total Tagihan</div>
                <div class="card-body">
                    <div class="card-left">
                        <span class="card-val" id="fcTotalInv">–</span>
                        <div class="card-meta">
                            <span class="card-pill pill-orange" id="cp-totalinv">—</span>
                            <span class="card-sub" id="fcTotalInvSub">0 invoice</span>
                        </div>
                    </div>
                    <div class="card-spark">
                        <svg id="sp-totalinv" viewBox="0 0 72 36" preserveAspectRatio="none">
                            <path class="sp-fill" id="sp-totalinv-fill" d="" fill="#c2410c" opacity=".12" />
                            <path class="sp-line" id="sp-totalinv-line" d="" stroke="#c2410c" />
                            <circle class="sp-dot" id="sp-totalinv-dot" r="2.5" fill="#c2410c" />
                        </svg>
                    </div>
                </div>
            </div>
            <div class="fin-card" id="fc-amt" onclick="payCardClick(this)">
                <div class="card-lbl">Penerimaan</div>
                <div class="card-body">
                    <div class="card-left">
                        <span class="card-val" id="fcAmt">–</span>
                        <div class="card-meta">
                            <span class="card-pill pill-blue" id="cp-amt">—</span>
                            <span class="card-sub" id="fcAmtSub">0 transaksi</span>
                        </div>
                    </div>
                    <div class="card-spark">
                        <svg id="sp-amt" viewBox="0 0 72 36" preserveAspectRatio="none">
                            <path class="sp-fill" id="sp-amt-fill" d="" fill="#2563eb" opacity=".12" />
                            <path class="sp-line" id="sp-amt-line" d="" stroke="#2563eb" />
                            <circle class="sp-dot" id="sp-amt-dot" r="2.5" fill="#2563eb" />
                        </svg>
                    </div>
                </div>
            </div>
            <div class="fin-card" id="fc-tx" onclick="payCardClick(this)">
                <div class="card-lbl">Transaksi</div>
                <div class="card-body">
                    <div class="card-left">
                        <span class="card-val" id="fcTx">–</span>
                        <div class="card-meta">
                            <span class="card-pill pill-teal" id="cp-tx">—</span>
                            <span class="card-sub" id="fcTxSub">Bulan ini</span>
                        </div>
                    </div>
                    <div class="card-spark">
                        <svg id="sp-tx" viewBox="0 0 72 36" preserveAspectRatio="none">
                            <path class="sp-fill" id="sp-tx-fill" d="" fill="#0891b2" opacity=".12" />
                            <path class="sp-line" id="sp-tx-line" d="" stroke="#0891b2" />
                            <circle class="sp-dot" id="sp-tx-dot" r="2.5" fill="#0891b2" />
                        </svg>
                    </div>
                </div>
            </div>
            <div class="fin-card" id="fc-overdue" onclick="payCardClick(this)">
                <div class="card-lbl">Tertunggak</div>
                <div class="card-body">
                    <div class="card-left">
                        <span class="card-val" id="fcOverdue">–</span>
                        <div class="card-meta">
                            <span class="card-pill pill-red" id="cp-overdue">—</span>
                            <span class="card-sub" id="fcOverdueSub">0 tagihan</span>
                        </div>
                    </div>
                    <div class="card-spark">
                        <svg id="sp-overdue" viewBox="0 0 72 36" preserveAspectRatio="none">
                            <path class="sp-fill" id="sp-overdue-fill" d="" fill="#dc2626" opacity=".12" />
                            <path class="sp-line" id="sp-overdue-line" d="" stroke="#dc2626" />
                            <circle class="sp-dot" id="sp-overdue-dot" r="2.5" fill="#dc2626" />
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main layout -->
        <div class="pay-layout">

            <!-- Form Panel -->
            <div class="form-card a5">
                <div class="form-card-header">
                    <div class="form-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24"
                            stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                        </svg>
                    </div>
                    <div>
                        <div class="form-card-title">Input Payment</div>
                        <div class="form-card-sub">Input transaksi baru</div>
                    </div>
                </div>

                <!-- Customer search -->
                <div class="pf-field">
                    <label class="pf-label">Pelanggan *</label>
                    <div class="cust-wrap">
                        <svg class="cust-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none"
                            viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <circle cx="11" cy="11" r="8" />
                            <path stroke-linecap="round" d="M21 21l-4.35-4.35" />
                        </svg>
                        <input type="text" id="custSearch" class="pf-input cust-inp"
                            placeholder="Nama, CID, atau nomor HP..." autocomplete="off"
                            oninput="searchCustomers(this.value)">
                        <input type="hidden" id="selectedCustId">
                        <div id="custDropdown"></div>
                    </div>
                    <div id="custInfo"></div>
                </div>

                <!-- Amount & Date -->
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                    <div class="pf-field">
                        <label class="pf-label">Jumlah (Rp) *</label>
                        <input type="text" id="payAmount" class="pf-input" placeholder="0" oninput="formatAmount(this)">
                    </div>
                    <div class="pf-field">
                        <label class="pf-label">Tanggal *</label>
                        <input type="date" id="payDate" class="pf-input">
                    </div>
                </div>

                <!-- Method -->
                <div class="pf-field">
                    <label class="pf-label">Metode Payment *</label>
                    <div class="method-grid">
                        <div class="mpill active" onclick="selectMethod(this,'cash')">Cash</div>
                        <div class="mpill" onclick="selectMethod(this,'transfer')">Transfer</div>
                        <div class="mpill" onclick="selectMethod(this,'dana')">DANA</div>
                        <div class="mpill" onclick="selectMethod(this,'ovo')">OVO</div>
                        <div class="mpill" onclick="selectMethod(this,'gopay')">GoPay</div>
                        <div class="mpill" onclick="selectMethod(this,'qris')">QRIS</div>
                    </div>
                    <input type="hidden" id="payMethod" value="cash">
                </div>

                <!-- Bank (conditional) -->
                <div class="pf-field" id="bankField" style="display:none;">
                    <label class="pf-label">Nama Bank</label>
                    <input type="text" id="payBank" class="pf-input" placeholder="BCA, Mandiri, BRI...">
                </div>

                <!-- Reference -->
                <div class="pf-field">
                    <label class="pf-label">No. Referensi / Bukti</label>
                    <input type="text" id="payRef" class="pf-input" placeholder="Kode transfer, bukti, dll">
                </div>

                <!-- Due date after -->
                <div class="pf-field">
                    <label class="pf-label">Jatuh Tempo Baru *</label>
                    <input type="date" id="payDueDate" class="pf-input">
                    <div style="font-size:11px;color:var(--d-muted);margin-top:4px;">Tanggal aktif baru setelah
                        pembayaran ini</div>
                </div>

                <!-- Period -->
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                    <div class="pf-field">
                        <label class="pf-label">Bulan</label>
                        <select id="payPeriodMonth" class="pf-input" style="cursor:pointer;">
                            <option value="1">Januari</option>
                            <option value="2">Februari</option>
                            <option value="3">Maret</option>
                            <option value="4">April</option>
                            <option value="5">Mei</option>
                            <option value="6">Juni</option>
                            <option value="7">Juli</option>
                            <option value="8">Agustus</option>
                            <option value="9">September</option>
                            <option value="10">Oktober</option>
                            <option value="11">November</option>
                            <option value="12">Desember</option>
                        </select>
                    </div>
                    <div class="pf-field">
                        <label class="pf-label">Tahun</label>
                        <input type="number" id="payPeriodYear" class="pf-input" min="2020" max="2099">
                    </div>
                </div>

                <!-- Notes -->
                <div class="pf-field">
                    <label class="pf-label">Catatan</label>
                    <input type="text" id="payNotes" class="pf-input" placeholder="Opsional">
                </div>

                <!-- WA toggle -->
                <div class="wa-toggle-row">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#25d366" viewBox="0 0 24 24">
                        <path
                            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                    </svg>
                    <div style="flex:1;">
                        <div style="font-size:13px;font-weight:600;color:#15803d;">Kirim konfirmasi WA</div>
                        <div style="font-size:11px;color:#16a34a;">Otomatis ke nomor pelanggan</div>
                    </div>
                    <label style="position:relative;display:inline-block;width:40px;height:22px;cursor:pointer;">
                        <input type="checkbox" id="paySendWa" style="opacity:0;width:0;height:0;">
                        <span id="waSlider"
                            style="position:absolute;inset:0;background:#ccc;border-radius:22px;transition:.2s;"></span>
                        <span id="waThumb"
                            style="position:absolute;width:18px;height:18px;background:#fff;border-radius:50%;top:2px;left:2px;transition:.2s;box-shadow:0 1px 3px rgba(0,0,0,.2);"></span>
                    </label>
                </div>

                <button class="pay-btn" id="submitBtn" onclick="submitPayment()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    Catat Pembayaran
                </button>
            </div>

            <!-- Right panel -->
            <div class="right-panel">

                <!-- Chart row: bar + donut -->
                <div class="chart-row a5">

                    <!-- Bar chart -->
                    <div class="w-card">
                        <div
                            style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:8px;">
                            <div>
                                <div class="wc-lbl">Penerimaan Harian</div>
                                <div class="wc-ttl" id="chartSubTitle">–</div>
                            </div>
                            <div class="chart-filters">
                                <select id="filterMonth" class="cf-select" onchange="onFilterChange()">
                                    <option value="1">Jan</option>
                                    <option value="2">Feb</option>
                                    <option value="3">Mar</option>
                                    <option value="4">Apr</option>
                                    <option value="5">Mei</option>
                                    <option value="6">Jun</option>
                                    <option value="7">Jul</option>
                                    <option value="8">Agu</option>
                                    <option value="9">Sep</option>
                                    <option value="10">Okt</option>
                                    <option value="11">Nov</option>
                                    <option value="12">Des</option>
                                </select>
                                <select id="filterYear" class="cf-select" onchange="onFilterChange()"></select>
                            </div>
                        </div>
                        <canvas id="payChart" style="max-height:150px;"></canvas>
                    </div>

                    <!-- Donut chart -->
                    <div class="w-card" style="display:flex;flex-direction:column;">
                        <div class="wc-lbl" style="margin-bottom:4px;">Metode Pembayaran</div>
                        <div class="wc-ttl" id="donutSubTitle" style="margin-bottom:14px;">–</div>
                        <canvas id="donutChart" style="max-height:130px;margin-bottom:14px;"></canvas>
                        <div id="donutLegend"></div>
                    </div>

                </div>

                <!-- Table -->
                <div class="table-card a6">
                    <div class="table-header">
                        <div>
                            <div class="tbl-section-title">Riwayat Pembayaran</div>
                            <div style="font-size:12px;color:var(--d-muted);margin-top:2px;" id="tblSubTitle">–</div>
                        </div>
                        <div class="tbl-search">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                <circle cx="11" cy="11" r="8" />
                                <path stroke-linecap="round" d="M21 21l-4.35-4.35" />
                            </svg>
                            <input type="text" id="tblSearch" placeholder="Cari nama, CID, HP..."
                                oninput="onSearchChange()">
                        </div>
                        <div class="tbl-count" id="tblCount">–</div>
                    </div>
                    <div style="overflow-x:auto;">
                        <table class="pay-table">
                            <thead>
                                <tr>
                                    <th>Pelanggan</th>
                                    <th>Tgl Bayar</th>
                                    <th>Jumlah</th>
                                    <th>Metode</th>
                                    <th>Due Date</th>
                                    <th class="col-hide-mobile">Notification</th>
                                    <th class="col-hide-mobile">Validation By</th>
                                    <th class="col-hide-mobile">Invoice</th>
                                    <th>Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="payTable">
                                <tr>
                                    <td colspan="9">
                                        <div class="tbl-empty"><svg xmlns="http://www.w3.org/2000/svg" fill="none"
                                                viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                                            </svg>
                                            <p>Memuat data...</p>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="pay-pagination" id="payPagination"></div>
                </div>

            </div>
        </div>

    </main>

    <%- include('layouts/footer') %>