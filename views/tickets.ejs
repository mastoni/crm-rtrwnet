                    <select class="form-input" id="dtl-update-status" style="width:160px; padding:8px 12px;">
                        <option value="open">Open</option>
                        <option value="in_progress">In Progress</option>
                        <option value="resolved">Resolved</option>
                        <option value="closed">Closed</option>
                    </select>
                    <button class="btn-modern btn-save" style="padding:8px 14px; font-size:12px; background:linear-gradient(135deg, #10b981, #059669); border-color:#059669;" onclick="updateTicketStatus()">Update Status</button>
                </div>
                <button type="button" class="btn-modern btn-cancel" onclick="closeDetailModal()">Tutup</button>
            </div>
        </div>
    </div>
