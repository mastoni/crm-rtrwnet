            border-color: #dc2626;
            color: #fff;
        }

        .btn-delete:hover {
            background: #b91c1c;
            border-color: #b91c1c;
            box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
        }

        .btn-action-delete {
