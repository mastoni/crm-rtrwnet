<%- include('layouts/header') %>

    <style>
        :root {
            --d-bg: #eef2f9;
            --d-card: #fff;
            --d-border: #e0e7f3;
            --d-text: #0d1b3e;
            --d-muted: #6b7fa8;
            --d-blue1: #1a6ef5;
        }

        .lg-page {
            font-family: 'DM Sans', sans-serif;
        }

        /* Stat cards */
        /* ── STAT CARDS — single strip ── */
        .ml-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            background: #fff;
            border-radius: 16px;
            border: 1px solid #e8eaed;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .ml-card {
            padding: 20px 22px 18px;
            border-right: 1px solid #e8eaed;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            gap: 0;
            position: relative;
            overflow: hidden;
            transition: background .15s;
        }

        .ml-card::before,
        .ml-card::after {
            display: none !important;
            content: none !important;
        }

        .ml-card:last-child {
            border-right: none;
        }

        .ml-card:hover {
            background: #fafbff;
        }

        .ml-card.xc-active {
            background: #2563eb;
            border-color: #2563eb;
        }

        .ml-card.xc-active:hover {
            background: #1d4ed8;
        }

        .ml-card.xc-active .xc-lbl {
            color: rgba(255, 255, 255, .70);
        }

        .ml-card.xc-active .xc-val {
            color: #fff;
        }

        .ml-card.xc-active .xc-sub {
            color: rgba(255, 255, 255, .60);
        }

        .ml-card.xc-active .xc-pill {
            background: rgba(255, 255, 255, .20) !important;
            color: rgba(255, 255, 255, .90) !important;
        }

        .ml-card.xc-active .sp-line {
            stroke: rgba(255, 255, 255, .70) !important;
        }

        .ml-card.xc-active .sp-fill {
            fill: rgba(255, 255, 255, .12) !important;
        }

        .ml-card.xc-active .sp-dot {
            fill: #fff !important;
        }

        .xc-lbl {
            font-size: 12px;
            font-weight: 500;
            color: #64748b;
            margin-bottom: 10px;
            letter-spacing: .1px;
            transition: color .15s;
        }

        .xc-body {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 8px;
        }

        .xc-left {
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .xc-val {
            font-size: 30px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -1.2px;
            line-height: 1;
            transition: color .15s;
        }

        @media(max-width:1400px) {
            .xc-val {
                font-size: 26px;
            }
        }

        .xc-meta {
            display: flex;
            align-items: center;
            gap: 5px;
            margin-top: 6px;
            flex-wrap: wrap;
        }

        .xc-pill {
            display: inline-flex;
            align-items: center;
            gap: 2px;
            padding: 1px 6px;
            border-radius: 100px;
            font-size: 10.5px;
            font-weight: 700;
            white-space: nowrap;
            flex-shrink: 0;
            transition: all .15s;
        }

        .xc-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .xc-green {
            background: #dcfce7;
            color: #16a34a;
        }

        .xc-red {
            background: #fee2e2;
            color: #dc2626;
        }

        .xc-amber {
            background: #fef3c7;
            color: #b45309;
        }

        .xc-slate {
            background: #f1f5f9;
            color: #475569;
        }

        .xc-teal {
            background: #cffafe;
            color: #0e7490;
        }

        .xc-orange {
            background: #ffedd5;
            color: #c2410c;
        }

        .xc-sub {
            font-size: 11px;
            color: #94a3b8;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            transition: color .15s;
        }

        .xc-spark {
            flex-shrink: 0;
            width: 72px;
            height: 36px;
        }

        .xc-spark svg {
            width: 72px;
            height: 36px;
        }

        .sp-fill {
            transition: fill .3s;
        }

        .sp-line {
            stroke-width: 1.8;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .sp-dot {}

        @media(max-width:700px) {
            .ml-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .ml-card {
                border-right: none;
                border-bottom: 1px solid #e8eaed;
            }

            .ml-card:nth-child(odd) {
                border-right: 1px solid #e8eaed;
            }

            .ml-card:nth-child(even) {
                border-right: none;
            }

            .ml-card:nth-last-child(-n+2) {
                border-bottom: none;
            }
        }

        @media(max-width:400px) {
            .ml-grid {
                grid-template-columns: 1fr;
            }

            .ml-card {
                border-right: none !important;
                border-bottom: 1px solid #e8eaed;
            }

            .ml-card:last-child {
                border-bottom: none;
            }
        }

        .fc-chip {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            background: rgba(255, 255, 255, .2);
            padding: 2px 8px;
            border-radius: 20px;
            display: inline-block;
        }

        .fc-val {
            font-size: 26px;
            font-weight: 800;
            line-height: 1;
            margin: 7px 0 3px;
            font-family: 'DM Mono', monospace;
        }

        .fc-sub {
            font-size: 11px;
            color: rgba(255, 255, 255, .7);
        }

        .fc-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: rgba(255, 255, 255, .18);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .fc-bar {
            height: 3px;
            border-radius: 99px;
            background: rgba(255, 255, 255, .2);
            overflow: hidden;
            margin-top: 12px;
        }

        .fc-bar-f {
            height: 100%;
            border-radius: 99px;
            background: rgba(255, 255, 255, .8);
            transition: width .7s;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(12px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        .a1 {
            animation: fadeUp .35s ease both
        }

        .a2 {
            animation: fadeUp .35s .07s ease both
        }

        .a3 {
            animation: fadeUp .35s .14s ease both
        }

        .a4 {
            animation: fadeUp .35s .21s ease both
        }

        .a5 {
            animation: fadeUp .35s .28s ease both
        }

        /* Tabs */
        .tab-bar {
            display: flex;
            gap: 4px;
            background: #f4f8ff;
            padding: 4px;
            border-radius: 12px;
            margin-bottom: 16px;
            width: fit-content;
        }

        .tab-btn {
            padding: 7px 18px;
            border-radius: 9px;
            border: none;
            background: transparent;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            color: var(--d-muted);
            transition: all .15s;
            font-family: 'DM Sans', sans-serif;
        }

        .tab-btn.active {
            background: #fff;
            color: var(--d-blue1);
            box-shadow: 0 1px 6px rgba(26, 110, 245, .12);
        }

        /* Filter bar */
        .filter-bar {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            align-items: center;
            margin-bottom: 14px;
        }

        .fi {
            padding: 7px 11px;
            border: 1.5px solid var(--d-border);
            border-radius: 9px;
            font-size: 12.5px;
            outline: none;
            background: #fff;
            color: var(--d-text);
            font-family: 'DM Sans', sans-serif;
            transition: border-color .15s;
        }

        .fi:focus {
            border-color: var(--d-blue1);
        }

        .fi-search {
            position: relative;
        }

        .fi-search svg {
            position: absolute;
            left: 9px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            pointer-events: none;
        }

        .fi-search input {
            padding-left: 30px;
        }

        .fi-btn {
            padding: 7px 14px;
            border-radius: 9px;
            border: none;
            background: linear-gradient(135deg, #1a6ef5, #0047cc);
            color: #fff;
            font-size: 12.5px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
        }

        .fi-btn-ghost {
            background: #f4f8ff;
            color: var(--d-blue1);
            border: 1.5px solid var(--d-border);
        }

        /* Main content card */
        .lg-card {
            background: #fff;
            border: 1px solid var(--d-border);
            border-radius: 20px;
            overflow: hidden;
        }

        .lg-card-hdr {
            padding: 14px 18px;
            border-bottom: 1px solid #f0f4ff;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        /* Table */
        .lg-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12.5px;
        }

        .lg-table thead th {
            padding: 9px 14px;
            font-size: 10px;
            font-weight: 700;
            color: var(--d-muted);
            text-transform: uppercase;
            letter-spacing: .06em;
            background: #f8faff;
            text-align: left;
            white-space: nowrap;
            border-bottom: 1px solid #f0f4ff;
        }

        .lg-table tbody td {
            padding: 10px 14px;
            border-bottom: 1px solid #f8faff;
            vertical-align: top;
        }

        .lg-table tbody tr:last-child td {
            border-bottom: none;
        }

        .lg-table tbody tr:hover td {
            background: #f8faff;
            cursor: pointer;
        }

        /* Message preview */
        .msg-preview {
            font-family: 'DM Mono', monospace;
            font-size: 11.5px;
            color: #374151;
            line-height: 1.5;
            max-width: 300px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        /* Status badges */
        .st {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 10.5px;
            font-weight: 700;
            white-space: nowrap;
        }

        .st::before {
            content: '';
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: currentColor;
            flex-shrink: 0;
        }

        .st-sent {
            background: #dcfce7;
            color: #16a34a;
        }

        .st-failed {
            background: #fee2e2;
            color: #dc2626;
        }

        .st-pending {
            background: #fef3c7;
            color: #d97706;
        }

        .st-in {
            background: #eff6ff;
            color: #2563eb;
        }

        /* Type chips */
        .tc {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 10.5px;
            font-weight: 700;
        }

        .tc-reminder {
            background: #fef3c7;
            color: #d97706;
        }

        .tc-broadcast {
            background: #ede9fe;
            color: #7c3aed;
        }

        .tc-manual {
            background: #e0f2fe;
            color: #0369a1;
        }

        .tc-otp {
            background: #fce7f3;
            color: #be185d;
        }

        /* Phone display */
        .phone-tag {
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: #374151;
            font-weight: 500;
        }

        /* Duration */
        .dur-tag {
            font-size: 11px;
            color: #94a3b8;
            font-family: 'DM Mono', monospace;
        }

        /* Empty */
        .tbl-empty {
            padding: 40px 20px;
            text-align: center;
            color: #94a3b8;
        }

        .tbl-empty svg {
            width: 36px;
            height: 36px;
            margin-bottom: 8px;
            opacity: .3;
        }

        /* Pagination */
        .pagination {
            padding: 12px 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid #f0f4ff;
            flex-wrap: wrap;
            gap: 8px;
        }

        .pg-info {
            font-size: 12px;
            color: var(--d-muted);
        }

        .pg-btns {
            display: flex;
            gap: 4px;
        }

        .pg-btn {
            padding: 5px 11px;
            border-radius: 7px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid var(--d-border);
            background: #fff;
            color: var(--d-text);
            transition: all .12s;
        }

        .pg-btn:hover:not(:disabled) {
            background: #f4f8ff;
        }

        .pg-btn.active {
            background: var(--d-blue1);
            border-color: var(--d-blue1);
            color: #fff;
        }

        .pg-btn:disabled {
            opacity: .4;
            cursor: not-allowed;
        }

        /* Chart */
        .chart-wrap {
            background: #fff;
            border: 1px solid var(--d-border);
            border-radius: 20px;
            padding: 18px;
            margin-bottom: 16px;
        }

        .chart-hdr {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 14px;
            flex-wrap: wrap;
            gap: 8px;
        }

        /* Modal */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .45);
            z-index: 999;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .modal-overlay.show {
            display: flex;
        }

        .modal-box {
            background: #fff;
            border-radius: 20px;
            width: 100%;
            max-width: 560px;
            max-height: 80vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 20px 60px rgba(0, 0, 0, .2);
        }

        .modal-hdr {
            padding: 16px 20px;
            border-bottom: 1px solid var(--d-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .modal-body {
            padding: 18px;
            overflow-y: auto;
            flex: 1;
        }

        .modal-msg {
            font-family: 'DM Mono', monospace;
            font-size: 12.5px;
            white-space: pre-wrap;
            line-height: 1.8;
            background: #f8faff;
            border-radius: 10px;
            padding: 14px;
            border: 1px solid var(--d-border);
            color: #1a1a1a;
            word-break: break-word;
        }

        @media(max-width:700px) {
            .filter-bar {
                flex-direction: column;
                align-items: stretch;
            }

            .fi,
            .fi-search input {
                width: 100%;
                box-sizing: border-box;
            }
        }
    </style>

    <main class="page-content">

        <!-- Header -->
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:16px;"
            class="a1">
            <div>
                <h1 style="font-size:21px;font-weight:800;color:#0d1b3e;margin:0 0 3px;">Message Logs</h1>
                <p style="font-size:12.5px;color:var(--d-muted);margin:0;">Riwayat pengiriman & penerimaan pesan
                    WhatsApp secara global</p>
            </div>
            <button onclick="exportLogs()"
                style="display:inline-flex;align-items:center;gap:6px;padding:8px 14px;border-radius:9px;border:1.5px solid var(--d-border);background:#fff;font-size:12.5px;font-weight:600;cursor:pointer;color:var(--d-text);">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Export CSV
            </button>
        </div>

        <!-- Stat cards -->
        <div class="ml-grid">
            <div class="ml-card xc-active" id="mlc-total" data-filter="total" onclick="mlCardClick(this)">
                <div class="xc-lbl">Total Keluar</div>
                <div class="xc-body">
                    <div class="xc-left">
                        <span class="xc-val" id="fcOutTotal">0</span>
                        <div class="xc-meta">
                            <span class="xc-pill xc-blue" id="ml-pill-total">—</span>
                            <span class="xc-sub">Pesan terkirim</span>
                        </div>
                    </div>
                    <div class="xc-spark">
                        <svg id="sp-total" viewBox="0 0 72 36" preserveAspectRatio="none">
                            <path class="sp-fill" id="sp-total-fill" d="" fill="#2563eb" opacity=".12" />
                            <path class="sp-line" id="sp-total-line" d="" stroke="#2563eb" />
                            <circle class="sp-dot" id="sp-total-dot" r="2.5" fill="#2563eb" />
                        </svg>
                    </div>
                </div>
            </div>
            <div class="ml-card" id="mlc-sent" data-filter="sent" onclick="mlCardClick(this)">
                <div class="xc-lbl">Terkirim</div>
                <div class="xc-body">
                    <div class="xc-left">
                        <span class="xc-val" id="fcSent">0</span>
                        <div class="xc-meta">
                            <span class="xc-pill xc-teal" id="ml-pill-sent">—</span>
                            <span class="xc-sub">Sukses delivery</span>
                        </div>
                    </div>
                    <div class="xc-spark">
                        <svg id="sp-sent" viewBox="0 0 72 36" preserveAspectRatio="none">
                            <path class="sp-fill" id="sp-sent-fill" d="" fill="#0891b2" opacity=".12" />
                            <path class="sp-line" id="sp-sent-line" d="" stroke="#0891b2" />
                            <circle class="sp-dot" id="sp-sent-dot" r="2.5" fill="#0891b2" />
                        </svg>
                    </div>
                </div>
            </div>
            <div class="ml-card" id="mlc-failed" data-filter="failed" onclick="mlCardClick(this)">
                <div class="xc-lbl">Gagal</div>
                <div class="xc-body">
                    <div class="xc-left">
                        <span class="xc-val" id="fcFailed">0</span>
                        <div class="xc-meta">
                            <span class="xc-pill xc-red" id="ml-pill-failed">—</span>
                            <span class="xc-sub">Gagal kirim</span>
                        </div>
                    </div>
                    <div class="xc-spark">
                        <svg id="sp-failed" viewBox="0 0 72 36" preserveAspectRatio="none">
                            <path class="sp-fill" id="sp-failed-fill" d="" fill="#dc2626" opacity=".12" />
                            <path class="sp-line" id="sp-failed-line" d="" stroke="#dc2626" />
                            <circle class="sp-dot" id="sp-failed-dot" r="2.5" fill="#dc2626" />
                        </svg>
                    </div>
                </div>
            </div>
            <div class="ml-card" id="mlc-queue" data-filter="queue" onclick="mlCardClick(this)">
                <div class="xc-lbl">Antrian</div>
                <div class="xc-body">
                    <div class="xc-left">
                        <span class="xc-val" id="fcQueue">0</span>
                        <div class="xc-meta">
                            <span class="xc-pill xc-amber" id="ml-pill-queue">—</span>
                            <span class="xc-sub">Menunggu kirim</span>
                        </div>
                    </div>
                    <div class="xc-spark">
                        <svg id="sp-queue" viewBox="0 0 72 36" preserveAspectRatio="none">
                            <path class="sp-fill" id="sp-queue-fill" d="" fill="#d97706" opacity=".12" />
                            <path class="sp-line" id="sp-queue-line" d="" stroke="#d97706" />
                            <circle class="sp-dot" id="sp-queue-dot" r="2.5" fill="#d97706" />
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chart -->
        <div class="chart-wrap a4">
            <div class="chart-hdr">
                <div>
                    <div style="font-size:13px;font-weight:700;color:#0d1b3e;">Aktivitas Pengiriman</div>
                    <div style="font-size:11.5px;color:var(--d-muted);" id="chartSubtitle">7 hari terakhir</div>
                </div>
                <div style="display:flex;gap:6px;">
                    <button onclick="setChartDays(7,this)" class="pg-btn active" id="days7">7 hari</button>
                    <button onclick="setChartDays(14,this)" class="pg-btn" id="days14">14 hari</button>
                    <button onclick="setChartDays(30,this)" class="pg-btn" id="days30">30 hari</button>
                </div>
            </div>
            <canvas id="activityChart" height="90"></canvas>
        </div>

        <!-- Tabs -->
        <div class="tab-bar a5">
            <button class="tab-btn active" onclick="switchTab('outgoing',this)" id="tabOut">
                Pesan Keluar <span id="tabOutCount"
                    style="font-size:10px;background:#eef3ff;color:#1a6ef5;padding:1px 6px;border-radius:20px;margin-left:4px;">–</span>
            </button>
            <button class="tab-btn" onclick="switchTab('incoming',this)" id="tabIn">
                Pesan Masuk <span id="tabInCount"
                    style="font-size:10px;background:#eef3ff;color:#1a6ef5;padding:1px 6px;border-radius:20px;margin-left:4px;">–</span>
            </button>
        </div>

        <!-- Filters -->
        <div class="filter-bar a5">
            <div class="fi-search">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor" stroke-width="2.5">
                    <circle cx="11" cy="11" r="8" />
                    <path stroke-linecap="round" d="M21 21l-4.35-4.35" />
                </svg>
                <input type="text" class="fi" id="filterSearch" placeholder="Cari nomor / pesan..."
                    oninput="onFilterChange()">
            </div>
            <select class="fi" id="filterStatus" onchange="onFilterChange()" style="padding:7px 11px;"
                id="filterStatusSel">
                <option value="">Semua Status</option>
                <option value="sent">Terkirim</option>
                <option value="failed">Gagal</option>
            </select>
            <select class="fi" id="filterType" onchange="onFilterChange()" style="padding:7px 11px;">
                <option value="">Semua Tipe</option>
                <option value="text">Teks</option>
                <option value="image">Gambar</option>
