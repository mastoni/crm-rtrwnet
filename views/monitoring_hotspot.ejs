<%- include('layouts/header') %>

    <style>
        /* ══ RESET & BASE ══════════════════════════════════════════ */
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --f: 'Geist', 'Plus Jakarta Sans', system-ui, sans-serif;
            --fm: 'Geist Mono', monospace;
            --bg: #f5f5f7;
            --surface: #ffffff;
            --surface2: #fafafa;
            --border: #e8e8ed;
            --border2: #f0f0f5;
            --text: #1d1d1f;
            --text2: #6e6e73;
            --text3: #aeaeb2;
            --blue: #0071e3;
            --blue-l: #e8f1fd;
            --green: #1a7f37;
            --green-l: #e6f4ea;
            --red: #d93025;
            --red-l: #fce8e6;
            --amber: #b45309;
            --amber-l: #fef3c7;
            --purple: #6d28d9;
            --purple-l: #ede9fe;
            --teal: #0e7490;
            --teal-l: #e0f2fe;
            --shadow-sm: 0 1px 2px rgba(0, 0, 0, .04), 0 0 0 1px rgba(0, 0, 0, .03);
            --shadow: 0 4px 16px rgba(0, 0, 0, .06), 0 0 0 1px rgba(0, 0, 0, .03);
            --shadow-lg: 0 16px 48px rgba(0, 0, 0, .12), 0 0 0 1px rgba(0, 0, 0, .04);
            --rc: 16px;
            --rc-sm: 10px;
            --rc-lg: 20px;
        }

        body {
            font-family: var(--f);
            background: var(--bg);
            color: var(--text);
            -webkit-font-smoothing: antialiased;
        }

        /* ══ LAYOUT ════════════════════════════════════════════════ */
        .hs-page {
            padding: 24px;
            max-width: none;
        }

        @media (max-width: 768px) {
            .hs-page {
                padding: 16px;
            }
        }

        /* ══ HEADER ════════════════════════════════════════════════ */
        .page-hdr {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 28px;
        }

        .page-hdr-l {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .page-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: linear-gradient(135deg, #0071e3, #34aadc);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 4px 12px rgba(0, 113, 227, .25);
        }

        .page-icon svg {
            width: 22px;
            height: 22px;
            stroke: #fff;
            fill: none;
        }

        .page-hdr-l h1 {
            font-size: 20px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: -.3px;
        }

        .page-hdr-l p {
            font-size: 13px;
            color: var(--text2);
            margin-top: 1px;
        }

        .page-hdr-r {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        /* ══ LIVE BADGE ════════════════════════════════════════════ */
        .live-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 12px;
            border-radius: 100px;
            background: var(--green-l);
            color: var(--green);
            font-size: 12px;
            font-weight: 600;
            letter-spacing: .1px;
        }

        .live-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--green);
            animation: blink 2s ease-in-out infinite;
        }

        @keyframes blink {

            0%,
            100% {
                opacity: 1
            }

            50% {
                opacity: .3
            }
        }

        /* ══ BUTTONS ═══════════════════════════════════════════════ */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            border-radius: var(--rc-sm);
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            border: 1px solid transparent;
            transition: all .15s ease;
            font-family: var(--f);
            white-space: nowrap;
            outline: none;
        }

        .btn svg {
            width: 14px;
            height: 14px;
            flex-shrink: 0;
        }

        .btn:disabled {
            opacity: .45;
            cursor: not-allowed;
        }

        .btn-ghost {
            background: var(--surface);
            border-color: var(--border);
            color: var(--text2);
        }

        .btn-ghost:hover {
            background: var(--surface2);
            color: var(--text);
        }

        .btn-primary {
            background: var(--blue);
            color: #fff;
        }

        .btn-primary:hover {
            background: #0077ed;
        }

        .btn-danger {
            background: var(--red-l);
            color: var(--red);
            border-color: #f5c6c3;
        }

        .btn-danger:hover {
            background: #f9d7d5;
        }

        .btn-success {
            background: var(--green-l);
            color: var(--green);
            border-color: #b7dfbe;
        }

        .btn-success:hover {
            background: #d0ebd5;
        }

        .btn-sm {
            padding: 5px 11px;
            font-size: 12px;
            border-radius: 8px;
        }

        .btn-xs {
            padding: 3px 9px;
            font-size: 11px;
            border-radius: 7px;
        }

        .btn-icon {
            padding: 7px;
        }

        /* ══ STAT CARDS — single strip with dividers ══════════════ */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            background: #fff;
            border-radius: 16px;
            border: 1px solid #e8eaed;
            overflow: hidden;
            margin-bottom: 24px;
        }

        @media(max-width:1200px) {
            .stats-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @media(max-width:900px) {
            .stats-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @media(max-width:700px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .stat-card {
                border-right: none;
                border-bottom: 1px solid #e8eaed;
            }

            .stat-card:nth-child(odd) {
                border-right: 1px solid #e8eaed;
            }

            .stat-card:nth-child(even) {
                border-right: none;
            }

            .stat-card:nth-last-child(-n+2) {
                border-bottom: none;
            }
        }

        @media(max-width:400px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }

            .stat-card {
                border-right: none !important;
                border-bottom: 1px solid #e8eaed;
            }

            .stat-card:last-child {
                border-bottom: none;
            }
        }

        .stat-card.sc-active {
            border-color: #2563eb;
        }

        /* ── Base card ── */
        .stat-card {
            padding: 20px 22px 18px;
            min-height: 130px;
            border-right: 1px solid #e8eaed;
            cursor: pointer;
            position: relative;
            transition: background .15s;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .stat-card:last-child {
            border-right: none;
        }

        .stat-card:hover {
            background: #fafbff;
        }

        /* ── Active state — biru solid ── */
        .stat-card.sc-active {
            background: #2563eb;
            border-color: #2563eb;
        }

        .stat-card.sc-active:hover {
            background: #1d4ed8;
        }

        .stat-card.sc-active .sc-label {
            color: rgba(255, 255, 255, .70);
        }

        .stat-card.sc-active .sc-num {
            color: #fff;
        }

        .stat-card.sc-active .sc-sub {
            color: rgba(255, 255, 255, .60);
        }

        .stat-card.sc-active .sc-pill-up {
            background: rgba(255, 255, 255, .20);
            color: #bbf7d0;
        }

        .stat-card.sc-active .sc-pill-down {
            background: rgba(255, 255, 255, .20);
            color: #fecaca;
        }

        .stat-card.sc-active .sc-pill-neu {
            background: rgba(255, 255, 255, .18);
            color: rgba(255, 255, 255, .85);
        }

        .stat-card.sc-active .sc-spark-line {
            stroke: rgba(255, 255, 255, .70) !important;
        }

        .stat-card.sc-active .sc-spark-fill {
            fill: rgba(255, 255, 255, .12) !important;
        }

        .stat-card.sc-active .sc-spark-dot {
            fill: #fff !important;
        }

        /* ── Label ── */
        .sc-label {
            font-size: 12px;
            font-weight: 500;
            color: #64748b;
            margin-bottom: 10px;
            letter-spacing: .1px;
            transition: color .15s;
        }

        /* ── Body: angka kiri + sparkline kanan ── */
        .sc-body {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 8px;
        }

        .sc-left {
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        /* ── Angka ── */
        .sc-num {
            font-size: 30px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -1.2px;
            line-height: 1;
            transition: color .15s;
        }

        @media (max-width: 1400px) {
            .sc-num {
                font-size: 26px;
            }
        }

        /* ── Meta: trend pill + sub-text ── */
        .sc-meta {
            display: flex;
            flex-direction: column;
            gap: 3px;
            margin-top: 6px;
        }

        .sc-pill {
            display: inline-flex;
            align-items: center;
            gap: 2px;
            padding: 1px 6px;
            border-radius: 100px;
            font-size: 10.5px;
            font-weight: 700;
            white-space: nowrap;
            flex-shrink: 0;
            transition: all .15s;
        }

        .sc-pill svg {
            width: 7px;
            height: 7px;
            flex-shrink: 0;
        }

        .sc-pill-up {
            background: #dcfce7;
            color: #16a34a;
        }

        .sc-pill-down {
            background: #fee2e2;
            color: #dc2626;
        }

        .sc-pill-neu {
            background: #f1f5f9;
            color: #64748b;
        }

        .sc-sub {
            font-size: 11px;
            color: #94a3b8;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            transition: color .15s;
        }

        /* ── Sparkline (kanan, sejajar angka) ── */
        .sc-spark {
            flex-shrink: 0;
            width: 72px;
            height: 36px;
        }

        .sc-spark svg {
            width: 72px;
            height: 36px;
        }

        .sc-spark-fill {
            transition: fill .2s;
        }

        .sc-spark-line {
            stroke-width: 1.8;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
            transition: stroke .2s;
        }

        .sc-spark-dot {
            transition: fill .2s;
        }

        @keyframes tcPulse {

            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: .4;
                transform: scale(1.4);
            }
        }

        #traffic-chart-panel select:focus {
            outline: none;
            border-color: #1e78ff;
        }

        #tc-iface-select:focus {
            border-color: #2563eb !important;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, .12) !important;
        }

        @media(max-width:640px) {
            #traffic-chart-panel .gf-panel-header {
                flex-wrap: wrap;
                gap: 6px;
            }

            #traffic-chart-panel .gf-panel-stats {
                flex-wrap: wrap;
                gap: 6px;
            }
        }

        /* Grafana-style panels (borrowed from device-monitor) */
        .gf-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .gf-toolbar-title {
            font-size: 11px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: .07em;
        }

        .gf-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 6px;
            margin-bottom: 14px;
        }

        @media(max-width:1100px) {
            .gf-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media(max-width:650px) {
            .gf-grid {
                grid-template-columns: 1fr;
            }
        }

        .gf-panel {
            background: #fff;
            border: 1px solid #e8eaed;
            border-radius: 4px;
            overflow: hidden;
            transition: border-color .15s;
        }

        .gf-panel:hover {
            border-color: #1e78ff;
        }

        .gf-panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 7px 12px 5px;
            border-bottom: 1px solid #f0f4f8;
        }

        .gf-panel-title {
            font-size: 11px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: .06em;
        }

        .gf-panel-stats {
            display: flex;
            gap: 10px;
        }

        .gf-stat {
            display: flex;
            align-items: baseline;
            gap: 3px;
        }

        .gf-stat-lbl {
            font-size: 9px;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
        }

        .gf-stat-val {
            font-size: 11px;
            font-weight: 700;
            font-family: 'Geist Mono', monospace;
            color: #0f172a;
        }

        .gf-chart-area {
            height: 140px;
        }

        /* Legacy compat */
        .stat-card-top,
        .stat-icon,
        .stat-sparkline {
            all: unset;
            display: none;
        }

        .spark-bar-wrap,
        .spark-bar,
        .sc-bars,
        .sc-bar {
            display: none;
        }

        .sc-icon-wrap,
        .sc-divider,
        .sc-sep,
        .sc-top {
            display: none;
        }

        .sc-r1,
        .sc-r2,
        .sc-r3,
        .sc-icon-box {
            display: none;
        }

        .sc-mid {
            display: contents;
        }

        .sc-mid-left {
            display: contents;
        }



        /* ══ GENERATE PANEL ════════════════════════════════════════ */
        .gen-panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--rc-lg);
            padding: 24px;
            margin-bottom: 24px;
            position: relative;
            overflow: hidden;
        }

        .gen-panel::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(0, 113, 227, .04) 0%, rgba(52, 170, 220, .04) 100%);
            pointer-events: none;
        }

        .gen-panel-hdr {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .gen-panel-hdr-l {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .gen-title-ico {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, #0071e3, #34aadc);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .gen-title-ico svg {
            width: 20px;
            height: 20px;
            stroke: #fff;
            fill: none;
        }

        .gen-panel-hdr-l h2 {
            font-size: 16px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: -.2px;
        }

        .gen-panel-hdr-l p {
            font-size: 12.5px;
            color: var(--text2);
            margin-top: 1px;
        }

        .gen-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 12px;
            align-items: end;
            margin-bottom: 12px;
        }

        @media (max-width: 1000px) {
            .gen-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @media (max-width: 650px) {
            .gen-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 420px) {
            .gen-grid {
                grid-template-columns: 1fr;
            }
        }

        .gen-field label {
            display: block;
            font-size: 11.5px;
            font-weight: 600;
            color: var(--text2);
            margin-bottom: 6px;
            letter-spacing: .1px;
        }

        .gen-field input,
        .gen-field select {
            width: 100%;
            padding: 9px 12px;
            border: 1px solid var(--border);
            border-radius: var(--rc-sm);
            font-size: 13px;
            color: var(--text);
            font-family: var(--f);
            background: var(--surface2);
            outline: none;
            transition: border-color .15s, box-shadow .15s;
        }

        .gen-field input:focus,
        .gen-field select:focus {
            border-color: var(--blue);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(0, 113, 227, .1);
        }

        .gen-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn-generate {
            background: var(--blue);
            color: #fff;
            border: none;
            padding: 10px 24px;
            border-radius: var(--rc-sm);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            font-family: var(--f);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: background .15s, transform .1s;
            white-space: nowrap;
        }

        .btn-generate:hover {
            background: #0077ed;
        }

        .btn-generate:active {
            transform: scale(.98);
        }

        .btn-generate:disabled {
            opacity: .5;
            cursor: not-allowed;
        }

        .btn-print-last {
            background: transparent;
            color: var(--text2);
            border: 1px solid var(--border);
            padding: 9px 14px;
            border-radius: var(--rc-sm);
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            font-family: var(--f);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all .15s;
            white-space: nowrap;
        }

        .btn-print-last:hover {
            background: var(--surface2);
            color: var(--text);
            border-color: var(--blue);
        }

        .btn-generate svg,
        .btn-print-last svg {
            width: 14px;
            height: 14px;
            flex-shrink: 0;
            stroke: currentColor;
            fill: none;
        }

        /* ── Print dropdown ── */
        .print-dropdown {
            position: relative;
            display: inline-flex;
        }

        .print-menu {
            position: fixed;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--rc);
            box-shadow: 0 8px 32px rgba(0, 0, 0, .14);
            z-index: 9998;
            width: 260px;
            overflow: hidden;
            animation: fadeIn .12s ease;
        }

        .print-menu-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .6px;
            color: var(--text3);
            padding: 8px 12px 4px;
        }

        .print-menu-item {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            padding: 8px 12px;
            font-size: 13px;
            font-weight: 500;
            color: var(--text);
            background: transparent;
            border: none;
            cursor: pointer;
            font-family: var(--f);
            text-align: left;
            transition: background .1s;
        }

        .print-menu-item:hover {
            background: var(--surface2);
        }

        .print-menu-item svg {
            width: 14px;
            height: 14px;
            stroke: currentColor;
            fill: none;
            flex-shrink: 0;
            color: var(--text2);
        }

        .print-menu-sep {
            height: 1px;
            background: var(--border2);
            margin: 4px 0;
        }

        .pm-badge {
            margin-left: auto;
            font-size: 11px;
            font-weight: 700;
            background: var(--border2);
            color: var(--text2);
            padding: 1px 7px;
            border-radius: 20px;
            flex-shrink: 0;
        }

        .pm-badge-green {
            background: var(--green-l);
            color: var(--green);
        }

        .pm-badge-red {
            background: var(--red-l);
            color: var(--red);
        }

        .pm-badge-amber {
            background: var(--amber-l);
            color: var(--amber);
        }

        .pm-badge-blue {
            background: var(--blue-l);
            color: var(--blue);
        }

        /* ══ TABS ══════════════════════════════════════════════════ */
        .tab-wrap {
            margin-bottom: 16px;
        }

        .tab-list {
            display: flex;
            gap: 2px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--rc);
            padding: 4px;
            width: fit-content;
            overflow-x: auto;
            max-width: 100%;
        }

        .tab-list::-webkit-scrollbar {
            display: none;
        }

        .tab-item {
            padding: 7px 16px;
            border-radius: var(--rc-sm);
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            border: none;
            background: transparent;
            color: var(--text2);
            transition: all .15s;
            white-space: nowrap;
            font-family: var(--f);
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .tab-item .tab-badge {
            min-width: 18px;
            height: 18px;
            border-radius: 9px;
            padding: 0 5px;
            font-size: 10px;
            font-weight: 700;
            background: var(--border);
            color: var(--text2);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .tab-item.active {
            background: var(--blue);
            color: #fff;
            box-shadow: 0 1px 4px rgba(0, 113, 227, .3);
        }

        .tab-item.active .tab-badge {
            background: rgba(255, 255, 255, .25);
            color: #fff;
        }

        .tab-panel {
            display: none;
        }

        .tab-panel.active {
            display: block;
            animation: fadeIn .15s ease;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
