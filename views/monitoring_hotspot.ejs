    <style>
        /* ── Bottom Nav ─────────────────────────────────────────────── */
        .bottom-nav {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 64px;
            background: #fff;
            border-top: 1px solid #e2e8f0;
            box-shadow: 0 -4px 20px rgba(0, 0, 0, .08);
            z-index: 500;
            align-items: center;
            justify-content: space-around;
            padding: 0 4px;
            padding-bottom: env(safe-area-inset-bottom);
        }

        @media (max-width: 768px) {
            .bottom-nav {
                display: flex;
            }

            .main-content {
                padding-bottom: 72px;
            }
        }

        .bn-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 3px;
            flex: 1;
            height: 100%;
            color: #94a3b8;
            text-decoration: none;
            font-size: 10px;
            font-weight: 600;
            background: none;
            border: none;
            cursor: pointer;
            transition: color .15s;
            font-family: inherit;
            padding: 8px 0;
            position: relative;
        }

        .bn-item.active,
        .bn-item:hover {
            color: #1e78ff;
        }

        .bn-item.active .bn-icon svg {
            stroke: #1e78ff;
        }

        .bn-item.active::after {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 32px;
            height: 3px;
            background: #1e78ff;
            border-radius: 0 0 4px 4px;
        }

        .bn-icon {
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .bn-icon svg {
            width: 22px;
            height: 22px;
            stroke: #94a3b8;
            transition: stroke .15s;
        }

        .bn-item.active .bn-icon svg,
        .bn-item:hover .bn-icon svg {
            stroke: #1e78ff;
        }

        .bn-more .bn-icon svg {
            stroke: #94a3b8;
        }

        .bn-more:hover .bn-icon svg,
        .bn-more.active .bn-icon svg {
            stroke: #1e78ff;
        }

        /* ── FAB ────────────────────────────────────────────────────── */
        .bn-fab {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            background: #1e78ff;
            border: none;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 4px 16px rgba(30, 120, 255, .45);
            transition: all .2s;
            flex-shrink: 0;
            margin-bottom: 8px;
        }

        .bn-fab:hover {
            background: #0052cc;
            transform: scale(1.05);
        }

        .bn-fab.open {
            background: #ef4444;
            border-radius: 50%;
            transform: rotate(45deg);
        }

        /* ── FAB Quick Menu ─────────────────────────────────────────── */
        .bn-menu-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .35);
            z-index: 499;
            backdrop-filter: blur(2px);
        }

        .bn-menu-overlay.show {
            display: block;
        }

        .bn-menu {
            display: none;
            position: fixed;
            bottom: 76px;
            left: 12px;
            right: 12px;
            background: #fff;
            border-radius: 20px;
            padding: 20px 16px 16px;
            z-index: 600;
            box-shadow: 0 -4px 40px rgba(0, 0, 0, .15);
            animation: bnMenuUp .25s cubic-bezier(.34, 1.56, .64, 1);
        }

        .bn-menu.show {
            display: block;
        }

        @keyframes bnMenuUp {
            from {
                opacity: 0;
                transform: translateY(20px) scale(.96);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .bn-menu-title {
            font-size: 11px;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: .07em;
            margin-bottom: 14px;
        }

        .bn-menu-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            max-height: 60vh;
            overflow-y: auto;
        }

        .bn-menu-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 7px;
            text-decoration: none;
            color: #374151;
            font-size: 11px;
            font-weight: 600;
            padding: 12px 8px;
            border-radius: 14px;
            background: #f8fafc;
            transition: all .15s;
            border: 1.5px solid transparent;
        }

        .bn-menu-item:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
        }

        .bn-mi-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>

    <script>
        // ── Bottom Nav active state ──────────────────────────────────
        (function () {
            const path = window.location.pathname;
            document.querySelectorAll('.bn-item[data-page]').forEach(el => {
                const page = el.dataset.page;
                const match =
                    (page === 'dashboard' && path === '/dashboard') ||
                    (page === 'customers' && path.startsWith('/customers')) ||
                    (page === 'billing' && path.startsWith('/billing'));
                if (match) el.classList.add('active');
            });

            // Highlight active quick action
            document.querySelectorAll('.bn-menu-item').forEach(el => {
                const href = el.getAttribute('href');
                if (href && path.startsWith(href)) {
                    el.style.background = '#eff6ff';
                    el.style.borderColor = '#bfdbfe';
                    el.style.color = '#1e78ff';
                }
            });
        })();

        // ── FAB Menu toggle ──────────────────────────────────────────
        function toggleBnMenu() {
            const menu = document.getElementById('bnMenu');
            const overlay = document.getElementById('bnMenuOverlay');
            const fab = document.getElementById('bnFab');
            const isOpen = menu.classList.contains('show');
            menu.classList.toggle('show', !isOpen);
            overlay.classList.toggle('show', !isOpen);
            fab.classList.toggle('open', !isOpen);
        }

        // ── Toggle sidebar dari bottom nav ──────────────────────────
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            if (sidebar) sidebar.classList.toggle('open');
        }
    </script>

