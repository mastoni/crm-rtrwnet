<%- include('layouts/header') %>

    <style>
        :root {
            --pm-blue: #2563eb;
            --pm-blue-d: #1d4ed8;
            --pm-blue-l: #eff6ff;
            --pm-green: #16a34a;
            --pm-green-d: #15803d;
            --pm-green-l: #f0fdf4;
            --pm-red: #dc2626;
            --pm-red-d: #b91c1c;
            --pm-red-l: #fef2f2;
            --pm-amber: #d97706;
            --pm-amber-d: #b45309;
            --pm-amber-l: #fffbeb;
            --pm-teal: #0891b2;
            --pm-teal-l: #ecfeff;
            --border: #e2e8f0;
            --text: #0f172a;
            --muted: #64748b;
            --faint: #94a3b8;
            --rc: 16px;
        }

        .pm {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        /* ── HEADER ── */
        .pm-hdr {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 24px;
        }

        .pm-hdr-l h1 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 4px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .pm-hdr-l p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

        .pm-hdr-r {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            align-items: center;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 9px 16px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid;
            transition: all .15s;
            white-space: nowrap;
            font-family: inherit;
        }

        .btn svg {
            flex-shrink: 0;
        }

        .btn-outline {
            background: #fff;
            border-color: var(--border);
            color: #374151;
        }

        .btn-outline:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

        .btn-blue {
            background: var(--pm-blue);
            border-color: var(--pm-blue);
            color: #fff;
        }

        .btn-blue:hover {
            background: var(--pm-blue-d);
        }

        .btn-green {
            background: var(--pm-green);
            border-color: var(--pm-green);
            color: #fff;
        }

        .btn-green:hover {
            background: var(--pm-green-d);
        }

        .btn-teal {
            background: var(--pm-teal);
            border-color: var(--pm-teal);
            color: #fff;
        }

        .btn-teal:hover {
            background: #0e7490;
        }

        .btn-sm {
            padding: 6px 12px;
            font-size: 12px;
            border-radius: 8px;
        }

        .btn:disabled {
            opacity: .5;
            cursor: not-allowed;
            pointer-events: none;
        }

        /* Live chip */
        .live-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
        }

        .chip-idle {
            background: #f1f5f9;
            border: 1px solid var(--border);
            color: var(--muted);
        }

        .chip-scanning {
            background: var(--pm-blue-l);
            border: 1px solid #bfdbfe;
            color: var(--pm-blue);
        }

        .chip-live {
            background: var(--pm-green-l);
            border: 1px solid #bbf7d0;
            color: var(--pm-green);
        }

        .live-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .chip-idle .live-dot {
            background: var(--faint);
        }

        .chip-scanning .live-dot {
            background: var(--pm-blue);
            animation: pulse .8s ease-in-out infinite;
        }

        .chip-live .live-dot {
            background: var(--pm-green);
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
                transform: scale(1)
            }

            50% {
                opacity: .35;
                transform: scale(.75)
            }
        }

        /* ── STAT CARDS ── */
        /* ── STAT CARDS — single strip with dividers ── */
        .pm-cards {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            background: #fff;
            border-radius: 16px;
            border: 1px solid #e8eaed;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .pm-card {
            padding: 20px 22px 18px;
            border-right: 1px solid #e8eaed;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            gap: 0;
            position: relative;
            overflow: hidden;
            transition: background .15s;
        }

        .pm-card:last-child {
            border-right: none;
        }

        .pm-card:hover {
            background: #fafbff;
        }

        /* Active — biru solid */
        .pm-card.pmc-active {
            background: #2563eb;
            border-color: #2563eb;
        }

        .pm-card.pmc-active:hover {
            background: #1d4ed8;
        }

        .pm-card.pmc-active .card-lbl {
            color: rgba(255, 255, 255, .70);
        }

        .pm-card.pmc-active .card-val {
            color: #fff;
        }

        .pm-card.pmc-active .card-sub {
            color: rgba(255, 255, 255, .60);
        }

        .pm-card.pmc-active .card-pill {
            background: rgba(255, 255, 255, .20) !important;
            color: rgba(255, 255, 255, .90) !important;
        }

        .pm-card.pmc-active .sp-line {
            stroke: rgba(255, 255, 255, .70) !important;
        }

        .pm-card.pmc-active .sp-fill {
            fill: rgba(255, 255, 255, .12) !important;
        }

        .pm-card.pmc-active .sp-dot {
            fill: #fff !important;
        }

        /* label */
        .card-lbl {
            font-size: 12px;
            font-weight: 500;
            color: #64748b;
            margin-bottom: 10px;
            letter-spacing: .1px;
            transition: color .15s;
        }

        /* body */
        .card-body {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 8px;
        }

        .card-left {
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        /* angka */
        .card-val {
            font-size: 30px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -1.2px;
            line-height: 1;
            transition: color .15s;
        }

        @media(max-width:1400px) {
            .card-val {
                font-size: 26px;
            }
        }

        /* meta */
        .card-meta {
            display: flex;
            align-items: center;
            gap: 5px;
            margin-top: 6px;
            flex-wrap: wrap;
        }

        .card-pill {
            display: inline-flex;
            align-items: center;
            gap: 2px;
            padding: 1px 6px;
            border-radius: 100px;
            font-size: 10.5px;
            font-weight: 700;
            white-space: nowrap;
            flex-shrink: 0;
            transition: all .15s;
        }

        .pill-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .pill-green {
            background: #dcfce7;
            color: #16a34a;
        }

        .pill-red {
            background: #fee2e2;
            color: #dc2626;
        }

        .pill-amber {
            background: #fef3c7;
            color: #b45309;
        }

        .card-sub {
            font-size: 11px;
            color: #94a3b8;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            transition: color .15s;
        }

        /* sparkline */
        .card-spark {
            flex-shrink: 0;
            width: 72px;
            height: 36px;
        }

        .card-spark svg {
            width: 72px;
            height: 36px;
        }

        .sp-fill {
            transition: fill .3s;
        }

        .sp-line {
            stroke-width: 1.8;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .sp-dot {}

        /* responsive */
        @media(max-width:700px) {
            .pm-card {
                border-right: none;
                border-bottom: 1px solid #e8eaed;
            }

            .pm-card:nth-child(odd) {
                border-right: 1px solid #e8eaed;
            }

            .pm-card:nth-child(even) {
                border-right: none;
            }

            .pm-card:nth-last-child(-n+2) {
                border-bottom: none;
            }
        }

        @media(max-width:400px) {
            .pm-cards {
                grid-template-columns: 1fr;
            }

            .pm-card {
                border-right: none !important;
                border-bottom: 1px solid #e8eaed;
            }

            .pm-card:last-child {
                border-bottom: none;
            }
        }

        .prog-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--pm-blue), #38bdf8);
            border-radius: 4px;
            transition: width .3s ease;
        }

        .prog-text {
            font-size: 12px;
            font-weight: 600;
            color: #374151;
            white-space: nowrap;
        }

        .prog-pct {
            font-size: 12px;
            font-weight: 800;
            color: var(--pm-blue);
            min-width: 36px;
            text-align: right;
        }

        /* ── CONTROLS ── */
        .pm-ctrl {
            background: #fff;
            border: 1.5px solid var(--border);
            border-radius: var(--rc);
            padding: 14px 20px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .search-wrap {
            position: relative;
            flex: 1;
            min-width: 200px;
            max-width: 300px;
        }

        .search-wrap svg {
            position: absolute;
            left: 11px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--faint);
            pointer-events: none;
            width: 15px;
            height: 15px;
        }

        .search-wrap input {
            width: 100%;
            padding: 9px 12px 9px 34px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-size: 13px;
            outline: none;
            box-sizing: border-box;
            background: #f8fafc;
            font-family: inherit;
            transition: all .15s;
        }

        .search-wrap input:focus {
            border-color: var(--pm-blue);
            background: #fff;
            box-shadow: 0 0 0 3px #2563eb15;
        }

        .pm-ctrl select {
            padding: 9px 12px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-size: 13px;
            outline: none;
            background: #f8fafc;
            color: #374151;
            cursor: pointer;
            font-family: inherit;
        }

        .pm-ctrl select:focus {
            border-color: var(--pm-blue);
        }

        .ctrl-r {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .cnt-info {
            font-size: 12px;
            color: var(--muted);
            font-weight: 600;
        }

        .interval-wrap {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--muted);
        }

        .interval-wrap select {
            padding: 5px 9px;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: 12px;
            font-family: inherit;
            background: #f8fafc;
            outline: none;
        }

        /* ── TABLE ── */
        .pm-tbl-wrap {
            background: #fff;
            border: 1.5px solid var(--border);
            border-radius: var(--rc);
            overflow: hidden;
        }

        .pm-tbl-hdr {
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 8px;
            border-bottom: 1px solid #f1f5f9;
            flex-wrap: wrap;
        }

        .pm-tbl-hdr-t {
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
        }

        .pm-tbl-note {
            font-size: 11px;
            color: var(--faint);
            margin-left: auto;
        }

        .pm-table {
            width: 100%;
            border-collapse: collapse;
        }

        .pm-table thead tr {
            background: #f8fafc;
        }

        .pm-table th {
            padding: 10px 16px;
            font-size: 10.5px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .7px;
            text-align: left;
            border-bottom: 1px solid #f1f5f9;
            white-space: nowrap;
        }

        .pm-table tbody tr {
            border-bottom: 1px solid #f8fafc;
            transition: background .1s;
        }

        .pm-table tbody tr:hover {
            background: #f8fafc;
        }

        .pm-table tbody tr:last-child {
            border-bottom: none;
        }

        .pm-table td {
            padding: 12px 16px;
            font-size: 13px;
            color: #374151;
            vertical-align: middle;
        }

        /* Cells */
        .cust-name {
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
            line-height: 1.3;
        }

        .cust-meta {
            font-size: 11px;
            color: var(--faint);
            margin-top: 2px;
        }

        .ip-badge {
            font-family: monospace;
            font-size: 12px;
            font-weight: 700;
            background: #f1f5f9;
            color: #334155;
            padding: 4px 9px;
            border-radius: 6px;
            display: inline-block;
        }

        /* Status pills */
        .pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11.5px;
            font-weight: 700;
            white-space: nowrap;
        }

        .sdot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .pill-up {
            background: var(--pm-green-l);
            color: #15803d;
            border: 1px solid #bbf7d0;
        }

        .pill-up .sdot {
            background: #22c55e;
            animation: pingRing 2s ease-in-out infinite;
        }

        .pill-down {
            background: var(--pm-red-l);
            color: #b91c1c;
            border: 1px solid #fecaca;
        }

        .pill-down .sdot {
            background: #ef4444;
        }

        .pill-unknown {
            background: #f8fafc;
            color: var(--muted);
            border: 1px solid var(--border);
        }

        .pill-unknown .sdot {
            background: var(--faint);
        }

        .pill-checking {
            background: var(--pm-blue-l);
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
        }

        .pill-checking .sdot {
            background: var(--pm-blue);
            animation: pulse .8s ease-in-out infinite;
        }

        @keyframes pingRing {

            0%,
            100% {
                box-shadow: 0 0 0 0 rgba(34, 197, 94, .4)
            }

            50% {
                box-shadow: 0 0 0 4px rgba(34, 197, 94, 0)
            }
        }

        /* Latency */
        .lat {
            font-size: 12px;
            font-weight: 700;
            padding: 3px 8px;
            border-radius: 6px;
            font-family: monospace;
        }

        .lat-good {
            background: #dcfce7;
            color: #15803d;
        }

        .lat-ok {
            background: #fef9c3;
            color: #854d0e;
        }

        .lat-bad {
            background: #fee2e2;
            color: #b91c1c;
        }

        .lat-na {
            background: #f1f5f9;
            color: var(--faint);
        }

        /* Loss bar */
        .loss-wrap {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .loss-bar {
            flex: 1;
            min-width: 60px;
            max-width: 80px;
            height: 5px;
            background: #f1f5f9;
            border-radius: 3px;
            overflow: hidden;
        }

        .loss-fill {
            height: 100%;
            border-radius: 3px;
            transition: width .5s;
        }

        .loss-0 .loss-fill {
            background: #22c55e;
        }

        .loss-lo .loss-fill {
            background: #f59e0b;
        }

        .loss-hi .loss-fill {
            background: #ef4444;
        }

        .loss-pct {
            font-size: 11.5px;
            font-weight: 700;
            min-width: 28px;
        }

        /* Action btn */
        .act-btn {
            padding: 5px 10px;
            border-radius: 7px;
            font-size: 11.5px;
            font-weight: 600;
            background: var(--pm-blue-l);
            color: var(--pm-blue);
            border: 1px solid #bfdbfe;
            cursor: pointer;
            font-family: inherit;
            transition: all .15s;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            white-space: nowrap;
        }

        .act-btn:hover {
            background: var(--pm-blue);
            color: #fff;
            border-color: var(--pm-blue);
        }

        .act-btn:disabled {
            opacity: .5;
            cursor: not-allowed;
        }

        .act-btn svg {
            width: 12px;
            height: 12px;
        }

        /* ── ASSIGN IP MODAL ── */
        .overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, .5);
            z-index: 400;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }

        .overlay.open {
            display: flex;
        }

        .modal {
            background: #fff;
            border-radius: 16px;
            width: 100%;
            max-width: 700px;
            max-height: 90vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 20px 60px rgba(0, 0, 0, .25);
        }

        .modal-hdr {
            padding: 20px 24px 16px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .modal-hdr h2 {
            font-size: 17px;
            font-weight: 800;
            color: var(--text);
        }

        .modal-close {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: #f1f5f9;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
            font-size: 16px;
            font-family: inherit;
        }

        .modal-close:hover {
            background: #e2e8f0;
        }

        .modal-body {
            flex: 1;
            overflow-y: auto;
            padding: 16px 24px;
        }

        .modal-note {
            font-size: 12.5px;
            color: var(--muted);
            margin-bottom: 14px;
            background: #f8fafc;
            border-radius: 8px;
            padding: 10px 14px;
            border-left: 3px solid #bfdbfe;
        }

        .assign-search {
            margin-bottom: 12px;
        }

        .assign-search input {
            width: 100%;
            padding: 10px 14px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-size: 13px;
            outline: none;
            font-family: inherit;
            box-sizing: border-box;
        }

        .assign-search input:focus {
            border-color: var(--pm-blue);
            box-shadow: 0 0 0 3px #2563eb15;
        }

        .assign-list {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .assign-row {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #f8fafc;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            padding: 10px 14px;
            transition: all .1s;
        }

        .assign-row:hover {
            border-color: #bfdbfe;
            background: var(--pm-blue-l);
        }

        .assign-row.has-ip {
            border-color: #bbf7d0;
            background: var(--pm-green-l);
        }

        .ar-info {
            flex: 1;
            min-width: 0;
        }

        .ar-name {
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
        }

        .ar-meta {
            font-size: 11px;
            color: var(--faint);
        }

        .ar-ip-input {
            width: 145px;
            padding: 7px 10px;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: 12.5px;
            font-family: monospace;
            outline: none;
            background: #fff;
        }

        .ar-ip-input:focus {
            border-color: var(--pm-blue);
        }

        .ar-save {
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            background: var(--pm-blue);
            color: #fff;
            border: none;
            cursor: pointer;
            font-family: inherit;
        }

        .ar-save:hover {
            background: var(--pm-blue-d);
        }

        /* Empty & skeleton */
        .pm-empty {
            text-align: center;
            padding: 56px 20px;
            color: var(--faint);
        }

        .pm-empty svg {
            width: 44px;
            height: 44px;
            margin-bottom: 12px;
            stroke: #cbd5e1;
        }

        .pm-empty strong {
            display: block;
            font-size: 14px;
            color: var(--muted);
            margin-bottom: 6px;
        }

        .pm-empty p {
            font-size: 13px;
        }

        .skeleton {
            background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
            background-size: 200% 100%;
            animation: shimmer 1.4s infinite;
            border-radius: 6px;
            display: block;
        }

        @keyframes shimmer {
            0% {
                background-position: 200% 0
            }

            100% {
                background-position: -200% 0
            }
        }

        /* Toast */
        .toast-wrap {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 8px;
            pointer-events: none;
        }

        .toast-item {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 13px;
            font-weight: 600;
            box-shadow: 0 4px 20px rgba(0, 0, 0, .13);
            display: flex;
            align-items: center;
            gap: 8px;
