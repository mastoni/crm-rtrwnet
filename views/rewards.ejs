<%- include('layouts/header') %>

<main class="page-content">
    <div class="page-header">
        <div class="page-header-left">
            <h1>Manajemen Reward Points</h1>
        </div>
        <div class="page-header-right">
            <button class="btn btn-primary" onclick="openAddItemModal()">+ Tambah Item</button>
            <button class="btn btn-success" onclick="openAdjustPointsModal()">Penyesuaian Manual</button>
        </div>
    </div>

    <!-- Items List -->
    <div class="card" style="margin-bottom: 24px;">
        <div class="card-header">
            <h3>Katalog Item Reward</h3>
        </div>
        <div class="card-body">
            <div class="grid-items" id="rewardItemsGrid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px;">
                <div class="loading-state">Memuat item...</div>
            </div>
        </div>
    </div>

    <!-- Histori Reward -->
    <div class="card">
        <div class="card-header">
            <h3>Histori Penukaran & Poin (Global)</h3>
        </div>
        <div class="card-body">
            <div class="form-group" style="max-width: 300px; margin-bottom: 16px;">
                <label class="form-label">Pilih Pelanggan (Cari ID):</label>
                <input type="number" class="form-control" id="historyCustomerId" placeholder="ID Pelanggan" onchange="loadHistory()">
            </div>
            <div style="overflow-x: auto;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Tanggal</th>
                            <th>Tipe</th>
                            <th>Deskripsi</th>
                            <th>Poin</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="historyTableBody">
                        <tr><td colspan="5" class="loading-state">Masukkan ID pelanggan untuk melihat histori...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<!-- Modal Add Item -->
<div class="modal-overlay" id="addItemModal">
    <div class="modal">
        <div class="modal-header">
            <h2>Tambah Item Reward</h2>
            <button class="modal-close" onclick="closeModals()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label">Nama Item</label>
                <input type="text" class="form-control" id="itemName">
            </div>
            <div class="form-group">
                <label class="form-label">Deskripsi</label>
                <textarea class="form-control" id="itemDesc" rows="3"></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Poin Dibutuhkan</label>
                <input type="number" class="form-control" id="itemPoints">
            </div>
            <div class="form-group">
                <label class="form-label">Stok</label>
                <input type="number" class="form-control" id="itemStock">
            </div>
            <div class="form-group">
                <label class="form-label">URL Gambar</label>
                <input type="text" class="form-control" id="itemImage" placeholder="https://...">
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModals()">Batal</button>
            <button class="btn btn-primary" onclick="submitItem()">Simpan</button>
        </div>
    </div>
</div>

<!-- Modal Adjust Points -->
<div class="modal-overlay" id="adjustPointsModal">
    <div class="modal">
        <div class="modal-header">
            <h2>Penyesuaian Poin Manual</h2>
            <button class="modal-close" onclick="closeModals()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label">ID Pelanggan</label>
                <input type="number" class="form-control" id="adjCustomerId">
            </div>
            <div class="form-group">
                <label class="form-label">Jumlah Poin (Gunakan minus untuk mengurangi)</label>
                <input type="number" class="form-control" id="adjPoints">
            </div>
            <div class="form-group">
                <label class="form-label">Deskripsi/Alasan</label>
                <textarea class="form-control" id="adjDesc" rows="3"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModals()">Batal</button>
            <button class="btn btn-primary" onclick="submitAdjust()">Simpan</button>
        </div>
    </div>
</div>

<%- include('layouts/footer') %>
