<%- include('layouts/header') %>

    <style>
        * {
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #f8fafc;
            --bg-secondary: #ffffff;
            --bg-tertiary: #f1f5f9;
            --border-light: #e2e8f0;
            --border-medium: #cbd5e1;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            --accent-blue: #3b82f6;
            --accent-blue-light: #dbeafe;
            --accent-green: #10b981;
            --accent-green-light: #d1fae5;
            --accent-orange: #f59e0b;
            --accent-orange-light: #fef3c7;
            --accent-red: #ef4444;
            --accent-red-light: #fee2e2;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
            --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1);
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        .resources-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 24px 24px;
        }

        /* Page Header */
        .page-header-modern {
            margin-bottom: 32px;
            padding-bottom: 24px;
            border-bottom: 1px solid var(--border-light);
        }

        .page-title-group {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 8px;
        }

        .page-title-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-md);
        }

        .page-title-modern {
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -0.02em;
            margin: 0;
            background: linear-gradient(135deg, #0f172a 0%, #334155 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .page-subtitle {
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: 500;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .refresh-indicator {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            color: var(--text-muted);
            background: var(--bg-tertiary);
            padding: 4px 12px;
            border-radius: 20px;
            margin-left: 12px;
        }

        .refresh-indicator svg {
            width: 14px;
            height: 14px;
        }

        /* Grid Layout */
        .resources-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
            gap: 24px;
            margin-bottom: 24px;
        }

        @media (max-width: 1100px) {
            .resources-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Modern Card */
        .resource-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border-light);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .resource-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
        }

        /* Card Header */
        .card-header-modern {
            padding: 24px;
            background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-title-group {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .card-icon-wrapper {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .card-icon-wrapper::before {
            content: '';
            position: absolute;
            inset: 0;
            background: inherit;
            opacity: 0.1;
        }

        .card-icon-wrapper.router {
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        }

        .card-icon-wrapper.server {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        }

        .card-icon-wrapper svg {
            width: 24px;
            height: 24px;
            position: relative;
            z-index: 1;
        }

        .card-title-modern {
            margin: 0;
            font-size: 18px;
            font-weight: 700;
            letter-spacing: -0.01em;
        }

        .card-subtitle {
            margin: 2px 0 0;
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* Status Badge */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.02em;
            text-transform: uppercase;
        }

        .status-badge.online {
            background: var(--accent-green-light);
            color: #065f46;
        }

        .status-badge.offline {
            background: var(--accent-red-light);
            color: #991b1b;
        }

        .status-badge.loading {
            background: var(--accent-orange-light);
            color: #92400e;
        }

        .status-badge svg {
            width: 12px;
            height: 12px;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: 0.5;
            }
        }

        /* Card Body */
        .card-body-modern {
            padding: 24px;
        }

        /* Info Grid */
        .info-grid {
            display: grid;
            gap: 12px;
            margin-bottom: 24px;
        }

        .info-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
            background: var(--bg-tertiary);
            border-radius: 12px;
            transition: all 0.2s;
        }

        .info-row:hover {
            background: #e8eef5;
            transform: translateX(2px);
        }

        .info-label-group {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .info-icon {
            width: 20px;
            height: 20px;
            color: var(--text-muted);
        }

        .info-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-secondary);
            letter-spacing: 0.01em;
        }

        .info-value {
            font-size: 14px;
            font-weight: 700;
            color: var(--text-primary);
            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;
        }

        /* Progress Section */
        .progress-section {
            display: grid;
            gap: 16px;
        }

        .progress-card {
            padding: 18px;
            background: var(--bg-tertiary);
            border-radius: 14px;
            border: 1px solid var(--border-light);
        }

        .progress-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 12px;
        }

        .progress-label-group {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .progress-icon-small {
            width: 18px;
            height: 18px;
            color: var(--text-secondary);
        }

        .progress-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-secondary);
        }

        .progress-value-group {
            display: flex;
            align-items: baseline;
            gap: 6px;
        }

        .progress-percent {
            font-size: 18px;
            font-weight: 800;
            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;
            letter-spacing: -0.02em;
        }

        .progress-detail {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* Progress Bar */
        .progress-bar-container {
            height: 10px;
            background: #e2e8f0;
            border-radius: 99px;
            overflow: hidden;
            position: relative;
        }

        .progress-bar-fill {
            height: 100%;
            border-radius: 99px;
            transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .progress-bar-fill::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            animation: shimmer 2s infinite;
        }

        @keyframes shimmer {
            0% {
                transform: translateX(-100%);
            }

            100% {
                transform: translateX(100%);
            }
        }

        .progress-bar-fill.low {
            background: linear-gradient(90deg, #10b981 0%, #059669 100%);
        }

        .progress-bar-fill.medium {
            background: linear-gradient(90deg, #f59e0b 0%, #d97706 100%);
        }

        .progress-bar-fill.high {
            background: linear-gradient(90deg, #ef4444 0%, #dc2626 100%);
        }

        /* Error State */
        .error-state {
            text-align: center;
            padding: 60px 20px;
        }

        .error-icon-wrapper {
            width: 80px;
            height: 80px;
            margin: 0 auto 20px;
            background: var(--accent-red-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .error-icon-wrapper svg {
            width: 40px;
            height: 40px;
            color: var(--accent-red);
        }

        .error-title {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0 0 8px;
        }

        .error-message {
            font-size: 14px;
            color: var(--text-secondary);
            margin: 0;
        }

        /* Loading State */
        .loading-state {
            text-align: center;
            padding: 60px 20px;
        }

        .loading-spinner {
            width: 40px;
            height: 40px;
            margin: 0 auto 20px;
            border: 4px solid var(--border-light);
            border-top-color: var(--accent-blue);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .loading-text {
            font-size: 14px;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* Utility */
        .text-green {
            color: #059669;
        }

        .text-orange {
            color: #d97706;
        }

        .text-red {
            color: #dc2626;
        }
    </style>

    <main class="page-content">
        <div class="resources-container">

            <!-- Page Header -->
            <div class="page-header-modern">
                <div class="page-title-group">
                    <div class="page-title-icon">
                        <svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24"
                            stroke-linecap="round" stroke-linejoin="round"
                            style="color: white; width: 22px; height: 22px;">
                            <path
                                d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z">
                            </path>
                        </svg>
                    </div>
                    <h1 class="page-title-modern">System Resources</h1>
                </div>
                <p class="page-subtitle">
                    <svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round"
                        stroke-linejoin="round" style="width: 16px; height: 16px;">
                        <path d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    Real-time monitoring of router and server performance
                    <span class="refresh-indicator">
                        <svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24"
                            stroke-linecap="round" stroke-linejoin="round">
                            <path
                                d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83">
                            </path>
                        </svg>
                        Auto-refresh every 10s
                    </span>
                </p>
            </div>

            <!-- Resources Grid -->
            <div class="resources-grid">

                <!-- Router Card -->
                <div class="resource-card">
                    <div class="card-header-modern">
                        <div class="card-title-group">
                            <div class="card-icon-wrapper router">
                                <svg stroke="white" fill="none" stroke-width="2" viewBox="0 0 24 24"
                                    stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                                    <path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="card-title-modern">Router Resources</h3>
                                <p class="card-subtitle">MikroTik RouterOS</p>
                            </div>
                        </div>
                        <div class="status-badge loading" id="router-status">
                            <span class="status-dot"></span>
                            Loading
                        </div>
                    </div>
                    <div class="card-body-modern" id="router-content">
                        <div class="loading-state">
                            <div class="loading-spinner"></div>
                            <p class="loading-text">Fetching router data...</p>
                        </div>
                    </div>
                </div>

                <!-- Server Card -->
                <div class="resource-card">
                    <div class="card-header-modern">
                        <div class="card-title-group">
                            <div class="card-icon-wrapper server">
                                <svg stroke="white" fill="none" stroke-width="2" viewBox="0 0 24 24"
                                    stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
                                    <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
                                    <line x1="6" y1="6" x2="6.01" y2="6"></line>
                                    <line x1="6" y1="18" x2="6.01" y2="18"></line>
                                </svg>
                            </div>
                            <div>
                                <h3 class="card-title-modern">Server Resources</h3>
                                <p class="card-subtitle">Node.js Application</p>
                            </div>
                        </div>
                        <div class="status-badge loading" id="server-status">
                            <span class="status-dot"></span>
                            Loading
                        </div>
                    </div>
                    <div class="card-body-modern" id="server-content">
                        <div class="loading-state">
                            <div class="loading-spinner"></div>
                            <p class="loading-text">Fetching server data...</p>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </main>

    <%- include('layouts/footer') %>