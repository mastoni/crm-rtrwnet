<%- include('layouts/header') %>

<style>
:root{--d-bg:#f0f4f8;--d-card:#fff;--d-border:#e2e8f0;--d-text:#0f172a;--d-muted:#64748b;--d-blue:#2563eb;--d-blue-l:#eff6ff;--d-green:#059669;--d-red:#dc2626;--d-amber:#d97706}

/* ── Layout helpers ── */
.cp-wrap{font-family:'Inter',-apple-system,sans-serif;padding:0 0 40px}
.cp-row{display:flex;gap:20px;margin-bottom:20px}
.cp-col-left{flex:0 0 340px}
.cp-col-right{flex:1;min-width:0;display:flex;flex-direction:column;gap:20px}
@media(max-width:1100px){.cp-row{flex-direction:column}.cp-col-left{flex:none}}

/* ── Back breadcrumb ── */
.cp-breadcrumb{display:flex;align-items:center;gap:8px;margin-bottom:20px;font-size:13px;color:var(--d-muted)}
.cp-breadcrumb a{color:var(--d-blue);text-decoration:none;font-weight:600;display:inline-flex;align-items:center;gap:5px;transition:opacity.15s}
.cp-breadcrumb a:hover{opacity:.75}
.cp-breadcrumb span{color:var(--d-muted)}

/* ── Card base ── */
.cp-card{background:#fff;border-radius:16px;border:1px solid var(--d-border);overflow:hidden}
.cp-card-hdr{padding:16px 20px;border-bottom:1px solid var(--d-border);display:flex;align-items:center;gap:10px}
.cp-card-hdr-icon{width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.cp-card-hdr-title{font-size:13.5px;font-weight:700;color:var(--d-text)}
.cp-card-body{padding:20px}

/* ── Profile card (left column) ── */
.pf-avatar-wrap{display:flex;flex-direction:column;align-items:center;padding:28px 20px 20px}
.pf-avatar{width:88px;height:88px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:34px;font-weight:800;color:#fff;margin-bottom:14px;position:relative;box-shadow:0 8px 24px rgba(0,0,0,.15)}
.pf-avatar-ring{position:absolute;inset:-4px;border-radius:50%;border:2px solid;opacity:.35}
.pf-name{font-size:18px;font-weight:800;color:var(--d-text);text-align:center;margin-bottom:4px}
.pf-cid{font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--d-blue);background:var(--d-blue-l);padding:3px 10px;border-radius:20px;margin-bottom:12px}
.pf-status{display:inline-flex;align-items:center;gap:6px;padding:5px 14px;border-radius:20px;font-size:12px;font-weight:700}
.pf-status-dot{width:7px;height:7px;border-radius:50%}
.pf-divider{height:1px;background:var(--d-border);margin:0}
.pf-info-list{padding:8px 0}
.pf-info-row{display:flex;align-items:flex-start;gap:12px;padding:10px 20px;font-size:13px;transition:background.1s}
.pf-info-row:hover{background:#f8fafc}
.pf-info-icon{width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:14px}
.pf-info-body{flex:1;min-width:0}
.pf-info-lbl{font-size:11px;font-weight:600;color:var(--d-muted);margin-bottom:1px;letter-spacing:.03em;text-transform:uppercase}
.pf-info-val{font-size:13px;font-weight:500;color:var(--d-text);word-break:break-all}
.pf-info-val.mono{font-family:'DM Mono',monospace;font-size:12.5px}

/* ── Action buttons on profile card ── */
.pf-actions{display:flex;gap:8px;padding:0 20px 20px;flex-wrap:wrap}
.pf-btn{flex:1;padding:9px 14px;border-radius:10px;font-size:12.5px;font-weight:700;cursor:pointer;border:1.5px solid;display:inline-flex;align-items:center;justify-content:center;gap:6px;text-decoration:none;transition:all.15s;white-space:nowrap}
.pf-btn-edit{background:#fff;color:var(--d-blue);border-color:#bfdbfe}
.pf-btn-edit:hover{background:var(--d-blue-l)}
.pf-btn-wa{background:#fff;color:#059669;border-color:#a7f3d0}
.pf-btn-wa:hover{background:#f0fdf9}
.pf-btn-isolir{background:#fff;color:#dc2626;border-color:#fecdd3}
.pf-btn-isolir:hover{background:#fef2f2}

/* ── Stats strip (4-grid) ── */
.stats-strip{display:grid;grid-template-columns:repeat(4,1fr);background:#fff;border-radius:16px;border:1px solid var(--d-border);overflow:hidden}
.stat-cell{padding:18px 20px;border-right:1px solid var(--d-border)}
.stat-cell:last-child{border-right:none}
.stat-val{font-size:26px;font-weight:800;color:var(--d-text);line-height:1;font-family:'Inter',sans-serif}
.stat-lbl{font-size:11.5px;color:var(--d-muted);margin-top:5px;font-weight:500}
.stat-sub{font-size:11px;color:var(--d-muted);margin-top:2px}
@media(max-width:768px){.stats-strip{grid-template-columns:repeat(2,1fr)}.stat-cell:nth-child(2){border-right:none}.stat-cell:nth-child(1),.stat-cell:nth-child(2){border-bottom:1px solid var(--d-border)}}

/* ── Network/billing grid ── */
.info-2col{display:grid;grid-template-columns:1fr 1fr;gap:20px}
@media(max-width:860px){.info-2col{grid-template-columns:1fr}}

/* ── Inline detail rows ── */
.det-row{display:flex;align-items:flex-start;padding:9px 0;border-bottom:1px solid #f1f5f9;font-size:13px;gap:12px}
.det-row:last-child{border-bottom:none}
.det-lbl{width:130px;flex-shrink:0;color:var(--d-muted);font-size:11.5px;font-weight:600;padding-top:1px;letter-spacing:.02em}
.det-val{color:var(--d-text);font-weight:500;flex:1;word-break:break-all}

/* ── Tags / Badges ── */
.tag{display:inline-block;padding:2px 8px;border-radius:6px;font-size:11px;font-weight:700}
.tag-blue{background:#eff6ff;color:#1d4ed8}
.tag-green{background:#f0fdf4;color:#15803d}
.tag-red{background:#fef2f2;color:#991b1b}
.tag-amber{background:#fffbeb;color:#92400e}
.tag-purple{background:#f5f3ff;color:#6d28d9}
.tag-slate{background:#f8fafc;color:#475569}

/* ── Tables ── */
.cp-table{width:100%;border-collapse:collapse;font-size:13px}
.cp-table thead th{text-align:left;padding:10px 16px;font-size:11px;font-weight:600;letter-spacing:.04em;color:var(--d-muted);background:#f8fafc;border-bottom:1px solid var(--d-border);white-space:nowrap}
.cp-table tbody tr{border-bottom:1px solid #f1f5f9;transition:background.1s}
.cp-table tbody tr:hover{background:#f8fafc}
.cp-table tbody tr:last-child{border-bottom:none}
.cp-table td{padding:11px 16px;vertical-align:middle;color:var(--d-text)}
.cp-table .empty-row td{text-align:center;padding:32px;color:var(--d-muted);font-size:13px}
.inv-no{font-family:'DM Mono',monospace;font-size:11.5px;color:#1d4ed8;background:#eff6ff;padding:2px 8px;border-radius:6px;display:inline-block}

/* ── Reward point row ── */
.rw-earn{color:#059669;font-weight:700}
.rw-spend{color:#dc2626;font-weight:700}

/* ── Points badge (hero) ── */
.pf-pts-badge{display:inline-flex;align-items:center;gap:6px;margin-top:10px;padding:6px 14px;border-radius:20px;background:linear-gradient(135deg,#7c3aed,#4f46e5);color:#fff;font-size:12.5px;font-weight:700;box-shadow:0 3px 10px rgba(124,58,237,.3)}

/* ── Due-date urgency colors ── */
.due-overdue{color:#dc2626;font-weight:700}
.due-soon{color:#d97706;font-weight:700}
.due-ok{color:var(--d-text)}

/* ── Animations ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
.a1{animation:fadeUp .35s ease both}
.a2{animation:fadeUp .35s .06s ease both}
.a3{animation:fadeUp .35s .12s ease both}
.a4{animation:fadeUp .35s .18s ease both}
.a5{animation:fadeUp .35s .24s ease both}
.a6{animation:fadeUp .35s .30s ease both}
</style>

<main class="page-content cp-wrap">
<%
/* ── Server-side helpers ── */
const MONTHS=['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
function fmtDate(d){if(!d)return'–';return new Date(d).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'});}
function fmtRp(n){if(!n&&n!==0)return'–';const v=Number(n);if(v>=1e6)return'Rp '+(v/1e6).toFixed(1).replace('.0','')+' jt';if(v>=1e3)return'Rp '+(v/1e3).toFixed(0)+' rb';return'Rp '+v.toLocaleString('id-ID');}
function fmtRpFull(n){if(!n)return'Rp 0';return'Rp '+Number(n).toLocaleString('id-ID');}

const AVATAR_COLORS=['#2563eb','#0891b2','#059669','#d97706','#dc2626','#0284c7','#16a34a','#ea580c','#7c3aed'];
let h=0;for(let i=0;i<(customer.name||'').length;i++)h=((h<<5)-h)+customer.name.charCodeAt(i);
const avColor=AVATAR_COLORS[Math.abs(h)%AVATAR_COLORS.length];
const initial=(customer.name||'?')[0].toUpperCase();

const stMap={
  active:  {cls:'sb-active',  dot:'#059669',lbl:'Aktif',bg:'#f0fdf4',fc:'#15803d'},
  isolated:{cls:'sb-iso',     dot:'#dc2626',lbl:'Isolir',bg:'#fef2f2',fc:'#991b1b'},
  suspended:{cls:'sb-sus',    dot:'#d97706',lbl:'Suspended',bg:'#fffbeb',fc:'#92400e'},
  inactive:{cls:'sb-inact',   dot:'#94a3b8',lbl:'Nonaktif',bg:'#f8fafc',fc:'#475569'},
};
const st=stMap[customer.status]||stMap.inactive;

const today=new Date();today.setHours(0,0,0,0);
const due=customer.due_date?new Date(customer.due_date+'T00:00:00'):null;
const dueDiff=due?Math.round((due-today)/86400000):null;

function invStatusTag(s){
  if(s==='paid')   return '<span class="tag tag-green">✓ Lunas</span>';
  if(s==='overdue')return '<span class="tag tag-red">✗ Overdue</span>';
  return '<span class="tag tag-amber">⏳ Belum Bayar</span>';
}
%>

<!-- ══ Breadcrumb ══ -->
<div class="cp-breadcrumb a1">
  <a href="/customers">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    Customer
  </a>
  <span>/</span>
  <span><%= customer.name %></span>
</div>

<!-- ══ Main layout: left column (profile card) + right column ══ -->
<div class="cp-row">

  <!-- ── LEFT: Profile Card ── -->
  <div class="cp-col-left a2">
    <div class="cp-card">

      <!-- Avatar + basic info -->
      <div class="pf-avatar-wrap">
        <div class="pf-avatar" style="background:<%=avColor%>">
          <%= initial %>
          <div class="pf-avatar-ring" style="border-color:<%=avColor%>"></div>
        </div>
        <div class="pf-name"><%= customer.name %></div>
        <div class="pf-cid"><%= customer.customer_id || '–' %></div>
        <div class="pf-status" style="background:<%=st.bg%>;color:<%=st.fc%>">
          <span class="pf-status-dot" style="background:<%=st.dot%>"></span>
          <%=st.lbl%>
        </div>
        <% if(stats.totalPoints > 0){ %>
        <div class="pf-pts-badge">
          ⭐ <%= stats.totalPoints.toLocaleString('id-ID') %> Points
        </div>
        <% } %>
      </div>

      <!-- Action buttons -->
      <div class="pf-actions">
        <% if(customer.phone){ %>
        <a href="https://wa.me/<%= customer.phone.replace(/[^0-9]/g,'').replace(/^0/,'62') %>" target="_blank" class="pf-btn pf-btn-wa">
          <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
        <% } %>
        <a href="/customers" onclick="event.preventDefault();history.back();setTimeout(()=>editCustomer(<%=customer.id%>),400)" class="pf-btn pf-btn-edit">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Edit
        </a>
      </div>

      <div class="pf-divider"></div>

      <!-- Info rows -->
      <div class="pf-info-list">
        <div class="pf-info-row">
          <div class="pf-info-icon" style="background:#eff6ff">📞</div>
          <div class="pf-info-body">
            <div class="pf-info-lbl">No. HP / WA</div>
            <div class="pf-info-val"><%= customer.phone || '–' %></div>
          </div>
        </div>
        <div class="pf-info-row">
          <div class="pf-info-icon" style="background:#f0fdf9">✉️</div>
          <div class="pf-info-body">
            <div class="pf-info-lbl">Email</div>
            <div class="pf-info-val"><%= customer.email || '–' %></div>
          </div>
        </div>
        <div class="pf-info-row">
          <div class="pf-info-icon" style="background:#fffbeb">📍</div>
          <div class="pf-info-body">
            <div class="pf-info-lbl">Alamat</div>
            <div class="pf-info-val"><%= customer.address || '–' %></div>
          </div>
        </div>
        <div class="pf-info-row">
          <div class="pf-info-icon" style="background:#fdf4ff">📅</div>
          <div class="pf-info-body">
            <div class="pf-info-lbl">Tgl Aktivasi</div>
            <div class="pf-info-val"><%- fmtDate(customer.installation_date) %></div>
          </div>
        </div>
        <div class="pf-info-row">
          <div class="pf-info-icon" style="background:#fef2f2">🗓️</div>
          <div class="pf-info-body">
            <div class="pf-info-lbl">Jatuh Tempo</div>
            <div class="pf-info-val">
              <% if(due){ %>
                <span class="<%=dueDiff<0?'due-overdue':dueDiff<=3?'due-soon':'due-ok'%>">
                  <%- fmtDate(customer.due_date) %>
                </span>
                <% if(dueDiff<0){ %><span class="tag tag-red" style="margin-left:5px"><%= Math.abs(dueDiff) %>h lalu</span>
                <% } else if(dueDiff===0){ %><span class="tag tag-amber" style="margin-left:5px">Hari ini</span>
                <% } else if(dueDiff<=3){ %><span class="tag tag-amber" style="margin-left:5px"><%=dueDiff%> hari</span>
                <% } %>
              <% } else { %>–<% } %>
            </div>
          </div>
        </div>
        <div class="pf-info-row">
          <div class="pf-info-icon" style="background:#f0fdf9">🌐</div>
          <div class="pf-info-body">
            <div class="pf-info-lbl">Portal Login</div>
            <div class="pf-info-val">
              <% if(customer.portal_enabled){ %><span class="tag tag-green">Aktif</span><% } else { %><span class="tag tag-slate">Nonaktif</span><% } %>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /cp-card -->
  </div><!-- /col-left -->

  <!-- ── RIGHT column ── -->
  <div class="cp-col-right">

    <!-- Stats Strip -->
    <div class="stats-strip a2">
      <div class="stat-cell">
        <div class="stat-val"><%= stats.totalInvoices %></div>
        <div class="stat-lbl">Total Invoice</div>
      </div>
      <div class="stat-cell">
        <div class="stat-val" style="color:#059669"><%= stats.paidCount %></div>
        <div class="stat-lbl">Sudah Lunas</div>
        <div class="stat-sub"><%= stats.paidCount %> / <%= stats.totalInvoices %></div>
      </div>
      <div class="stat-cell">
        <div class="stat-val" style="color:<%=stats.overdueCount>0?'#dc2626':'#0f172a'%>"><%= stats.overdueCount %></div>
        <div class="stat-lbl">Overdue</div>
        <div class="stat-sub"><%=stats.overdueCount>0?'Perlu tindakan':'Aman'%></div>
      </div>
      <div class="stat-cell">
        <div class="stat-val" style="font-size:20px;color:#7c3aed">⭐ <%= stats.totalPoints.toLocaleString('id-ID') %></div>
        <div class="stat-lbl">Reward Points</div>
        <div class="stat-sub"><%- fmtRpFull(stats.totalPaid) %> dibayar</div>
      </div>
    </div>

    <!-- Network + Package info side by side -->
    <div class="info-2col a3">

      <!-- Paket Internet -->
      <div class="cp-card">
        <div class="cp-card-hdr">
          <div class="cp-card-hdr-icon" style="background:#eff6ff">📶</div>
          <span class="cp-card-hdr-title">Paket Internet</span>
        </div>
        <div class="cp-card-body">
          <div class="det-row">
            <div class="det-lbl">Paket</div>
            <div class="det-val"><% if(customer.package_name){ %><span class="tag tag-blue"><%= customer.package_name %></span><% }else{ %>–<% } %></div>
          </div>
          <div class="det-row">
            <div class="det-lbl">Harga/Bulan</div>
            <div class="det-val" style="font-weight:700;color:#1d4ed8"><%- fmtRpFull(customer.package_price) %></div>
          </div>
          <div class="det-row">
            <div class="det-lbl">Kecepatan</div>
            <div class="det-val">
              <% if(customer.speed_down||customer.speed_up){ %>
              <span style="font-family:'DM Mono',monospace;font-size:12px">↓ <%= customer.speed_down||'–' %> / ↑ <%= customer.speed_up||'–' %> Mbps</span>
              <% }else{ %>–<% } %>
            </div>
          </div>
          <div class="det-row">
            <div class="det-lbl">PPPoE</div>
            <div class="det-val" style="font-family:'DM Mono',monospace;font-size:12.5px"><%= customer.pppoe_username||'–' %></div>
          </div>
          <div class="det-row">
            <div class="det-lbl">Static IP</div>
            <div class="det-val" style="font-family:'DM Mono',monospace;font-size:12.5px"><%= customer.static_ip||'–' %></div>
          </div>
          <div class="det-row">
            <div class="det-lbl">ONT SN</div>
            <div class="det-val" style="font-family:'DM Mono',monospace;font-size:12.5px"><%= customer.ont_sn||'–' %></div>
          </div>
          <div class="det-row">
            <div class="det-lbl">Router</div>
            <div class="det-val">
              <% if(customer.router_name){ %>
              <span class="tag tag-blue"><%= customer.router_name %></span>
              <span style="font-size:11px;color:var(--d-muted);margin-left:5px;font-family:'DM Mono',monospace"><%= customer.router_ip||'' %></span>
              <% }else{ %>–<% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Tagihan Summary -->
      <div class="cp-card">
        <div class="cp-card-hdr">
          <div class="cp-card-hdr-icon" style="background:#fffbeb">💳</div>
          <span class="cp-card-hdr-title">Ringkasan Tagihan</span>
        </div>
        <div class="cp-card-body">
          <div class="det-row">
            <div class="det-lbl">Total Invoice</div>
            <div class="det-val"><%= stats.totalInvoices %> tagihan</div>
          </div>
          <div class="det-row">
            <div class="det-lbl">Sudah Lunas</div>
            <div class="det-val" style="color:#059669;font-weight:700"><%= stats.paidCount %> invoice</div>
          </div>
          <div class="det-row">
            <div class="det-lbl">Overdue</div>
            <div class="det-val">
              <% if(stats.overdueCount>0){ %>
              <span class="tag tag-red"><%= stats.overdueCount %> overdue</span>
              <% }else{ %><span class="tag tag-green">Tidak ada</span><% } %>
            </div>
          </div>
          <div class="det-row">
            <div class="det-lbl">Total Dibayar</div>
            <div class="det-val" style="font-weight:700;color:#059669"><%- fmtRpFull(stats.totalPaid) %></div>
          </div>
          <div class="det-row">
            <div class="det-lbl">Reward Points</div>
            <div class="det-val">
              <span style="font-weight:700;color:#7c3aed">⭐ <%= stats.totalPoints.toLocaleString('id-ID') %> pts</span>
            </div>
          </div>
          <div class="det-row">
            <div class="det-lbl">Jatuh Tempo</div>
            <div class="det-val">
              <% if(due){ %>
              <span class="<%=dueDiff<0?'due-overdue':dueDiff<=3?'due-soon':'due-ok'%>"><%- fmtDate(customer.due_date) %></span>
              <% if(dueDiff!==null&&dueDiff<0){ %>&nbsp;<span class="tag tag-red">Terlambat</span>
              <% }else if(dueDiff===0){ %>&nbsp;<span class="tag tag-amber">Hari ini</span>
              <% }else if(dueDiff<=3){ %>&nbsp;<span class="tag tag-amber"><%=dueDiff%> hari lagi</span>
              <% } %>
              <% }else{ %>–<% } %>
            </div>
          </div>
          <div class="det-row">
            <div class="det-lbl">Aktivasi</div>
            <div class="det-val"><%- fmtDate(customer.installation_date) %></div>
          </div>
        </div>
      </div>

    </div><!-- /info-2col -->

  </div><!-- /col-right -->
</div><!-- /cp-row -->

<!-- ══ Invoice History ══ -->
<div class="cp-card a4" style="margin-bottom:20px">
  <div class="cp-card-hdr">
    <div class="cp-card-hdr-icon" style="background:#eff6ff">🧾</div>
    <span class="cp-card-hdr-title">Riwayat Invoice</span>
    <span style="margin-left:auto;font-size:12px;color:var(--d-muted)"><%= stats.totalInvoices %> invoice terakhir</span>
  </div>
  <div style="overflow-x:auto">
    <table class="cp-table">
      <thead>
        <tr>
          <th>No Invoice</th>
          <th>Periode</th>
          <th>Jumlah</th>
          <th>Jatuh Tempo</th>
          <th>Tgl Bayar</th>
          <th>Status</th>
          <th style="text-align:center">Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if(!invoices.length){ %>
        <tr class="empty-row"><td colspan="7">📄 Belum ada invoice</td></tr>
        <% } else { invoices.forEach(inv=>{ %>
        <tr>
          <td><span class="inv-no"><%= inv.invoice_number||('INV-'+String(inv.id).padStart(5,'0')) %></span></td>
          <td style="color:var(--d-muted)"><%= MONTHS[(inv.period_month||1)-1] %> <%= inv.period_year %></td>
          <td style="font-weight:700;color:#1d4ed8"><%- fmtRpFull(inv.amount) %></td>
          <td style="color:var(--d-muted)"><%- fmtDate(inv.due_date) %></td>
          <td style="color:var(--d-muted)"><%- fmtDate(inv.paid_date) %></td>
          <td><%- invStatusTag(inv.status) %></td>
          <td style="text-align:center">
            <a href="/invoice/inv/<%= inv.id %>" target="_blank" title="Lihat Invoice" style="display:inline-flex;align-items:center;gap:4px;font-size:12px;font-weight:600;color:#1d4ed8;text-decoration:none;padding:4px 10px;border-radius:7px;border:1px solid #bfdbfe;background:#fff;transition:all.15s" onmouseenter="this.style.background='#eff6ff'" onmouseleave="this.style.background='#fff'">
              <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              Lihat
            </a>
          </td>
        </tr>
        <% }) } %>
      </tbody>
    </table>
  </div>
</div>

<!-- ══ Payment History ══ -->
<div class="cp-card a5" style="margin-bottom:20px">
  <div class="cp-card-hdr">
    <div class="cp-card-hdr-icon" style="background:#f0fdf4">💰</div>
    <span class="cp-card-hdr-title">Riwayat Pembayaran</span>
    <span style="margin-left:auto;font-size:12px;color:var(--d-muted)"><%= payments.length %> transaksi terakhir</span>
  </div>
  <div style="overflow-x:auto">
    <table class="cp-table">
      <thead>
        <tr>
          <th>No Invoice</th>
          <th>Jumlah</th>
          <th>Metode</th>
          <th>No Referensi</th>
          <th>Tgl Bayar</th>
        </tr>
      </thead>
      <tbody>
        <% if(!payments.length){ %>
        <tr class="empty-row"><td colspan="5">💸 Belum ada pembayaran</td></tr>
        <% } else { payments.forEach(p=>{ %>
        <tr>
          <td><span class="inv-no"><%= p.invoice_number||('INV-'+String(p.invoice_id).padStart(5,'0')) %></span></td>
          <td style="font-weight:700;color:#059669"><%- fmtRpFull(p.amount) %></td>
          <td><span class="tag tag-blue"><%= p.payment_method||'–' %></span></td>
          <td style="font-family:'DM Mono',monospace;font-size:11.5px;color:var(--d-muted)"><%= p.reference_number||'–' %></td>
          <td style="color:var(--d-muted)"><%- fmtDate(p.payment_date) %></td>
        </tr>
        <% }) } %>
      </tbody>
    </table>
  </div>
</div>

<!-- ══ Reward Point History ══ -->
<div class="cp-card a6">
  <div class="cp-card-hdr">
    <div class="cp-card-hdr-icon" style="background:#f5f3ff">⭐</div>
    <span class="cp-card-hdr-title">Riwayat Reward Point</span>
    <span style="margin-left:auto;font-size:12px;color:var(--d-muted)">Total: <strong style="color:#7c3aed">⭐ <%= stats.totalPoints.toLocaleString('id-ID') %> pts</strong></span>
  </div>
  <div style="overflow-x:auto">
    <table class="cp-table">
      <thead>
        <tr>
          <th>Tanggal</th>
          <th>Tipe</th>
          <th>Poin</th>
          <th>Keterangan</th>
          <th>Referensi</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% if(!rewardHistory.length){ %>
        <tr class="empty-row"><td colspan="6">⭐ Belum ada riwayat reward point</td></tr>
        <% } else { rewardHistory.forEach(r=>{ %>
        <tr>
          <td style="color:var(--d-muted);white-space:nowrap"><%- fmtDate(r.created_at) %></td>
          <td>
            <% if(r.type==='earn'||r.type==='credit'||r.type==='bonus'){ %>
            <span class="tag tag-green">+ Earn</span>
            <% } else if(r.type==='redeem'||r.type==='debit'||r.type==='spend'){ %>
            <span class="tag tag-red">− Redeem</span>
            <% } else { %>
            <span class="tag tag-slate"><%= r.type %></span>
            <% } %>
          </td>
          <td>
            <% if(r.type==='earn'||r.type==='credit'||r.type==='bonus'){ %>
            <span class="rw-earn">+<%= r.points %></span>
            <% } else { %>
            <span class="rw-spend">−<%= Math.abs(r.points) %></span>
            <% } %>
          </td>
          <td style="color:var(--d-text);max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= r.description||'' %>">
            <%= r.item_name || r.description || '–' %>
          </td>
          <td style="font-family:'DM Mono',monospace;font-size:11.5px;color:var(--d-muted)"><%= r.reference_id||'–' %></td>
          <td>
            <% if(r.status==='approved'){ %><span class="tag tag-green">Approved</span>
            <% } else if(r.status==='pending'){ %><span class="tag tag-amber">Pending</span>
            <% } else if(r.status==='rejected'){ %><span class="tag tag-red">Rejected</span>
            <% } else { %><span class="tag tag-slate"><%= r.status||'–' %></span><% } %>
          </td>
        </tr>
        <% }) } %>
      </tbody>
    </table>
  </div>
</div>

</main>

<%- include('layouts/footer') %>
